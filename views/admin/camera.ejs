<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script>
    (function(){
        try {
            const s = JSON.parse(localStorage.getItem('yuraSettings') || '{}');
            if (s.darkMode === false) {
                const st = document.createElement('style');
                st.id = '__yuraLight';
                st.textContent = `
                    body { background: #f0f2f5 !important; color: #111 !important; }
                    .sidebar { background: #fff !important; border-color: rgba(0,0,0,0.1) !important; }
                    .top-bar { background: #fff !important; border-color: rgba(0,0,0,0.1) !important; }
                    .main-content, .content { background: #f0f2f5 !important; }
                    .cam-main-wrap, .cam-thumb, .ctrl-panel, .filters-panel { background: #fff !important; border-color: rgba(0,0,0,0.08) !important; }
                    .nav-item { color: #555 !important; }
                    .nav-item:hover { background: rgba(0,0,0,0.04) !important; color: #111 !important; }
                    .nav-item.active { color: var(--rouge) !important; background: rgba(192,57,43,0.07) !important; }
                    .logo-name, .user-name-s, h1 { color: #111 !important; }
                    .logo-sub, .user-role-s, .topbar-title { color: #666 !important; }
                    .topbar-user { background: rgba(192,57,43,0.07) !important; border-color: rgba(192,57,43,0.2) !important; }
                    .robot-badge { background: rgba(192,57,43,0.07) !important; border-color: rgba(192,57,43,0.25) !important; }
                    .ctrl-btn { background: rgba(0,0,0,0.05) !important; border-color: rgba(0,0,0,0.1) !important; color: #555 !important; }
                    .slider-wrap label { color: #666 !important; }
                    .panel-title { color: #888 !important; }
                    .cam-label { color: #333 !important; }
                `;
                document.head.appendChild(st);
            }
            if (s.colorTheme === 'blue-black') {
                document.documentElement.style.setProperty('--rouge', '#2563eb');
                document.documentElement.style.setProperty('--rouge-light', '#3b82f6');
                document.documentElement.style.setProperty('--border', 'rgba(37,99,235,0.18)');
            } else if (s.colorTheme === 'green-black') {
                document.documentElement.style.setProperty('--rouge', '#16a34a');
                document.documentElement.style.setProperty('--rouge-light', '#22c55e');
                document.documentElement.style.setProperty('--border', 'rgba(22,163,74,0.18)');
            }
        } catch(e) {}
    })();
    </script>
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        :root {
            --rouge:#c0392b; --rouge-light:#e74c3c;
            --noir:#0a0a0a; --card:#111111;
            --border:rgba(192,57,43,0.18); --gris:#888; --gris2:#bbb;
        }
        body { font-family:'Segoe UI',sans-serif; background:var(--noir); color:#fff; display:flex; min-height:100vh; }

        /* SIDEBAR */
        .sidebar { width:300px; min-height:100vh; background:#0d0d0d; border-right:1px solid var(--border); display:flex; flex-direction:column; position:fixed; top:0; left:0; bottom:0; z-index:100; }
        .logo-section { padding:20px 18px; border-bottom:1px solid var(--border); display:flex; align-items:center; gap:14px; }
        .logo-name { font-size:1.1rem; font-weight:800; color:#fff; letter-spacing:2px; }
        .logo-sub { font-size:0.65rem; color:var(--gris); letter-spacing:2px; text-transform:uppercase; }
        .admin-badge-side { margin:12px 16px 4px; padding:8px 14px; background:rgba(192,57,43,0.2); border:1px solid rgba(192,57,43,0.5); border-radius:6px; font-size:0.7rem; font-weight:800; color:var(--rouge-light); letter-spacing:2px; text-transform:uppercase; text-align:center; }
        .robot-badge { margin:8px 16px 6px; padding:10px 16px; background:rgba(192,57,43,0.12); border:1px solid rgba(192,57,43,0.4); border-radius:8px; display:flex; align-items:center; gap:10px; font-size:0.75rem; font-weight:700; color:var(--rouge-light); }
        .badge-dot { width:8px; height:8px; background:var(--rouge-light); border-radius:50%; animation:blink 1.2s infinite; }
        @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.1} }
        .nav-section { padding:8px 0; flex:1; overflow-y:auto; }
        .nav-label { font-size:0.6rem; font-weight:700; color:var(--gris); letter-spacing:2px; padding:12px 18px 5px; text-transform:uppercase; }
        .nav-item { display:flex; align-items:center; gap:13px; padding:11px 18px; color:#666; text-decoration:none; font-size:0.87rem; font-weight:500; border-left:2px solid transparent; transition:all 0.18s; }
        .nav-item:hover { color:#fff; background:rgba(192,57,43,0.07); }
        .nav-item.active { color:#fff; background:rgba(192,57,43,0.13); border-left-color:var(--rouge); font-weight:600; }
        .nav-icon-wrap { width:20px; height:20px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
        .nav-text { flex:1; }
        .nav-count { background:var(--rouge); color:#fff; font-size:0.6rem; font-weight:700; padding:2px 7px; border-radius:10px; }
        .sidebar-footer { border-top:1px solid var(--border); padding:8px 0; }
        .user-row { display:flex; align-items:center; gap:10px; padding:11px 18px; }
        .user-av { width:34px; height:34px; background:linear-gradient(135deg,var(--rouge),#7b241c); border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:0.85rem; font-weight:700; flex-shrink:0; }
        .user-name-s { font-size:0.82rem; font-weight:600; }
        .user-role-s { font-size:0.65rem; color:var(--rouge-light); font-weight:600; }

        /* MAIN */
        .main-content { margin-left:300px; flex:1; display:flex; flex-direction:column; min-height:100vh; }
        .top-bar { height:52px; background:#0d0d0d; border-bottom:1px solid var(--border); display:flex; align-items:center; padding:0 24px; gap:12px; position:sticky; top:0; z-index:50; }
        .topbar-title { font-size:0.78rem; color:var(--gris); letter-spacing:1.5px; text-transform:uppercase; flex:1; }
        .topbar-right { display:flex; align-items:center; gap:10px; }
        .topbar-bell { position:relative; cursor:pointer; text-decoration:none; }
        .bell-badge { position:absolute; top:-4px; right:-4px; width:16px; height:16px; background:var(--rouge); border-radius:50%; font-size:0.6rem; color:#fff; font-weight:700; display:flex; align-items:center; justify-content:center; }
        .topbar-user { display:flex; align-items:center; gap:7px; background:rgba(192,57,43,0.12); border:1px solid rgba(192,57,43,0.35); padding:5px 14px; border-radius:20px; font-size:0.75rem; font-weight:700; color:var(--rouge-light); text-decoration:none; }
        .user-dot { width:7px; height:7px; background:var(--rouge-light); border-radius:50%; }
        .admin-pill { background:rgba(192,57,43,0.25); border:1px solid rgba(192,57,43,0.5); padding:4px 10px; border-radius:4px; font-size:0.62rem; font-weight:800; color:var(--rouge-light); letter-spacing:1.5px; text-transform:uppercase; }

        /* CONTENT */
        .content { padding:20px 24px; flex:1; display:flex; flex-direction:column; gap:14px; }
        .page-header { display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:10px; }
        .page-header h1 { font-size:1.6rem; font-weight:800; }
        .page-header p { font-size:0.8rem; color:var(--gris); margin-top:3px; }
        .rec-indicator { display:flex; align-items:center; gap:7px; background:rgba(192,57,43,0.1); border:1px solid rgba(192,57,43,0.3); padding:6px 14px; border-radius:20px; font-size:0.75rem; font-weight:700; color:var(--rouge-light); }
        .rec-dot { width:8px; height:8px; background:var(--rouge); border-radius:50%; animation:blink 0.8s infinite; }

        /* MAIN LAYOUT */
        .cam-layout { display:grid; grid-template-columns:1fr 280px; gap:14px; }

        /* MAIN CAM */
        .cam-main-wrap { background:var(--card); border:1px solid rgba(255,255,255,0.06); border-radius:12px; overflow:hidden; position:relative; }
        .cam-main-feed { width:100%; aspect-ratio:16/9; background:#000; position:relative; overflow:hidden; display:flex; align-items:center; justify-content:center; }
        .cam-feed-bg { position:absolute; inset:0; background:radial-gradient(ellipse at center, #0a1628 0%, #050a14 100%); }
        .cam-scanline { position:absolute; inset:0; background:repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,255,0,0.015) 2px, rgba(0,255,0,0.015) 4px); pointer-events:none; z-index:2; }
        .cam-grid-overlay { position:absolute; inset:0; background-image:linear-gradient(rgba(255,255,255,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.03) 1px,transparent 1px); background-size:60px 60px; z-index:2; display:none; }
        .cam-grid-overlay.show { display:block; }
        .cam-crosshair { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); z-index:3; opacity:0.3; }
        .cam-noise { position:absolute; inset:0; opacity:0.04; background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E"); z-index:1; }
        .cam-robot-dot { position:absolute; width:14px; height:14px; background:var(--rouge); border-radius:50%; border:2px solid var(--rouge-light); box-shadow:0 0 10px rgba(192,57,43,0.8); top:45%; left:52%; z-index:4; animation:float 3s ease-in-out infinite; }
        @keyframes float { 0%,100%{transform:translate(0,0)} 50%{transform:translate(3px,-3px)} }
        .cam-robot-dot::after { content:''; position:absolute; inset:-6px; border-radius:50%; border:1px solid rgba(192,57,43,0.5); animation:ping 1.5s infinite; }
        @keyframes ping { 0%{transform:scale(1);opacity:0.8} 100%{transform:scale(2.5);opacity:0} }

        /* CAM OVERLAYS */
        .cam-overlay-tl { position:absolute; top:12px; left:12px; z-index:5; display:flex; flex-direction:column; gap:5px; }
        .cam-overlay-tr { position:absolute; top:12px; right:12px; z-index:5; display:flex; flex-direction:column; align-items:flex-end; gap:5px; }
        .cam-overlay-bl { position:absolute; bottom:12px; left:12px; z-index:5; }
        .cam-overlay-br { position:absolute; bottom:12px; right:12px; z-index:5; }
        .cam-chip { background:rgba(0,0,0,0.7); border:1px solid rgba(255,255,255,0.1); border-radius:5px; padding:4px 9px; font-size:0.65rem; font-weight:700; color:#fff; letter-spacing:0.5px; backdrop-filter:blur(4px); }
        .cam-chip.live { background:rgba(192,57,43,0.8); border-color:var(--rouge); }
        .cam-chip.rec { background:rgba(192,57,43,0.6); animation:blink 1s infinite; }
        .cam-chip.night { background:rgba(0,50,100,0.8); border-color:#3b82f6; color:#93c5fd; }
        .cam-zoom-val { background:rgba(0,0,0,0.6); border:1px solid rgba(255,255,255,0.12); border-radius:5px; padding:3px 8px; font-size:0.62rem; color:#aaa; }
        .cam-timestamp { font-size:0.6rem; color:#888; font-family:monospace; }

        /* CAM CONTROLS BAR */
        .cam-controls-bar { padding:12px 16px; display:flex; align-items:center; gap:8px; border-top:1px solid rgba(255,255,255,0.05); flex-wrap:wrap; }
        .ctrl-btn { display:flex; align-items:center; gap:5px; padding:7px 12px; background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); border-radius:7px; color:#888; font-size:0.73rem; font-weight:600; cursor:pointer; transition:all 0.15s; white-space:nowrap; }
        .ctrl-btn:hover { background:rgba(192,57,43,0.12); border-color:rgba(192,57,43,0.3); color:#fff; }
        .ctrl-btn.active { background:rgba(192,57,43,0.18); border-color:rgba(192,57,43,0.45); color:var(--rouge-light); }
        .ctrl-btn.danger { border-color:rgba(192,57,43,0.25); color:var(--rouge-light); }
        .ctrl-btn.danger:hover { background:rgba(192,57,43,0.2); }
        .ctrl-btn.success { border-color:rgba(39,174,96,0.3); color:#27ae60; background:rgba(39,174,96,0.08); }
        .ctrl-sep { width:1px; height:24px; background:rgba(255,255,255,0.06); margin:0 2px; }

        /* RIGHT PANEL */
        .right-panel { display:flex; flex-direction:column; gap:12px; }

        /* THUMBNAILS */
        .thumbs-grid { display:grid; grid-template-columns:1fr 1fr; gap:8px; }
        .cam-thumb { background:#0a0a0a; border:1px solid rgba(255,255,255,0.06); border-radius:9px; overflow:hidden; cursor:pointer; transition:all 0.2s; position:relative; }
        .cam-thumb:hover { border-color:rgba(192,57,43,0.35); transform:scale(1.02); }
        .cam-thumb.active-thumb { border-color:var(--rouge); box-shadow:0 0 10px rgba(192,57,43,0.3); }
        .cam-thumb-feed { aspect-ratio:16/9; background:radial-gradient(ellipse at 60% 40%, #0d1a2e, #050a14); position:relative; display:flex; align-items:center; justify-content:center; }
        .cam-thumb-dot { width:6px; height:6px; background:var(--rouge); border-radius:50%; opacity:0.7; }
        .cam-thumb-label { padding:5px 8px; display:flex; align-items:center; justify-content:space-between; }
        .cam-label { font-size:0.65rem; font-weight:700; color:#888; }
        .cam-status-dot { width:5px; height:5px; border-radius:50%; }
        .cam-status-dot.on  { background:#27ae60; box-shadow:0 0 4px rgba(39,174,96,0.6); }
        .cam-status-dot.off { background:#333; }

        /* FILTERS PANEL */
        .panel-card { background:var(--card); border:1px solid rgba(255,255,255,0.06); border-radius:11px; padding:16px; }
        .panel-title { font-size:0.65rem; font-weight:700; color:var(--gris); text-transform:uppercase; letter-spacing:1.5px; margin-bottom:12px; }
        .slider-wrap { margin-bottom:10px; }
        .slider-wrap label { font-size:0.7rem; color:#888; display:flex; justify-content:space-between; margin-bottom:5px; }
        .slider-wrap label span { color:var(--rouge-light); font-weight:700; }
        input[type=range] { width:100%; accent-color:var(--rouge); cursor:pointer; }
        .toggle-row { display:flex; align-items:center; justify-content:space-between; padding:7px 0; border-bottom:1px solid rgba(255,255,255,0.04); }
        .toggle-row:last-child { border-bottom:none; }
        .toggle-label { font-size:0.75rem; color:#888; }
        .toggle-sw { width:34px; height:18px; background:rgba(255,255,255,0.08); border-radius:9px; position:relative; cursor:pointer; transition:background 0.2s; flex-shrink:0; }
        .toggle-sw.on { background:var(--rouge); }
        .toggle-sw::after { content:''; position:absolute; top:3px; left:3px; width:12px; height:12px; background:#fff; border-radius:50%; transition:transform 0.2s; }
        .toggle-sw.on::after { transform:translateX(16px); }

        /* SNAPSHOT FLASH */
        .snap-flash { position:fixed; inset:0; background:#fff; opacity:0; pointer-events:none; z-index:9999; transition:opacity 0.05s; }
        .snap-flash.flash { opacity:0.6; }

        @keyframes fadeInUp { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }
        .cam-main-wrap { animation:fadeInUp 0.3s ease both; }
        .panel-card { animation:fadeInUp 0.35s ease both; }
    </style>
</head>
<body>

<div class="snap-flash" id="snapFlash"></div>

<!-- SIDEBAR -->
<aside class="sidebar">
    <div class="logo-section">
        <img src="/images/logo robot.png" alt="YURA" style="width:42px;height:42px;object-fit:contain;border-radius:8px;flex-shrink:0;">
        <div>
            <div class="logo-name">YURA</div>
            <div class="logo-sub">Guardian System</div>
        </div>
    </div>
    <div class="admin-badge-side">⚡ ADMIN PANEL</div>
    <div class="robot-badge">
        <div class="badge-dot"></div>
        <span>ROBOT EN LIGNE</span>
    </div>
    <div class="nav-section">
        <div class="nav-label">Administration</div>
        <a href="/admin/dashboard" class="nav-item">
            <span class="nav-icon-wrap"><svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor"><rect x="1" y="1" width="6" height="6" rx="1"/><rect x="9" y="1" width="6" height="6" rx="1"/><rect x="1" y="9" width="6" height="6" rx="1"/><rect x="9" y="9" width="6" height="6" rx="1"/></svg></span>
