        <a href="/admin/notifications" class="nav-item">
            <span class="nav-icon-wrap"><svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1a5 5 0 00-5 5v3l-1.5 2.5h13L13 9V6a5 5 0 00-5-5zm0 14a2 2 0 01-2-2h4a2 2 0 01-2 2z"/></svg></span>
            <span class="nav-text">Alertes</span>
            <span class="nav-count">3</span>
        </a>
        <div class="nav-label">Agent</div>
        <a href="/dashboard/security" class="nav-item">
            <span class="nav-icon-wrap"><svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1L2 4v5c0 4.5 3 7.5 6 8.5C11 16.5 14 13.5 14 9V4L8 1z"/></svg></span>
            <span class="nav-text">Vue Agent</span>
        </a>
    </div>
    <div class="sidebar-footer">
        <div class="user-row">
            <div class="user-av"><%= user.name.charAt(0).toUpperCase() %></div>
            <div>
                <div class="user-name-s"><%= user.name %></div>
                <div class="user-role-s">Administrateur</div>
            </div>
        </div>
        <a href="/logout" class="nav-item" style="color:#555;">
            <span class="nav-icon-wrap"><svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor"><path d="M6 2H3a1 1 0 00-1 1v10a1 1 0 001 1h3v-1.5H3.5v-9H6V2zm4.5 3.5L13 8l-2.5 2.5-1-1L11 8H6V6.5h5l-1.5-1.5 1-1z"/></svg></span>
            <span class="nav-text">Déconnexion</span>
        </a>
    </div>
</aside>

<!-- MAIN -->
<div class="main-content">
    <div class="top-bar">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="#888"><rect y="3" width="18" height="2"/><rect y="8" width="18" height="2"/><rect y="13" width="18" height="2"/></svg>
        <span class="topbar-title">Surveillance Caméras</span>
        <div class="topbar-right">
            <span class="admin-pill">ADMIN</span>
            <a href="/notifications" class="topbar-bell">
                <svg width="18" height="18" viewBox="0 0 16 16" fill="#888"><path d="M8 1a5 5 0 00-5 5v3l-1.5 2.5h13L13 9V6a5 5 0 00-5-5zm0 14a2 2 0 01-2-2h4a2 2 0 01-2 2z"/></svg>
                <div class="bell-badge">3</div>
            </a>
            <a href="/dashboard/settings" class="topbar-user"><div class="user-dot"></div><%= user.name %></a>
        </div>
    </div>

    <div class="content">
        <!-- HEADER -->
        <div class="page-header">
            <div>
                <h1>Caméras</h1>
                <p>Surveillance multi-caméras — YURA-001</p>
            </div>
            <div class="rec-indicator">
                <div class="rec-dot"></div>
                REC — 4 caméras actives
            </div>
        </div>

        <!-- CAM LAYOUT -->
        <div class="cam-layout">

            <!-- MAIN CAM -->
            <div class="cam-main-wrap">
                <div class="cam-main-feed" id="mainFeed">
                    <div class="cam-feed-bg"></div>
                    <div class="cam-noise"></div>
                    <div class="cam-scanline"></div>
                    <div class="cam-grid-overlay" id="gridOverlay"></div>
                    <div class="cam-crosshair">
                        <svg width="60" height="60" viewBox="0 0 60 60" fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="1">
                            <line x1="30" y1="0" x2="30" y2="22"/><line x1="30" y1="38" x2="30" y2="60"/>
                            <line x1="0" y1="30" x2="22" y2="30"/><line x1="38" y1="30" x2="60" y2="30"/>
                            <circle cx="30" cy="30" r="8"/>
                        </svg>
                    </div>
                    <div class="cam-robot-dot" id="robotDot"></div>

                    <!-- Overlays -->
                    <div class="cam-overlay-tl">
                        <div class="cam-chip live">● LIVE</div>
                        <div class="cam-chip" id="activeCamLabel">CAM 1 — Entrée principale</div>
                        <div class="cam-chip rec" id="recChip" style="display:none">⏺ REC</div>
                        <div class="cam-chip night" id="nightChip" style="display:none">🌙 NIGHT MODE</div>
                    </div>
                    <div class="cam-overlay-tr">
                        <div class="cam-chip" id="timestampChip">00:00:00</div>
                        <div class="cam-zoom-val" id="zoomLabel">Zoom: 1.0x</div>
                    </div>
                    <div class="cam-overlay-bl">
                        <div class="cam-chip">YURA-001 · Zone A</div>
                    </div>
                    <div class="cam-overlay-br">
                        <div class="cam-chip">1920×1080 · 30fps</div>
                    </div>
                </div>

                <!-- CONTROLS BAR -->
                <div class="cam-controls-bar">
                    <button class="ctrl-btn" onclick="zoomIn()">
                        <svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="5.5" cy="5.5" r="4"/><line x1="9" y1="9" x2="12" y2="12"/><line x1="3.5" y1="5.5" x2="7.5" y2="5.5"/><line x1="5.5" y1="3.5" x2="5.5" y2="7.5"/></svg>
                        Zoom +
                    </button>
                    <button class="ctrl-btn" onclick="zoomOut()">
                        <svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="5.5" cy="5.5" r="4"/><line x1="9" y1="9" x2="12" y2="12"/><line x1="3.5" y1="5.5" x2="7.5" y2="5.5"/></svg>
                        Zoom −
                    </button>
                    <div class="ctrl-sep"></div>
                    <button class="ctrl-btn" onclick="takeSnapshot()" id="snapBtn">
                        <svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="11" height="8" rx="1"/><circle cx="6.5" cy="7" r="2"/><path d="M4 3l1-2h3l1 2"/></svg>
                        Snapshot
                    </button>
                    <button class="ctrl-btn danger" onclick="toggleRecord()" id="recBtn">
                        <svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="6.5" cy="6.5" r="4"/><circle cx="6.5" cy="6.5" r="2" fill="currentColor"/></svg>
                        Enregistrer
                    </button>
                    <div class="ctrl-sep"></div>
                    <button class="ctrl-btn" onclick="toggleGrid()" id="gridBtn">
                        <svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="1" width="4" height="4"/><rect x="8" y="1" width="4" height="4"/><rect x="1" y="8" width="4" height="4"/><rect x="8" y="8" width="4" height="4"/></svg>
                        Grille
                    </button>
                    <button class="ctrl-btn" onclick="toggleNight()" id="nightBtn">
                        <svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10 7A5 5 0 015 2a6 6 0 100 9 5 5 0 005-4z"/></svg>
                        Nuit
                    </button>
                    <button class="ctrl-btn" onclick="toggleFullscreen()" style="margin-left:auto;">
                        <svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 4V1h3M9 1h3v3M12 9v3H9M4 12H1V9"/></svg>
                        Plein écran
                    </button>
                </div>
            </div>

            <!-- RIGHT PANEL -->
            <div class="right-panel">

                <!-- THUMBNAILS -->
                <div class="panel-card">
                    <div class="panel-title">Caméras</div>
                    <div class="thumbs-grid">
                        <div class="cam-thumb active-thumb" onclick="selectCam(1,'Entrée principale','Zone A')">
                            <div class="cam-thumb-feed">
                                <div style="position:absolute;inset:0;background:radial-gradient(ellipse at 60% 40%,#0d1a2e,#050a14)"></div>
                                <div class="cam-thumb-dot"></div>
                            </div>
                            <div class="cam-thumb-label">
                                <span class="cam-label">CAM 1</span>
                                <div class="cam-status-dot on"></div>
                            </div>
                        </div>
                        <div class="cam-thumb" onclick="selectCam(2,'Bureau central','Zone B')">
                            <div class="cam-thumb-feed">
                                <div style="position:absolute;inset:0;background:radial-gradient(ellipse at 30% 60%,#1a0d0d,#050a14)"></div>
                                <div class="cam-thumb-dot" style="background:#f59e0b"></div>
                            </div>
                            <div class="cam-thumb-label">
                                <span class="cam-label">CAM 2</span>
                                <div class="cam-status-dot on"></div>
                            </div>
                        </div>
                        <div class="cam-thumb" onclick="selectCam(3,'Entrepôt','Zone C')">
                            <div class="cam-thumb-feed">
                                <div style="position:absolute;inset:0;background:radial-gradient(ellipse at 70% 30%,#0d1a0d,#050a14)"></div>
                                <div class="cam-thumb-dot" style="background:#27ae60"></div>
                            </div>
                            <div class="cam-thumb-label">
                                <span class="cam-label">CAM 3</span>
                                <div class="cam-status-dot on"></div>
                            </div>
                        </div>
                        <div class="cam-thumb" onclick="selectCam(4,'Parking','Zone D')">
                            <div class="cam-thumb-feed">
                                <div style="position:absolute;inset:0;background:#040408"></div>
                                <div class="cam-thumb-dot" style="opacity:0.3"></div>
                                <div style="position:absolute;font-size:0.55rem;color:#333;font-weight:700;">HORS LIGNE</div>
                            </div>
                            <div class="cam-thumb-label">
                                <span class="cam-label">CAM 4</span>
                                <div class="cam-status-dot off"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- IMAGE FILTERS -->
                <div class="panel-card">
                    <div class="panel-title">Filtres Image</div>
                    <div class="slider-wrap">
                        <label>Luminosité <span id="brightVal">100%</span></label>
                        <input type="range" min="50" max="200" value="100" oninput="updateFilter('brightness',this.value,'brightVal','%')">
                    </div>
                    <div class="slider-wrap">
                        <label>Contraste <span id="contrastVal">100%</span></label>
                        <input type="range" min="50" max="200" value="100" oninput="updateFilter('contrast',this.value,'contrastVal','%')">
                    </div>
                    <div class="slider-wrap">
                        <label>Saturation <span id="saturateVal">100%</span></label>
                        <input type="range" min="0" max="200" value="100" oninput="updateFilter('saturate',this.value,'saturateVal','%')">
                    </div>
                    <div class="slider-wrap">
                        <label>Netteté <span id="sharpVal">0</span></label>
                        <input type="range" min="0" max="5" value="0" step="0.5" oninput="updateSharpness(this.value)">
                    </div>
                </div>

                <!-- TOGGLES -->
                <div class="panel-card">
                    <div class="panel-title">Options</div>
                    <div class="toggle-row">
                        <span class="toggle-label">Audio</span>
                        <div class="toggle-sw" onclick="this.classList.toggle('on')"></div>
                    </div>
                    <div class="toggle-row">
                        <span class="toggle-label">Détection mouvement</span>
                        <div class="toggle-sw on" onclick="this.classList.toggle('on')"></div>
                    </div>
                    <div class="toggle-row">
                        <span class="toggle-label">Alerte intrusion</span>
                        <div class="toggle-sw on" onclick="this.classList.toggle('on')"></div>
                    </div>
                    <div class="toggle-row">
                        <span class="toggle-label">Timestamp overlay</span>
                        <div class="toggle-sw on" onclick="this.classList.toggle('on')"></div>
                    </div>
                    <div class="toggle-row">
                        <span class="toggle-label">Sauvegarde auto</span>
                        <div class="toggle-sw" onclick="this.classList.toggle('on')"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
let zoom = 1.0;
let isRec = false;
let isNight = false;
let isGrid = false;
let filters = { brightness: 100, contrast: 100, saturate: 100 };
let sharpness = 0;

// TIMESTAMP
function updateTimestamp() {
    const now = new Date();
    document.getElementById('timestampChip').textContent =
        now.toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit', second:'2-digit'});
}
setInterval(updateTimestamp, 1000);
updateTimestamp();

// SELECT CAM
function selectCam(num, name, zone) {
    document.querySelectorAll('.cam-thumb').forEach(t => t.classList.remove('active-thumb'));
    event.currentTarget.classList.add('active-thumb');
    document.getElementById('activeCamLabel').textContent = 'CAM ' + num + ' — ' + name;
}

// ZOOM
function applyZoom() {
    document.getElementById('robotDot').style.transform = 'scale(' + (1/zoom) + ')';
    document.getElementById('zoomLabel').textContent = 'Zoom: ' + zoom.toFixed(1) + 'x';
    document.querySelector('.cam-feed-bg').style.transform = 'scale(' + zoom + ')';
}
function zoomIn()  { if(zoom < 4.0) { zoom = +(zoom + 0.5).toFixed(1); applyZoom(); } }
function zoomOut() { if(zoom > 1.0) { zoom = +(zoom - 0.5).toFixed(1); applyZoom(); } }

// SNAPSHOT
function takeSnapshot() {
    const flash = document.getElementById('snapFlash');
    flash.classList.add('flash');
    setTimeout(() => flash.classList.remove('flash'), 150);
    const btn = document.getElementById('snapBtn');
    btn.classList.add('success');
    btn.textContent = '✓ Sauvegardé';
    setTimeout(() => { btn.classList.remove('success'); btn.innerHTML = '<svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="11" height="8" rx="1"/><circle cx="6.5" cy="7" r="2"/><path d="M4 3l1-2h3l1 2"/></svg> Snapshot'; }, 2000);
}

// RECORD
function toggleRecord() {
    isRec = !isRec;
    const btn = document.getElementById('recBtn');
    const chip = document.getElementById('recChip');
    if (isRec) {
        btn.classList.add('active');
        btn.innerHTML = '<svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/></svg> Stop REC';
        chip.style.display = '';
    } else {
        btn.classList.remove('active');
        btn.innerHTML = '<svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="6.5" cy="6.5" r="4"/><circle cx="6.5" cy="6.5" r="2" fill="currentColor"/></svg> Enregistrer';
        chip.style.display = 'none';
    }
}

// GRID
function toggleGrid() {
    isGrid = !isGrid;
    document.getElementById('gridOverlay').classList.toggle('show', isGrid);
    document.getElementById('gridBtn').classList.toggle('active', isGrid);
}

// NIGHT MODE
function toggleNight() {
    isNight = !isNight;
    const feed = document.getElementById('mainFeed');
    const chip = document.getElementById('nightChip');
    const btn  = document.getElementById('nightBtn');
    if (isNight) {
        feed.style.filter = 'sepia(0.3) hue-rotate(90deg) saturate(0.5) brightness(0.7)';
        chip.style.display = '';
        btn.classList.add('active');
    } else {
        applyAllFilters();
        chip.style.display = 'none';
        btn.classList.remove('active');
    }
}

// FILTERS
function applyAllFilters() {
    const f = `brightness(${filters.brightness}%) contrast(${filters.contrast}%) saturate(${filters.saturate}%) blur(${sharpness > 0 ? 0 : 0}px)`;
    document.getElementById('mainFeed').style.filter = f;
}
function updateFilter(type, val, labelId, unit) {
    filters[type] = val;
    document.getElementById(labelId).textContent = val + unit;
    if (!isNight) applyAllFilters();
}
function updateSharpness(val) {
    sharpness = val;
    document.getElementById('sharpVal').textContent = val;
}

// FULLSCREEN
function toggleFullscreen() {
    const el = document.querySelector('.cam-main-feed');
    if (!document.fullscreenElement) el.requestFullscreen();
    else document.exitFullscreen();
}
</script>
</body>
</html>