            <span class="nav-text">Historique</span>
        </a>
        <div class="nav-label">Surveillance</div>
        <a href="/admin/camera" class="nav-item">
            <span class="nav-icon-wrap"><svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor"><path d="M1 4a1 1 0 011-1h8a1 1 0 011 1v1.5l3-2v7l-3-2V12a1 1 0 01-1 1H2a1 1 0 01-1-1V4z"/></svg></span>
            <span class="nav-text">Caméras</span>
        </a>
        <a href="/admin/map" class="nav-item">
            <span class="nav-icon-wrap"><svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor"><path d="M6 1l4 2 4-2v11l-4 2-4-2-4 2V3l4-2zm0 1.5L2 4.5v9l4-2 4 2 4-2v-9l-4 2-4-2z"/></svg></span>
            <span class="nav-text">Navigation</span>
        </a>
        <a href="/admin/notifications" class="nav-item">
            <span class="nav-icon-wrap"><svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1a5 5 0 00-5 5v3l-1.5 2.5h13L13 9V6a5 5 0 00-5-5zm0 14a2 2 0 01-2-2h4a2 2 0 01-2 2z"/></svg></span>
            <span class="nav-text">Alertes</span>
            <span class="nav-count">3</span>
        </a>
        <div class="nav-label">Agent</div>
        <a href="/dashboard/security" class="nav-item">
            <span class="nav-icon-wrap"><svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1L2 4v5c0 4.5 3 7.5 6 8.5C11 16.5 14 13.5 14 9V4L8 1z"/></svg></span>
            <span class="nav-text">Vue Agent</span>
        </a>
    </div>
    <div class="sidebar-footer">
        <div class="user-row">
            <div class="user-av"><%= user.name.charAt(0).toUpperCase() %></div>
            <div>
                <div class="user-name-s"><%= user.name %></div>
                <div class="user-role-s">Administrateur</div>
            </div>
        </div>
        <a href="/logout" class="nav-item" style="color:#555;">
            <span class="nav-icon-wrap"><svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor"><path d="M6 2H3a1 1 0 00-1 1v10a1 1 0 001 1h3v-1.5H3.5v-9H6V2zm4.5 3.5L13 8l-2.5 2.5-1-1L11 8H6V6.5h5l-1.5-1.5 1-1z"/></svg></span>
            <span class="nav-text">Déconnexion</span>
        </a>
    </div>
</aside>

<!-- MAIN -->
<div class="main-content">
    <div class="top-bar">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="#888"><rect y="3" width="18" height="2"/><rect y="8" width="18" height="2"/><rect y="13" width="18" height="2"/></svg>
        <span class="topbar-title">Historique Système</span>
        <div class="topbar-right">
            <span class="admin-pill">ADMIN</span>
            <a href="/notifications" class="topbar-bell">
                <svg width="18" height="18" viewBox="0 0 16 16" fill="#888"><path d="M8 1a5 5 0 00-5 5v3l-1.5 2.5h13L13 9V6a5 5 0 00-5-5zm0 14a2 2 0 01-2-2h4a2 2 0 01-2 2z"/></svg>
                <div class="bell-badge">3</div>
            </a>
            <a href="/dashboard/settings" class="topbar-user"><div class="user-dot"></div><%= user.name %></a>
        </div>
    </div>

    <div class="content">
        <!-- HEADER -->
        <div class="page-header">
            <div>
                <h1>Historique</h1>
                <p>Journal complet des actions système</p>
            </div>
            <button class="export-btn" onclick="exportCSV()">
                <svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6.5 1v8M4 7l2.5 2.5L9 7"/><path d="M1 10v1a1 1 0 001 1h9a1 1 0 001-1v-1"/></svg>
                Exporter CSV
            </button>
        </div>

        <!-- STATS -->
        <%
        const total    = histories ? histories.length : 0;
        const logins   = histories ? histories.filter(h => h.action && h.action.toLowerCase().includes('connexion')).length : 0;
        const alerts   = histories ? histories.filter(h => h.action && h.action.toLowerCase().includes('alert')).length : 0;
        const robots   = histories ? histories.filter(h => h.action && h.action.toLowerCase().includes('robot')).length : 0;
        %>
        <div class="stat-row">
            <div class="stat-card c1">
                <div class="stat-icon-wrap c1"><svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="#e74c3c" stroke-width="1.5"><path d="M8 1a7 7 0 100 14A7 7 0 008 1zm0 2v5l3 3-1 1-3.5-3.5V3H8z"/></svg></div>
                <div class="stat-num"><%= total %></div>
                <div class="stat-label">Total Actions</div>
            </div>
            <div class="stat-card c2">
                <div class="stat-icon-wrap c2"><svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="#27ae60" stroke-width="1.5"><path d="M8 1L2 4v5c0 4.5 3 7.5 6 8.5C11 16.5 14 13.5 14 9V4L8 1z"/></svg></div>
                <div class="stat-num"><%= logins %></div>
                <div class="stat-label">Connexions</div>
            </div>
            <div class="stat-card c3">
                <div class="stat-icon-wrap c3"><svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="#f59e0b" stroke-width="1.5"><path d="M8 1L1 14h14L8 1zm0 5v4M8 11v1"/></svg></div>
                <div class="stat-num"><%= alerts %></div>
                <div class="stat-label">Alertes</div>
            </div>
            <div class="stat-card c4">
                <div class="stat-icon-wrap c4"><svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="#3b82f6" stroke-width="1.5"><rect x="4" y="2" width="8" height="6" rx="1"/><rect x="3" y="8" width="10" height="5" rx="1"/><circle cx="6" cy="4" r="1"/><circle cx="10" cy="4" r="1"/></svg></div>
                <div class="stat-num"><%= robots %></div>
                <div class="stat-label">Cmd Robot</div>
            </div>
        </div>

        <!-- FILTERS -->
        <div class="filter-wrap">
            <div class="search-wrap">
                <span class="search-icon"><svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="5.5" cy="5.5" r="4"/><path d="M9 9l2.5 2.5"/></svg></span>
                <input type="text" class="search-input" id="searchInput" placeholder="Rechercher action, utilisateur..." oninput="filterRows()">
            </div>
            <select class="filter-select" id="typeFilter" onchange="filterRows()">
                <option value="">Tous les types</option>
                <option value="connexion">Connexion</option>
                <option value="robot">Robot</option>
                <option value="alert">Alerte</option>
                <option value="param">Paramètres</option>
                <option value="system">Système</option>
            </select>
            <button class="clear-btn" onclick="clearFilters()">Réinitialiser</button>
        </div>

        <!-- TABLE -->
        <div class="table-wrap">
            <div class="table-head">
                <span>#</span>
                <span>Action</span>
                <span>Type</span>
                <span>Utilisateur</span>
                <span>Détails</span>
                <span>Date/Heure</span>
            </div>

            <div id="histList">
            <% if(histories && histories.length > 0) { %>
                <% histories.forEach(function(h, i) {
                    let type = 'default';
                    const a = (h.action || '').toLowerCase();
                    if (a.includes('connexion') || a.includes('login')) type = 'login';
                    else if (a.includes('déconnexion') || a.includes('logout')) type = 'logout';
                    else if (a.includes('alert')) type = 'alert';
                    else if (a.includes('robot')) type = 'robot';
                    else if (a.includes('param') || a.includes('mot de passe')) type = 'param';
                    else if (a.includes('système') || a.includes('system') || a.includes('créé') || a.includes('supprimé')) type = 'system';

                    const labels = { login:'Connexion', logout:'Déconnexion', alert:'Alerte', robot:'Robot', param:'Paramètres', system:'Système', default:'Action' };
                    const date = new Date(h.timestamp || h.createdAt);
                    const dateStr = date.toLocaleDateString('fr-FR', {day:'2-digit', month:'2-digit', year:'numeric'});
                    const timeStr = date.toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit', second:'2-digit'});
                %>
                <div class="hist-row" data-action="<%= (h.action||'').toLowerCase() %>" data-user="<%= (h.userName||'').toLowerCase() %>" data-type="<%= type %>">
                    <span class="idx-cell"><%= i + 1 %></span>
                    <span class="action-cell"><%= h.action || '—' %></span>
                    <span><span class="type-badge badge-<%= type %>"><%= labels[type] %></span></span>
                    <div class="user-cell-h">
                        <div class="user-av-sm"><%= h.userName ? h.userName.charAt(0).toUpperCase() : '?' %></div>
                        <%= h.userName || 'Système' %>
                    </div>
                    <span class="details-cell" title="<%= h.details || '' %>"><%= h.details || '—' %></span>
                    <div class="time-cell">
                        <span class="time-date"><%= dateStr %></span>
                        <span class="time-hour"><%= timeStr %></span>
                    </div>
                </div>
                <% }); %>
            <% } else { %>
                <div class="empty-row">Aucune entrée dans l'historique</div>
            <% } %>
            </div>

            <!-- PAGINATION -->
            <div class="pagination" id="paginationWrap">
                <span class="pag-info" id="pagInfo"></span>
                <div class="pag-btns" id="pagBtns"></div>
            </div>
        </div>
    </div>
</div>

<script>
const ROWS_PER_PAGE = 15;
let currentPage = 1;
let filteredRows = [];

function getAllRows() {
    return Array.from(document.querySelectorAll('#histList .hist-row'));
}

function filterRows() {
    const search = document.getElementById('searchInput').value.toLowerCase();
    const type   = document.getElementById('typeFilter').value;
    filteredRows = getAllRows().filter(function(row) {
        const matchSearch = !search || (row.dataset.action||'').includes(search) || (row.dataset.user||'').includes(search);
        const matchType   = !type   || row.dataset.type === type;
        return matchSearch && matchType;
    });
    currentPage = 1;
    renderPage();
}

function renderPage() {
    const all = getAllRows();
    all.forEach(r => r.style.display = 'none');

    const start = (currentPage - 1) * ROWS_PER_PAGE;
    const end   = start + ROWS_PER_PAGE;
    const pageRows = filteredRows.slice(start, end);
    pageRows.forEach(r => r.style.display = '');

    const total = filteredRows.length;
    const totalPages = Math.max(1, Math.ceil(total / ROWS_PER_PAGE));

    document.getElementById('pagInfo').textContent = total + ' entrée' + (total > 1 ? 's' : '') + ' — page ' + currentPage + '/' + totalPages;

    const btns = document.getElementById('pagBtns');
    btns.innerHTML = '';

    const prev = document.createElement('button');
    prev.className = 'pag-btn' + (currentPage <= 1 ? ' disabled' : '');
    prev.textContent = '← Préc.';
    prev.onclick = () => { if(currentPage > 1){ currentPage--; renderPage(); } };
    btns.appendChild(prev);

    for (let p = Math.max(1, currentPage-2); p <= Math.min(totalPages, currentPage+2); p++) {
        const btn = document.createElement('button');
        btn.className = 'pag-btn' + (p === currentPage ? ' active' : '');
        btn.textContent = p;
        btn.onclick = (function(pg){ return function(){ currentPage = pg; renderPage(); }; })(p);
        btns.appendChild(btn);
    }

    const next = document.createElement('button');
    next.className = 'pag-btn' + (currentPage >= totalPages ? ' disabled' : '');
    next.textContent = 'Suiv. →';
    next.onclick = () => { if(currentPage < totalPages){ currentPage++; renderPage(); } };
    btns.appendChild(next);
}

function clearFilters() {
    document.getElementById('searchInput').value = '';
    document.getElementById('typeFilter').value = '';
    filterRows();
}

function exportCSV() {
    const rows = getAllRows();
    let csv = 'Action,Type,Utilisateur,Détails,Date\n';
    rows.forEach(function(row) {
        const cells = row.querySelectorAll('.action-cell, .type-badge, .user-cell-h, .details-cell, .time-date');
        const vals = Array.from(cells).map(c => '"' + (c.textContent.trim().replace(/"/g,'""')) + '"');
        csv += vals.join(',') + '\n';
    });
    const blob = new Blob([csv], {type:'text/csv;charset=utf-8;'});
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = 'historique-yura-' + new Date().toISOString().slice(0,10) + '.csv';
    a.click();
}

// Init
window.addEventListener('DOMContentLoaded', function() {
    filteredRows = getAllRows();
    renderPage();
});
</script>
</body>
</html>