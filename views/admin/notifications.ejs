            <a href="/admin/notifications" class="topbar-bell">
                <svg width="18" height="18" viewBox="0 0 16 16" fill="#888"><path d="M8 1a5 5 0 00-5 5v3l-1.5 2.5h13L13 9V6a5 5 0 00-5-5zm0 14a2 2 0 01-2-2h4a2 2 0 01-2 2z"/></svg>
                <div class="bell-badge"><%= unreadCount || 0 %></div>
            </a>
            <a href="/dashboard/settings" class="topbar-user"><div class="user-dot"></div><%= user.name %></a>
        </div>
    </div>

    <div class="content">
        <!-- HEADER -->
        <div class="page-header">
            <div>
                <h1>Alertes</h1>
                <p>Centre de notifications YURA Guardian</p>
            </div>
            <div class="header-actions">
                <form action="/notifications/read-all" method="POST" style="display:inline">
                    <button type="submit" class="btn-action btn-secondary">
                        <svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="2,6 5,9 11,3"/></svg>
                        Tout marquer lu
                    </button>
                </form>
            </div>
        </div>

        <!-- STATS -->
        <%
        const notifs = notifications || [];
        const crit   = notifs.filter(n => n.type === 'danger'  || n.type === 'critique').length;
        const warns  = notifs.filter(n => n.type === 'warning' || n.type === 'connexion' || n.type === 'robot').length;
        const infos  = notifs.filter(n => n.type === 'info'    || n.type === 'system').length;
        const resol  = notifs.filter(n => n.read === true).length;
        %>
        <div class="stat-row">
            <div class="stat-card danger" onclick="filterByType('danger')">
                <div class="stat-icon-wrap danger">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="#e74c3c" stroke-width="1.5"><path d="M8 1L1 14h14L8 1zm0 5v4M8 11v1"/></svg>
                </div>
                <div class="stat-num" id="sc-danger"><%= crit %></div>
                <div class="stat-label">Critiques</div>
            </div>
            <div class="stat-card warning" onclick="filterByType('warning')">
                <div class="stat-icon-wrap warning">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="#f59e0b" stroke-width="1.5"><circle cx="8" cy="8" r="6"/><path d="M8 5v3M8 10v1"/></svg>
                </div>
                <div class="stat-num" id="sc-warning"><%= warns %></div>
                <div class="stat-label">Avertissements</div>
            </div>
            <div class="stat-card info" onclick="filterByType('info')">
                <div class="stat-icon-wrap info">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="#3b82f6" stroke-width="1.5"><circle cx="8" cy="8" r="6"/><path d="M8 7v5M8 5v1"/></svg>
                </div>
                <div class="stat-num" id="sc-info"><%= infos %></div>
                <div class="stat-label">Informations</div>
            </div>
            <div class="stat-card success" onclick="filterByType('resolved')">
                <div class="stat-icon-wrap success">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="#27ae60" stroke-width="1.5"><circle cx="8" cy="8" r="6"/><polyline points="5,8 7,10 11,6"/></svg>
                </div>
                <div class="stat-num" id="sc-resolved"><%= resol %></div>
                <div class="stat-label">Résolues</div>
            </div>
        </div>

        <!-- FILTER BAR -->
        <div class="filter-bar">
            <div class="search-wrap">
                <span class="search-icon"><svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="5.5" cy="5.5" r="4"/><path d="M9 9l2.5 2.5"/></svg></span>
                <input type="text" class="search-input" id="searchInput" placeholder="Rechercher une alerte..." oninput="applyFilters()">
            </div>
            <button class="filter-btn active" id="fb-all"     onclick="setFilter('all')">Toutes</button>
            <button class="filter-btn" id="fb-unread"  onclick="setFilter('unread')">Non lues</button>
            <button class="filter-btn" id="fb-danger"  onclick="setFilter('danger')">Critiques</button>
            <button class="filter-btn" id="fb-warning" onclick="setFilter('warning')">Warnings</button>
            <button class="filter-btn" id="fb-info"    onclick="setFilter('info')">Infos</button>
            <button class="mark-all-btn" onclick="document.querySelector('form[action=\'/notifications/read-all\']').submit()">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="2,6 4.5,8.5 10,3"/></svg>
                Tout lu
            </button>
        </div>

        <!-- ALERTS LIST -->
        <div class="alerts-list" id="alertsList">
        <% if(notifs.length > 0) { %>
            <% notifs.forEach(function(n) {
                let type = 'info';
                const t = (n.type || '').toLowerCase();
                if (t === 'danger' || t === 'critique' || t === 'alerte') type = 'danger';
                else if (t === 'warning' || t === 'robot' || t === 'connexion') type = 'warning';
                else if (t === 'success') type = 'success';

                const icons = { danger:'🚨', warning:'⚠️', info:'ℹ️', success:'✅' };
                const labels = { danger:'Critique', warning:'Warning', info:'Info', success:'Résolu' };
                const date = new Date(n.createdAt || n.timestamp || Date.now());
                const timeStr = date.toLocaleString('fr-FR', {day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'});
            %>
            <div class="alert-card <%= type %> <%= n.read ? 'resolved' : '' %> new-alert"
                 data-type="<%= type %>"
                 data-read="<%= n.read ? 'true' : 'false' %>"
                 data-msg="<%= (n.message || '').toLowerCase() %>"
                 id="alert-<%= n._id %>">

                <div class="alert-icon-wrap <%= type %>"><%= icons[type] %></div>

                <div class="alert-body">
                    <div class="alert-top">
                        <span class="alert-title"><%= n.message || 'Notification' %></span>
                        <span class="alert-badge <%= n.read ? 'resolved' : type %>">
                            <%= n.read ? 'Lu' : labels[type] %>
                        </span>
                        <% if(!n.read) { %><div class="new-dot"></div><% } %>
                    </div>
                    <div class="alert-msg">
                        Généré par : <strong style="color:#888"><%= n.userName || 'Système' %></strong>
                        — Type : <%= n.type || 'notification' %>
                    </div>
                    <div class="alert-meta">
                        <span>
                            <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.3"><circle cx="5" cy="5" r="4"/><path d="M5 3v2l1.5 1.5"/></svg>
                            <%= timeStr %>
                        </span>
                        <span>
                            <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M5 1L1 4v4a5 5 0 008 0V4L5 1z"/></svg>
                            YURA-001
                        </span>
                    </div>
                </div>

                <div class="alert-actions">
                    <% if(!n.read) { %>
                    <form action="/notifications/read/<%= n._id %>" method="POST">
                        <button type="submit" class="act-btn resolve" title="Marquer lu">
                            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2"><polyline points="2,6 5,9 10,3"/></svg>
                        </button>
                    </form>
                    <% } %>
                    <form action="/notifications/delete/<%= n._id %>" method="POST" onsubmit="return confirmDelete(this)">
                        <button type="submit" class="act-btn del" title="Supprimer">
                            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3h8M4 3V2h4v1M3 3v7h6V3H3z"/></svg>
                        </button>
                    </form>
                </div>
            </div>
            <% }); %>
        <% } else { %>
            <div class="empty-state" id="emptyState">
                <svg width="52" height="52" viewBox="0 0 52 52" fill="currentColor"><path d="M26 4a16 16 0 00-16 16v10l-4 7h40l-4-7V20A16 16 0 0026 4zm0 44a6 6 0 01-6-6h12a6 6 0 01-6 6z"/></svg>
                <p style="margin-top:10px;font-size:0.9rem;">Aucune alerte</p>
                <p style="font-size:0.75rem;margin-top:5px;color:#444;">Le système fonctionne normalement</p>
            </div>
        <% } %>
        </div>

        <!-- PAGINATION -->
        <div class="pagination" id="paginationWrap">
            <span class="pag-info" id="pagInfo"></span>
            <div class="pag-btns" id="pagBtns"></div>
        </div>
    </div>
</div>

<script>
const PER_PAGE = 12;
let currentPage = 1;
let activeFilter = 'all';
let filteredCards = [];

function getAllCards() {
    return Array.from(document.querySelectorAll('.alert-card'));
}

function setFilter(f) {
    activeFilter = f;
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    const btn = document.getElementById('fb-' + f);
    if (btn) btn.classList.add('active');
    currentPage = 1;
    applyFilters();
}

function filterByType(type) {
    setFilter(type === 'resolved' ? 'resolved' : type);
}

function applyFilters() {
    const search = (document.getElementById('searchInput').value || '').toLowerCase();
    filteredCards = getAllCards().filter(function(card) {
        const type  = card.dataset.type || '';
        const read  = card.dataset.read === 'true';
        const msg   = card.dataset.msg  || '';
        let match = true;
        if (activeFilter === 'unread')   match = !read;
        else if (activeFilter === 'resolved') match = read;
        else if (activeFilter !== 'all') match = type === activeFilter;
        if (search) match = match && msg.includes(search);
        return match;
    });
    currentPage = 1;
    renderPage();
}

function renderPage() {
    getAllCards().forEach(c => c.style.display = 'none');
    const start = (currentPage - 1) * PER_PAGE;
    filteredCards.slice(start, start + PER_PAGE).forEach(c => c.style.display = '');

    const total = filteredCards.length;
    const totalPages = Math.max(1, Math.ceil(total / PER_PAGE));
    document.getElementById('pagInfo').textContent = total + ' alerte' + (total > 1 ? 's' : '');

    const btns = document.getElementById('pagBtns');
    btns.innerHTML = '';
    if (totalPages <= 1) return;

    const prev = document.createElement('button');
    prev.className = 'pag-btn' + (currentPage <= 1 ? ' disabled' : '');
    prev.textContent = '← Préc.';
    prev.onclick = () => { if(currentPage > 1){ currentPage--; renderPage(); } };
    btns.appendChild(prev);

    for (let p = 1; p <= totalPages; p++) {
        const btn = document.createElement('button');
        btn.className = 'pag-btn' + (p === currentPage ? ' active' : '');
        btn.textContent = p;
        btn.onclick = (function(pg){ return function(){ currentPage = pg; renderPage(); }; })(p);
        btns.appendChild(btn);
    }

    const next = document.createElement('button');
    next.className = 'pag-btn' + (currentPage >= totalPages ? ' disabled' : '');
    next.textContent = 'Suiv. →';
    next.onclick = () => { if(currentPage < totalPages){ currentPage++; renderPage(); } };
    btns.appendChild(next);
}

function confirmDelete(form) {
    if (!confirm('Supprimer cette alerte ?')) return false;
    const card = form.closest('.alert-card');
    if (card) { card.style.opacity = '0'; card.style.transform = 'translateX(20px)'; card.style.transition = '0.3s'; }
    return true;
}

window.addEventListener('DOMContentLoaded', function() {
    filteredCards = getAllCards();
    renderPage();
});
</script>
</body>
</html>