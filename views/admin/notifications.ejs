<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script>
    (function(){
        try {
            const s = JSON.parse(localStorage.getItem('yuraSettings') || '{}');
            if (s.darkMode === false) {
                const st = document.createElement('style');
                st.id = '__yuraLight';
                st.textContent = `
                    body { background: #f0f2f5 !important; color: #111 !important; }
                    .sidebar { background: #fff !important; border-color: rgba(0,0,0,0.1) !important; }
                    .top-bar { background: #fff !important; border-color: rgba(0,0,0,0.1) !important; }
                    .main-content, .content { background: #f0f2f5 !important; }
                    .stat-card, .filter-bar, .alert-card { background: #fff !important; border-color: rgba(0,0,0,0.08) !important; }
                    .nav-item { color: #555 !important; }
                    .nav-item:hover { background: rgba(0,0,0,0.04) !important; color: #111 !important; }
                    .nav-item.active { color: var(--rouge) !important; background: rgba(192,57,43,0.07) !important; }
                    .logo-name, .user-name-s, h1 { color: #111 !important; }
                    .logo-sub, .user-role-s, .topbar-title { color: #666 !important; }
                    .topbar-user { background: rgba(192,57,43,0.07) !important; border-color: rgba(192,57,43,0.2) !important; }
                    .robot-badge { background: rgba(192,57,43,0.07) !important; border-color: rgba(192,57,43,0.25) !important; }
                    .alert-title { color: #111 !important; }
                    .alert-msg { color: #555 !important; }
                    .alert-meta span { color: #888 !important; }
                    .search-input, .filter-btn { background: #f0f0f0 !important; border-color: rgba(0,0,0,0.1) !important; color: #555 !important; }
                    .act-btn { background: rgba(0,0,0,0.04) !important; border-color: rgba(0,0,0,0.08) !important; color: #666 !important; }
                    .stat-num { color: #111 !important; }
                    .stat-label { color: #888 !important; }
                    .empty-state { color: #888 !important; }
                `;
                document.head.appendChild(st);
            }
            if (s.colorTheme === 'blue-black') {
                document.documentElement.style.setProperty('--rouge', '#2563eb');
                document.documentElement.style.setProperty('--rouge-light', '#3b82f6');
                document.documentElement.style.setProperty('--border', 'rgba(37,99,235,0.18)');
            } else if (s.colorTheme === 'green-black') {
                document.documentElement.style.setProperty('--rouge', '#16a34a');
                document.documentElement.style.setProperty('--rouge-light', '#22c55e');
                document.documentElement.style.setProperty('--border', 'rgba(22,163,74,0.18)');
            }
        } catch(e) {}
    })();
    </script>
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        :root {
            --rouge:#c0392b; --rouge-light:#e74c3c;
            --noir:#0a0a0a; --card:#111111;
            --border:rgba(192,57,43,0.18); --gris:#888; --gris2:#bbb;
        }
        body { font-family:'Segoe UI',sans-serif; background:var(--noir); color:#fff; display:flex; min-height:100vh; }

        /* SIDEBAR */
        .sidebar { width:300px; min-height:100vh; background:#0d0d0d; border-right:1px solid var(--border); display:flex; flex-direction:column; position:fixed; top:0; left:0; bottom:0; z-index:100; }
        .logo-section { padding:20px 18px; border-bottom:1px solid var(--border); display:flex; align-items:center; gap:14px; }
        .logo-name { font-size:1.1rem; font-weight:800; color:#fff; letter-spacing:2px; }
        .logo-sub { font-size:0.65rem; color:var(--gris); letter-spacing:2px; text-transform:uppercase; }
        .admin-badge-side { margin:12px 16px 4px; padding:8px 14px; background:rgba(192,57,43,0.2); border:1px solid rgba(192,57,43,0.5); border-radius:6px; font-size:0.7rem; font-weight:800; color:var(--rouge-light); letter-spacing:2px; text-transform:uppercase; text-align:center; }
        .robot-badge { margin:8px 16px 6px; padding:10px 16px; background:rgba(192,57,43,0.12); border:1px solid rgba(192,57,43,0.4); border-radius:8px; display:flex; align-items:center; gap:10px; font-size:0.75rem; font-weight:700; color:var(--rouge-light); }
        .badge-dot { width:8px; height:8px; background:var(--rouge-light); border-radius:50%; animation:blink 1.2s infinite; }
        @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.1} }
        .nav-section { padding:8px 0; flex:1; overflow-y:auto; }
        .nav-label { font-size:0.6rem; font-weight:700; color:var(--gris); letter-spacing:2px; padding:12px 18px 5px; text-transform:uppercase; }
        .nav-item { display:flex; align-items:center; gap:13px; padding:11px 18px; color:#666; text-decoration:none; font-size:0.87rem; font-weight:500; border-left:2px solid transparent; transition:all 0.18s; }
        .nav-item:hover { color:#fff; background:rgba(192,57,43,0.07); }
        .nav-item.active { color:#fff; background:rgba(192,57,43,0.13); border-left-color:var(--rouge); font-weight:600; }
        .nav-icon-wrap { width:20px; height:20px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
        .nav-text { flex:1; }
        .nav-count { background:var(--rouge); color:#fff; font-size:0.6rem; font-weight:700; padding:2px 7px; border-radius:10px; }
        .sidebar-footer { border-top:1px solid var(--border); padding:8px 0; }
        .user-row { display:flex; align-items:center; gap:10px; padding:11px 18px; }
        .user-av { width:34px; height:34px; background:linear-gradient(135deg,var(--rouge),#7b241c); border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:0.85rem; font-weight:700; flex-shrink:0; }
        .user-name-s { font-size:0.82rem; font-weight:600; }
        .user-role-s { font-size:0.65rem; color:var(--rouge-light); font-weight:600; }

        /* MAIN */
        .main-content { margin-left:300px; flex:1; display:flex; flex-direction:column; min-height:100vh; }
        .top-bar { height:52px; background:#0d0d0d; border-bottom:1px solid var(--border); display:flex; align-items:center; padding:0 24px; gap:12px; position:sticky; top:0; z-index:50; }
        .topbar-title { font-size:0.78rem; color:var(--gris); letter-spacing:1.5px; text-transform:uppercase; flex:1; }
        .topbar-right { display:flex; align-items:center; gap:10px; }
        .topbar-bell { position:relative; cursor:pointer; text-decoration:none; }
        .bell-badge { position:absolute; top:-4px; right:-4px; width:16px; height:16px; background:var(--rouge); border-radius:50%; font-size:0.6rem; color:#fff; font-weight:700; display:flex; align-items:center; justify-content:center; }
        .topbar-user { display:flex; align-items:center; gap:7px; background:rgba(192,57,43,0.12); border:1px solid rgba(192,57,43,0.35); padding:5px 14px; border-radius:20px; font-size:0.75rem; font-weight:700; color:var(--rouge-light); text-decoration:none; }
        .user-dot { width:7px; height:7px; background:var(--rouge-light); border-radius:50%; }
        .admin-pill { background:rgba(192,57,43,0.25); border:1px solid rgba(192,57,43,0.5); padding:4px 10px; border-radius:4px; font-size:0.62rem; font-weight:800; color:var(--rouge-light); letter-spacing:1.5px; text-transform:uppercase; }

        /* CONTENT */
        .content { padding:20px 24px; flex:1; }
        .page-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:20px; flex-wrap:wrap; gap:10px; }
        .page-header h1 { font-size:1.6rem; font-weight:800; }
        .page-header p { font-size:0.8rem; color:var(--gris); margin-top:3px; }
        .header-actions { display:flex; gap:8px; }
        .btn-action { display:flex; align-items:center; gap:6px; padding:7px 14px; border-radius:8px; font-size:0.78rem; font-weight:700; cursor:pointer; transition:all 0.18s; border:none; }
        .btn-primary { background:var(--rouge); color:#fff; }
        .btn-primary:hover { background:var(--rouge-light); }
        .btn-secondary { background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.09) !important; color:#888; }
        .btn-secondary:hover { background:rgba(255,255,255,0.08); color:#fff; }

        /* STAT CARDS */
        .stat-row { display:grid; grid-template-columns:repeat(4,1fr); gap:12px; margin-bottom:18px; }
        .stat-card { background:var(--card); border:1px solid rgba(255,255,255,0.06); border-radius:11px; padding:16px 18px; position:relative; overflow:hidden; transition:all 0.2s; cursor:pointer; }
        .stat-card:hover { transform:translateY(-2px); }
        .stat-card.active-filter { border-color:rgba(192,57,43,0.45); }
        .stat-card::before { content:''; position:absolute; top:0; left:0; right:0; height:2px; }
        .stat-card.danger::before  { background:var(--rouge); }
        .stat-card.warning::before { background:#f59e0b; }
        .stat-card.info::before    { background:#3b82f6; }
        .stat-card.success::before { background:#27ae60; }
        .stat-icon-wrap { width:36px; height:36px; border-radius:8px; display:flex; align-items:center; justify-content:center; margin-bottom:10px; }
        .stat-icon-wrap.danger  { background:rgba(192,57,43,0.12); border:1px solid rgba(192,57,43,0.2); }
        .stat-icon-wrap.warning { background:rgba(245,158,11,0.1);  border:1px solid rgba(245,158,11,0.2); }
        .stat-icon-wrap.info    { background:rgba(59,130,246,0.1);  border:1px solid rgba(59,130,246,0.2); }
        .stat-icon-wrap.success { background:rgba(39,174,96,0.1);   border:1px solid rgba(39,174,96,0.2); }
        .stat-num { font-size:1.9rem; font-weight:800; color:#fff; line-height:1; }
        .stat-label { font-size:0.67rem; color:var(--gris); text-transform:uppercase; letter-spacing:0.8px; margin-top:5px; }

        /* FILTER BAR */
        .filter-bar { background:var(--card); border:1px solid rgba(255,255,255,0.06); border-radius:11px; padding:12px 16px; margin-bottom:14px; display:flex; align-items:center; gap:10px; flex-wrap:wrap; }
        .search-wrap { position:relative; flex:1; min-width:180px; }
        .search-icon { position:absolute; left:11px; top:50%; transform:translateY(-50%); color:#555; }
        .search-input { width:100%; background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.07); border-radius:7px; padding:7px 11px 7px 34px; color:#fff; font-size:0.82rem; outline:none; }
        .search-input:focus { border-color:rgba(192,57,43,0.4); }
        .search-input::placeholder { color:#444; }
        .filter-btn { padding:6px 13px; background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.07); border-radius:7px; color:#666; font-size:0.75rem; font-weight:600; cursor:pointer; transition:all 0.15s; }
        .filter-btn:hover { color:#fff; background:rgba(255,255,255,0.08); }
        .filter-btn.active { background:rgba(192,57,43,0.15); border-color:rgba(192,57,43,0.4); color:var(--rouge-light); }
        .mark-all-btn { display:flex; align-items:center; gap:5px; padding:6px 13px; background:rgba(39,174,96,0.08); border:1px solid rgba(39,174,96,0.2); border-radius:7px; color:#27ae60; font-size:0.75rem; font-weight:600; cursor:pointer; margin-left:auto; transition:all 0.15s; }
        .mark-all-btn:hover { background:rgba(39,174,96,0.15); }

        /* ALERTS LIST */
        .alerts-list { display:flex; flex-direction:column; gap:8px; }
        .alert-card { background:var(--card); border:1px solid rgba(255,255,255,0.06); border-radius:11px; padding:14px 16px; display:flex; align-items:flex-start; gap:14px; transition:all 0.2s; position:relative; overflow:hidden; }
        .alert-card::before { content:''; position:absolute; left:0; top:0; bottom:0; width:3px; border-radius:3px 0 0 3px; }
        .alert-card.danger::before  { background:var(--rouge); }
        .alert-card.warning::before { background:#f59e0b; }
        .alert-card.info::before    { background:#3b82f6; }
        .alert-card.success::before { background:#27ae60; }
        .alert-card.resolved { opacity:0.45; }
        .alert-card:hover { border-color:rgba(255,255,255,0.1); }
        .alert-card.new-alert { animation:slideIn 0.3s ease; }
        @keyframes slideIn { from{opacity:0;transform:translateX(-10px)} to{opacity:1;transform:translateX(0)} }

        .alert-icon-wrap { width:40px; height:40px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:1.2rem; flex-shrink:0; }
        .alert-icon-wrap.danger  { background:rgba(192,57,43,0.12); border:1px solid rgba(192,57,43,0.2); }
        .alert-icon-wrap.warning { background:rgba(245,158,11,0.1);  border:1px solid rgba(245,158,11,0.2); }
        .alert-icon-wrap.info    { background:rgba(59,130,246,0.1);  border:1px solid rgba(59,130,246,0.2); }
        .alert-icon-wrap.success { background:rgba(39,174,96,0.1);   border:1px solid rgba(39,174,96,0.2); }

        .alert-body { flex:1; min-width:0; }
        .alert-top { display:flex; align-items:center; gap:8px; margin-bottom:4px; flex-wrap:wrap; }
        .alert-title { font-size:0.88rem; font-weight:700; color:#fff; }
        .alert-badge { font-size:0.6rem; font-weight:700; padding:2px 7px; border-radius:4px; text-transform:uppercase; letter-spacing:0.5px; }
        .alert-badge.danger  { background:rgba(192,57,43,0.2);  color:var(--rouge-light); border:1px solid rgba(192,57,43,0.3); }
        .alert-badge.warning { background:rgba(245,158,11,0.15); color:#f59e0b; border:1px solid rgba(245,158,11,0.3); }
        .alert-badge.info    { background:rgba(59,130,246,0.12); color:#3b82f6; border:1px solid rgba(59,130,246,0.3); }
        .alert-badge.success { background:rgba(39,174,96,0.12);  color:#27ae60; border:1px solid rgba(39,174,96,0.3); }
        .alert-badge.resolved { background:rgba(136,136,136,0.1); color:#555; border:1px solid rgba(136,136,136,0.15); }
        .new-dot { width:7px; height:7px; background:var(--rouge); border-radius:50%; animation:blink 1s infinite; flex-shrink:0; }
        .alert-msg { font-size:0.78rem; color:#666; line-height:1.5; margin-bottom:6px; }
        .alert-meta { display:flex; align-items:center; gap:12px; flex-wrap:wrap; }
        .alert-meta span { font-size:0.68rem; color:#444; display:flex; align-items:center; gap:4px; }

        .alert-actions { display:flex; flex-direction:column; gap:5px; flex-shrink:0; }
        .act-btn { width:30px; height:30px; border-radius:6px; background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.07); color:#555; cursor:pointer; display:flex; align-items:center; justify-content:center; transition:all 0.15s; }
        .act-btn.resolve:hover { background:rgba(39,174,96,0.15); border-color:rgba(39,174,96,0.35); color:#27ae60; }
        .act-btn.del:hover     { background:rgba(192,57,43,0.15); border-color:rgba(192,57,43,0.35); color:var(--rouge-light); }

        /* EMPTY */
        .empty-state { text-align:center; padding:50px 20px; color:var(--gris); }
        .empty-state svg { opacity:0.15; margin-bottom:12px; }

        /* PAGINATION */
        .pagination { display:flex; align-items:center; justify-content:space-between; padding:14px 0; }
        .pag-info { font-size:0.73rem; color:var(--gris); }
        .pag-btns { display:flex; gap:5px; }
        .pag-btn { padding:5px 12px; background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); border-radius:6px; color:#777; font-size:0.75rem; font-weight:600; cursor:pointer; transition:all 0.15s; }
        .pag-btn:hover { background:rgba(192,57,43,0.1); border-color:rgba(192,57,43,0.3); color:#fff; }
        .pag-btn.active { background:var(--rouge); border-color:var(--rouge); color:#fff; }
        .pag-btn.disabled { opacity:0.25; pointer-events:none; }

        @keyframes fadeInUp { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }
        .stat-card { animation:fadeInUp 0.3s ease both; }
        .stat-card:nth-child(1){animation-delay:0.04s}
        .stat-card:nth-child(2){animation-delay:0.08s}
        .stat-card:nth-child(3){animation-delay:0.12s}
        .stat-card:nth-child(4){animation-delay:0.16s}
    </style>
</head>
