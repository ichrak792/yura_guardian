<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script>
    (function(){
        try {
            const s = JSON.parse(localStorage.getItem('yuraSettings') || '{}');
            if (s.darkMode === false) {
                const st = document.createElement('style');
                st.id = '__yuraLight';
                st.textContent = `
                    body { background: #f0f2f5 !important; color: #111 !important; }
                    .sidebar { background: #fff !important; border-color: rgba(0,0,0,0.1) !important; }
                    .top-bar { background: #fff !important; border-color: rgba(0,0,0,0.1) !important; }
                    .main-content, .content { background: #f0f2f5 !important; }
                    .card { background: #fff !important; border-color: rgba(0,0,0,0.08) !important; }
                    .nav-item { color: #555 !important; }
                    .nav-item:hover { background: rgba(0,0,0,0.04) !important; color: #111 !important; }
                    .nav-item.active { color: var(--rouge) !important; background: rgba(192,57,43,0.07) !important; }
                    .logo-name, .user-name-s, h1, .card-title { color: #111 !important; }
                    .logo-sub, .user-role-s, .topbar-title { color: #666 !important; }
                    .topbar-user { background: rgba(192,57,43,0.07) !important; border-color: rgba(192,57,43,0.2) !important; }
                    .robot-badge { background: rgba(192,57,43,0.07) !important; border-color: rgba(192,57,43,0.25) !important; }
                    .dpad-btn { background: rgba(0,0,0,0.06) !important; border-color: rgba(0,0,0,0.1) !important; color: #444 !important; }
                    .cmd-btn { background: rgba(0,0,0,0.05) !important; border-color: rgba(0,0,0,0.1) !important; color: #555 !important; }
                    .log-item { border-color: rgba(0,0,0,0.05) !important; }
                    .log-cmd { color: #333 !important; }
                    .log-time { color: #888 !important; }
                    .zone-plan { background: #e8e8e8 !important; }
                    .zone-box { border-color: rgba(0,0,0,0.15) !important; }
                    .zone-box-label { color: #444 !important; }
                    .speed-track { background: rgba(0,0,0,0.1) !important; }
                `;
                document.head.appendChild(st);
            }
            if (s.colorTheme === 'blue-black') {
                document.documentElement.style.setProperty('--rouge', '#2563eb');
                document.documentElement.style.setProperty('--rouge-light', '#3b82f6');
                document.documentElement.style.setProperty('--border', 'rgba(37,99,235,0.18)');
            } else if (s.colorTheme === 'green-black') {
                document.documentElement.style.setProperty('--rouge', '#16a34a');
                document.documentElement.style.setProperty('--rouge-light', '#22c55e');
                document.documentElement.style.setProperty('--border', 'rgba(22,163,74,0.18)');
            }
        } catch(e) {}
    })();
    </script>
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        :root {
            --rouge:#c0392b; --rouge-light:#e74c3c;
            --noir:#0a0a0a; --card:#111111;
            --border:rgba(192,57,43,0.18); --gris:#888; --gris2:#bbb;
        }
        body { font-family:'Segoe UI',sans-serif; background:var(--noir); color:#fff; display:flex; min-height:100vh; }

        /* SIDEBAR */
        .sidebar { width:300px; min-height:100vh; background:#0d0d0d; border-right:1px solid var(--border); display:flex; flex-direction:column; position:fixed; top:0; left:0; bottom:0; z-index:100; }
        .logo-section { padding:20px 18px; border-bottom:1px solid var(--border); display:flex; align-items:center; gap:14px; }
        .logo-name { font-size:1.1rem; font-weight:800; color:#fff; letter-spacing:2px; }
        .logo-sub { font-size:0.65rem; color:var(--gris); letter-spacing:2px; text-transform:uppercase; }
        .admin-badge-side { margin:12px 16px 4px; padding:8px 14px; background:rgba(192,57,43,0.2); border:1px solid rgba(192,57,43,0.5); border-radius:6px; font-size:0.7rem; font-weight:800; color:var(--rouge-light); letter-spacing:2px; text-transform:uppercase; text-align:center; }
        .robot-badge { margin:8px 16px 6px; padding:10px 16px; background:rgba(192,57,43,0.12); border:1px solid rgba(192,57,43,0.4); border-radius:8px; display:flex; align-items:center; gap:10px; font-size:0.75rem; font-weight:700; color:var(--rouge-light); }
        .badge-dot { width:8px; height:8px; background:var(--rouge-light); border-radius:50%; animation:blink 1.2s infinite; }
        @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.1} }
        .nav-section { padding:8px 0; flex:1; overflow-y:auto; }
        .nav-label { font-size:0.6rem; font-weight:700; color:var(--gris); letter-spacing:2px; padding:12px 18px 5px; text-transform:uppercase; }
        .nav-item { display:flex; align-items:center; gap:13px; padding:11px 18px; color:#666; text-decoration:none; font-size:0.87rem; font-weight:500; border-left:2px solid transparent; transition:all 0.18s; }
        .nav-item:hover { color:#fff; background:rgba(192,57,43,0.07); }
        .nav-item.active { color:#fff; background:rgba(192,57,43,0.13); border-left-color:var(--rouge); font-weight:600; }
        .nav-icon-wrap { width:20px; height:20px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
        .nav-text { flex:1; }
        .nav-count { background:var(--rouge); color:#fff; font-size:0.6rem; font-weight:700; padding:2px 7px; border-radius:10px; }
        .sidebar-footer { border-top:1px solid var(--border); padding:8px 0; }
        .user-row { display:flex; align-items:center; gap:10px; padding:11px 18px; }
        .user-av { width:34px; height:34px; background:linear-gradient(135deg,var(--rouge),#7b241c); border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:0.85rem; font-weight:700; flex-shrink:0; }
        .user-name-s { font-size:0.82rem; font-weight:600; }
        .user-role-s { font-size:0.65rem; color:var(--rouge-light); font-weight:600; }

        /* MAIN */
        .main-content { margin-left:300px; flex:1; display:flex; flex-direction:column; min-height:100vh; }
        .top-bar { height:52px; background:#0d0d0d; border-bottom:1px solid var(--border); display:flex; align-items:center; padding:0 24px; gap:12px; position:sticky; top:0; z-index:50; }
        .topbar-title { font-size:0.78rem; color:var(--gris); letter-spacing:1.5px; text-transform:uppercase; flex:1; }
        .topbar-right { display:flex; align-items:center; gap:10px; }
        .topbar-bell { position:relative; cursor:pointer; text-decoration:none; }
        .bell-badge { position:absolute; top:-4px; right:-4px; width:16px; height:16px; background:var(--rouge); border-radius:50%; font-size:0.6rem; color:#fff; font-weight:700; display:flex; align-items:center; justify-content:center; }
        .topbar-user { display:flex; align-items:center; gap:7px; background:rgba(192,57,43,0.12); border:1px solid rgba(192,57,43,0.35); padding:5px 14px; border-radius:20px; font-size:0.75rem; font-weight:700; color:var(--rouge-light); text-decoration:none; }
        .user-dot { width:7px; height:7px; background:var(--rouge-light); border-radius:50%; }
        .admin-pill { background:rgba(192,57,43,0.25); border:1px solid rgba(192,57,43,0.5); padding:4px 10px; border-radius:4px; font-size:0.62rem; font-weight:800; color:var(--rouge-light); letter-spacing:1.5px; text-transform:uppercase; }

        /* CONTENT */
        .content { padding:20px 24px; flex:1; }
        .page-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:20px; flex-wrap:wrap; gap:10px; }
        .page-header h1 { font-size:1.6rem; font-weight:800; }
        .page-header p { font-size:0.8rem; color:var(--gris); margin-top:3px; }
        .status-online { display:flex; align-items:center; gap:7px; background:rgba(39,174,96,0.1); border:1px solid rgba(39,174,96,0.3); padding:6px 14px; border-radius:20px; font-size:0.75rem; font-weight:700; color:#27ae60; }
        .status-online-dot { width:7px; height:7px; background:#27ae60; border-radius:50%; animation:blink 1.5s infinite; }

        /* LAYOUT */
        .grid-main { display:grid; grid-template-columns:1fr 380px; gap:14px; margin-bottom:14px; }
        .grid-bottom { display:grid; grid-template-columns:1fr 1fr; gap:14px; }

        /* CARD */
        .card { background:var(--card); border:1px solid rgba(255,255,255,0.06); border-radius:12px; padding:20px; }
        .card-title { font-size:0.7rem; font-weight:700; color:var(--gris); text-transform:uppercase; letter-spacing:1.5px; margin-bottom:16px; display:flex; align-items:center; justify-content:space-between; }
        .card-badge { font-size:0.62rem; padding:3px 8px; border-radius:10px; background:rgba(192,57,43,0.15); color:var(--rouge-light); border:1px solid rgba(192,57,43,0.25); font-weight:700; }

        /* DPAD */
        .dpad-wrap { display:flex; flex-direction:column; align-items:center; gap:6px; margin-bottom:20px; }
        .dpad-row { display:flex; gap:6px; align-items:center; }
        .dpad-btn { width:56px; height:56px; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); border-radius:10px; color:#888; cursor:pointer; display:flex; align-items:center; justify-content:center; transition:all 0.15s; font-size:1.2rem; user-select:none; }
        .dpad-btn:hover { background:rgba(192,57,43,0.18); border-color:rgba(192,57,43,0.45); color:#fff; transform:scale(1.05); }
        .dpad-btn:active { transform:scale(0.95); background:rgba(192,57,43,0.3); }
        .dpad-btn.center { background:rgba(192,57,43,0.12); border-color:rgba(192,57,43,0.35); color:var(--rouge-light); width:56px; height:56px; border-radius:50%; }
        .dpad-btn.center:hover { background:rgba(192,57,43,0.25); }
        .dpad-btn.stop-big { width:72px; height:72px; background:rgba(192,57,43,0.15); border:2px solid rgba(192,57,43,0.4); border-radius:50%; color:var(--rouge-light); font-size:0.75rem; font-weight:800; letter-spacing:0.5px; flex-direction:column; gap:3px; }
        .dpad-btn.stop-big:hover { background:rgba(192,57,43,0.3); transform:scale(1.05); }

        /* SPEED */
        .speed-wrap { margin-bottom:16px; }
        .speed-label { font-size:0.68rem; color:var(--gris); text-transform:uppercase; letter-spacing:0.8px; margin-bottom:8px; display:flex; justify-content:space-between; }
        .speed-val { color:var(--rouge-light); font-weight:700; }
        .speed-track { width:100%; height:6px; background:rgba(255,255,255,0.07); border-radius:3px; position:relative; cursor:pointer; }
        .speed-fill { height:100%; background:linear-gradient(90deg,var(--rouge),var(--rouge-light)); border-radius:3px; transition:width 0.2s; pointer-events:none; }
        input[type=range] { width:100%; accent-color:var(--rouge); cursor:pointer; }

        /* QUICK CMDS */
        .quick-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:7px; }
        .cmd-btn { padding:10px 6px; background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); border-radius:8px; color:#888; font-size:0.72rem; font-weight:600; cursor:pointer; transition:all 0.18s; display:flex; flex-direction:column; align-items:center; gap:5px; }
        .cmd-btn:hover { background:rgba(192,57,43,0.12); border-color:rgba(192,57,43,0.35); color:#fff; }
        .cmd-btn.active-cmd { background:rgba(39,174,96,0.12); border-color:rgba(39,174,96,0.35); color:#27ae60; }
        .cmd-btn svg { opacity:0.7; }
        .cmd-btn:hover svg { opacity:1; }

        /* ZONE PLAN */
        .zone-plan { background:#0d0d0d; border-radius:10px; position:relative; height:260px; overflow:hidden; border:1px solid rgba(255,255,255,0.06); }
        .zone-plan-grid { position:absolute; inset:0; background-image:linear-gradient(rgba(192,57,43,0.05) 1px,transparent 1px),linear-gradient(90deg,rgba(192,57,43,0.05) 1px,transparent 1px); background-size:40px 40px; }
        .zone-box { position:absolute; border:1px solid; border-radius:6px; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:4px; cursor:pointer; transition:all 0.2s; }
        .zone-box:hover { filter:brightness(1.3); transform:scale(1.02); }
        .zone-box-label { font-size:0.6rem; font-weight:700; text-transform:uppercase; letter-spacing:0.8px; }
        .zone-box-name { font-size:0.55rem; opacity:0.8; }
        .zone-a { top:10px; left:10px; width:110px; height:70px; background:rgba(39,174,96,0.12); border-color:rgba(39,174,96,0.4); color:#27ae60; }
        .zone-b { top:10px; left:130px; width:130px; height:90px; background:rgba(59,130,246,0.1); border-color:rgba(59,130,246,0.35); color:#3b82f6; }
        .zone-c { top:110px; left:10px; width:110px; height:80px; background:rgba(39,174,96,0.1); border-color:rgba(39,174,96,0.3); color:#27ae60; }
        .zone-d { top:110px; left:130px; width:100px; height:60px; background:rgba(255,255,255,0.03); border-color:rgba(255,255,255,0.12); color:#555; }
        .zone-e { top:10px; right:10px; width:80px; height:180px; background:rgba(255,255,255,0.02); border-color:rgba(255,255,255,0.1); color:#444; }
        .robot-marker { position:absolute; width:22px; height:22px; background:var(--rouge); border-radius:50%; border:2px solid var(--rouge-light); box-shadow:0 0 12px rgba(192,57,43,0.7); transition:all 0.6s ease; z-index:5; }
        .robot-marker::after { content:''; position:absolute; inset:-5px; border-radius:50%; border:1px solid rgba(192,57,43,0.4); animation:ping 1.5s infinite; }
        @keyframes ping { 0%{transform:scale(1);opacity:0.8} 100%{transform:scale(2);opacity:0} }

        /* LOGS */
        .logs-wrap { max-height:280px; overflow-y:auto; }
        .logs-wrap::-webkit-scrollbar { width:3px; }
        .logs-wrap::-webkit-scrollbar-thumb { background:rgba(192,57,43,0.3); border-radius:2px; }
        .log-item { display:flex; align-items:center; gap:10px; padding:9px 0; border-bottom:1px solid rgba(255,255,255,0.04); }
        .log-item:last-child { border-bottom:none; }
        .log-dot { width:7px; height:7px; border-radius:50%; flex-shrink:0; }
        .log-cmd { font-size:0.8rem; color:var(--gris2); flex:1; }
        .log-user { font-size:0.68rem; color:#555; }
        .log-time { font-size:0.65rem; color:var(--gris); flex-shrink:0; }
        .log-empty { text-align:center; color:var(--gris); font-size:0.8rem; padding:30px 0; }

        /* FEEDBACK */
        .feedback-bar { position:fixed; bottom:20px; right:24px; background:#1a1a1a; border:1px solid var(--border); border-radius:10px; padding:10px 16px; font-size:0.8rem; color:#fff; display:none; align-items:center; gap:8px; z-index:999; box-shadow:0 4px 20px rgba(0,0,0,0.5); }
        .feedback-bar.show { display:flex; animation:slideUp 0.25s ease; }
        @keyframes slideUp { from{opacity:0;transform:translateY(10px)} to{opacity:1;transform:translateY(0)} }
        .feedback-dot { width:8px; height:8px; border-radius:50%; background:#27ae60; }

        @keyframes fadeInUp { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }
        .card { animation:fadeInUp 0.35s ease both; }
    </style>
</head>
<body>

<!-- FEEDBACK -->
<div class="feedback-bar" id="feedbackBar">
    <div class="feedback-dot"></div>
    <span id="feedbackMsg">Commande envoyée</span>
</div>

<!-- SIDEBAR -->
<aside class="sidebar">
    <div class="logo-section">
        <img src="/images/logo robot.png" alt="YURA" style="width:42px;height:42px;object-fit:contain;border-radius:8px;flex-shrink:0;">
        <div>
            <div class="logo-name">YURA</div>
            <div class="logo-sub">Guardian System</div>
        </div>
    </div>
    <div class="admin-badge-side">⚡ ADMIN PANEL</div>
    <div class="robot-badge">
        <div class="badge-dot"></div>
