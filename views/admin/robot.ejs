    </div>
    <div class="sidebar-footer">
        <div class="user-row">
            <div class="user-av"><%= user.name.charAt(0).toUpperCase() %></div>
            <div>
                <div class="user-name-s"><%= user.name %></div>
                <div class="user-role-s">Administrateur</div>
            </div>
        </div>
        <a href="/logout" class="nav-item" style="color:#555;">
            <span class="nav-icon-wrap"><svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor"><path d="M6 2H3a1 1 0 00-1 1v10a1 1 0 001 1h3v-1.5H3.5v-9H6V2zm4.5 3.5L13 8l-2.5 2.5-1-1L11 8H6V6.5h5l-1.5-1.5 1-1z"/></svg></span>
            <span class="nav-text">Déconnexion</span>
        </a>
    </div>
</aside>

<!-- MAIN -->
<div class="main-content">
    <div class="top-bar">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="#888"><rect y="3" width="18" height="2"/><rect y="8" width="18" height="2"/><rect y="13" width="18" height="2"/></svg>
        <span class="topbar-title">Contrôle Robot</span>
        <div class="topbar-right">
            <span class="admin-pill">ADMIN</span>
            <a href="/notifications" class="topbar-bell">
                <svg width="18" height="18" viewBox="0 0 16 16" fill="#888"><path d="M8 1a5 5 0 00-5 5v3l-1.5 2.5h13L13 9V6a5 5 0 00-5-5zm0 14a2 2 0 01-2-2h4a2 2 0 01-2 2z"/></svg>
                <div class="bell-badge">3</div>
            </a>
            <a href="/dashboard/settings" class="topbar-user"><div class="user-dot"></div><%= user.name %></a>
        </div>
    </div>

    <div class="content">
        <!-- HEADER -->
        <div class="page-header">
            <div>
                <h1>Contrôle Robot</h1>
                <p>YURA-001 — Commandes directes et supervision</p>
            </div>
            <div class="status-online">
                <div class="status-online-dot"></div>
                YURA-001 EN LIGNE
            </div>
        </div>

        <!-- ROW 1: Dpad + Zones -->
        <div class="grid-main">

            <!-- DPAD + CMDS -->
            <div class="card">
                <div class="card-title">
                    Commandes Directionnelles
                    <span class="card-badge" id="lastCmdBadge">En attente</span>
                </div>

                <!-- DPAD -->
                <div class="dpad-wrap">
                    <div class="dpad-row">
                        <div style="width:56px"></div>
                        <button class="dpad-btn" onclick="sendCmd('avancer')" title="Avancer [↑]">
                            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 16V4M4 10l6-6 6 6"/></svg>
                        </button>
                        <div style="width:56px"></div>
                    </div>
                    <div class="dpad-row">
                        <button class="dpad-btn" onclick="sendCmd('gauche')" title="Gauche [←]">
                            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 10h12M4 10l6-6M4 10l6 6"/></svg>
                        </button>
                        <button class="dpad-btn stop-big" onclick="sendCmd('stop')">
                            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="3" width="10" height="10" rx="1"/></svg>
                            STOP
                        </button>
                        <button class="dpad-btn" onclick="sendCmd('droite')" title="Droite [→]">
                            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 10H4M16 10l-6-6M16 10l-6 6"/></svg>
                        </button>
                    </div>
                    <div class="dpad-row">
                        <div style="width:56px"></div>
                        <button class="dpad-btn" onclick="sendCmd('reculer')" title="Reculer [↓]">
                            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 4v12M4 10l6 6 6-6"/></svg>
                        </button>
                        <div style="width:56px"></div>
                    </div>
                </div>

                <!-- SPEED -->
                <div class="speed-wrap">
                    <div class="speed-label">
                        <span>Vitesse</span>
                        <span class="speed-val" id="speedVal">50%</span>
                    </div>
                    <input type="range" min="0" max="100" value="50" id="speedSlider" oninput="updateSpeed(this.value)">
                </div>

                <!-- QUICK CMDS -->
                <div class="card-title" style="margin-top:16px;">Modes</div>
                <div class="quick-grid">
                    <button class="cmd-btn" onclick="sendCmd('patrouille')">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="8" cy="8" r="6"/><path d="M8 5v3l2 2"/></svg>
                        Patrouille
                    </button>
                    <button class="cmd-btn" onclick="sendCmd('base')">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 8l7-6 7 6M2 8v7h4V11h4v4h4V8"/></svg>
                        Base
                    </button>
                    <button class="cmd-btn" onclick="sendCmd('scanner')">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="8" cy="8" r="3"/><path d="M1 8h2M13 8h2M8 1v2M8 13v2"/></svg>
                        Scanner
                    </button>
                    <button class="cmd-btn" onclick="sendCmd('charger')">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 1l-5 7h5l-5 7"/></svg>
                        Charger
                    </button>
                    <button class="cmd-btn" onclick="sendCmd('verrouiller')">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="7" width="10" height="8" rx="1"/><path d="M5 7V5a3 3 0 016 0v2"/></svg>
                        Verrouil.
                    </button>
                    <button class="cmd-btn" onclick="sendCmd('urgence')" style="border-color:rgba(192,57,43,0.3);color:var(--rouge-light);">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 1L1 14h14L8 1zm0 5v4M8 11v1"/></svg>
                        Urgence
                    </button>
                </div>
            </div>

            <!-- ZONE PLAN -->
            <div class="card">
                <div class="card-title">
                    Plan des Zones
                    <span class="card-badge" style="background:rgba(59,130,246,0.12);color:#3b82f6;border-color:rgba(59,130,246,0.25);" id="robotZone">Zone B</span>
                </div>
                <div class="zone-plan">
                    <div class="zone-plan-grid"></div>
                    <div class="zone-box zone-a" onclick="sendToZone('Zone A')">
                        <div class="zone-box-label">Zone A</div>
                        <div class="zone-box-name">Entrée</div>
                    </div>
                    <div class="zone-box zone-b" onclick="sendToZone('Zone B')">
                        <div class="zone-box-label">Zone B</div>
                        <div class="zone-box-name">Bureau</div>
                    </div>
                    <div class="zone-box zone-c" onclick="sendToZone('Zone C')">
                        <div class="zone-box-label">Zone C</div>
                        <div class="zone-box-name">Entrepôt</div>
                    </div>
                    <div class="zone-box zone-d" onclick="sendToZone('Zone D')">
                        <div class="zone-box-label">Zone D</div>
                        <div class="zone-box-name">Parking</div>
                    </div>
                    <div class="zone-box zone-e" onclick="sendToZone('Zone E')">
                        <div class="zone-box-label">Zone E</div>
                        <div class="zone-box-name">Toit</div>
                    </div>
                    <!-- Robot marker -->
                    <div class="robot-marker" id="robotMarker" style="left:160px;top:30px;"></div>
                </div>
                <div style="margin-top:12px;display:flex;gap:8px;flex-wrap:wrap;">
                    <div style="display:flex;align-items:center;gap:5px;font-size:0.65rem;color:#27ae60;">
                        <div style="width:8px;height:8px;background:#27ae60;border-radius:2px;"></div>Active
                    </div>
                    <div style="display:flex;align-items:center;gap:5px;font-size:0.65rem;color:#3b82f6;">
                        <div style="width:8px;height:8px;background:#3b82f6;border-radius:2px;"></div>Patrouille
                    </div>
                    <div style="display:flex;align-items:center;gap:5px;font-size:0.65rem;color:#555;">
                        <div style="width:8px;height:8px;background:#333;border-radius:2px;"></div>Inactive
                    </div>
                    <div style="display:flex;align-items:center;gap:5px;font-size:0.65rem;color:var(--rouge-light);margin-left:auto;">
                        <div style="width:8px;height:8px;background:var(--rouge);border-radius:50%;"></div>Robot
                    </div>
                </div>
            </div>
        </div>

        <!-- ROW 2: Logs -->
        <div class="card">
            <div class="card-title">
                Journal des Commandes
                <div style="display:flex;gap:8px;align-items:center;">
                    <span style="font-size:0.65rem;color:var(--gris);" id="logCount">0 commandes</span>
                    <button onclick="clearLogs()" style="font-size:0.65rem;padding:3px 8px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:5px;color:#666;cursor:pointer;">Vider</button>
                </div>
            </div>
            <div class="logs-wrap" id="logsWrap">
                <div class="log-empty" id="logEmpty">Aucune commande envoyée</div>
            </div>
        </div>

    </div>
</div>

<script>
let logCount = 0;
let speed = 50;

// SPEED
function updateSpeed(val) {
    speed = val;
    document.getElementById('speedVal').textContent = val + '%';
}

// SEND CMD
function sendCmd(cmd) {
    // UI feedback
    const badge = document.getElementById('lastCmdBadge');
    badge.textContent = cmd.toUpperCase();
    badge.style.background = 'rgba(39,174,96,0.15)';
    badge.style.color = '#27ae60';
    badge.style.borderColor = 'rgba(39,174,96,0.3)';
    setTimeout(() => {
        badge.style.background = '';
        badge.style.color = '';
        badge.style.borderColor = '';
    }, 2000);

    // Add log
    addLog(cmd, 'manual');

    // Show feedback
    showFeedback('Commande "' + cmd + '" envoyée');

    // Fetch
    fetch('/admin/robot/command', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ command: cmd, speed: speed })
    });

    // Move robot on plan
    if (cmd === 'avancer') moveRobot(0, -20);
    else if (cmd === 'reculer') moveRobot(0, 20);
    else if (cmd === 'gauche')  moveRobot(-20, 0);
    else if (cmd === 'droite')  moveRobot(20, 0);
}

// SEND TO ZONE
function sendToZone(zone) {
    showFeedback('Robot → ' + zone);
    addLog('Aller à ' + zone, 'zone');
    document.getElementById('robotZone').textContent = zone;
    const positions = {
        'Zone A': {left:'55px', top:'35px'},
        'Zone B': {left:'185px', top:'45px'},
        'Zone C': {left:'55px', top:'145px'},
        'Zone D': {left:'175px', top:'135px'},
        'Zone E': {left:'295px', top:'90px'}
    };
    if (positions[zone]) {
        const m = document.getElementById('robotMarker');
        m.style.left = positions[zone].left;
        m.style.top  = positions[zone].top;
    }
    fetch('/admin/robot/command', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ command: 'goto-' + zone })
    });
}

// MOVE ROBOT
function moveRobot(dx, dy) {
    const m = document.getElementById('robotMarker');
    const plan = m.parentElement;
    let x = parseInt(m.style.left) + dx;
    let y = parseInt(m.style.top)  + dy;
    x = Math.max(5, Math.min(plan.offsetWidth  - 27, x));
    y = Math.max(5, Math.min(plan.offsetHeight - 27, y));
    m.style.left = x + 'px';
    m.style.top  = y + 'px';
}

// ADD LOG
function addLog(cmd, type) {
    logCount++;
    document.getElementById('logCount').textContent = logCount + ' commande' + (logCount > 1 ? 's' : '');
    document.getElementById('logEmpty').style.display = 'none';

    const colors = { manual:'#27ae60', zone:'#3b82f6', system:'#f59e0b' };
    const now = new Date();
    const time = now.toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit', second:'2-digit'});

    const item = document.createElement('div');
    item.className = 'log-item';
    item.innerHTML = `
        <div class="log-dot" style="background:${colors[type]||'#888'}"></div>
        <span class="log-cmd">→ ${cmd}</span>
        <span class="log-user" style="color:#555">Vitesse: ${speed}%</span>
        <span class="log-time">${time}</span>
    `;
    const wrap = document.getElementById('logsWrap');
    wrap.insertBefore(item, wrap.firstChild);
}

// CLEAR LOGS
function clearLogs() {
    logCount = 0;
    document.getElementById('logCount').textContent = '0 commandes';
    document.getElementById('logsWrap').innerHTML = '<div class="log-empty" id="logEmpty">Aucune commande envoyée</div>';
}

// FEEDBACK
let feedbackTimeout;
function showFeedback(msg) {
    const bar = document.getElementById('feedbackBar');
    document.getElementById('feedbackMsg').textContent = msg;
    bar.classList.add('show');
    clearTimeout(feedbackTimeout);
    feedbackTimeout = setTimeout(() => bar.classList.remove('show'), 2500);
}

// KEYBOARD
document.addEventListener('keydown', function(e) {
    const map = { ArrowUp:'avancer', ArrowDown:'reculer', ArrowLeft:'gauche', ArrowRight:'droite', ' ':'stop' };
    if (map[e.key]) { e.preventDefault(); sendCmd(map[e.key]); }
});
</script>
</body>
</html>