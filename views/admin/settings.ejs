<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script>
    (function(){
        try {
            const s = JSON.parse(localStorage.getItem('yuraSettings') || '{}');
            if (s.darkMode === false) {
                const st = document.createElement('style');
                st.id = '__yuraLight';
                st.textContent = `
                    body { background: #f0f2f5 !important; color: #111 !important; }
                    .sidebar { background: #fff !important; border-color: rgba(0,0,0,0.1) !important; }
                    .top-bar { background: #fff !important; border-color: rgba(0,0,0,0.1) !important; }
                    .main-content, .content { background: #f0f2f5 !important; }
                    .settings-card { background: #fff !important; border-color: rgba(0,0,0,0.08) !important; }
                    .nav-item { color: #555 !important; }
                    .nav-item:hover { background: rgba(0,0,0,0.04) !important; color: #111 !important; }
                    .nav-item.active { color: var(--rouge) !important; background: rgba(192,57,43,0.07) !important; }
                    .logo-name, .user-name-s, h1 { color: #111 !important; }
                    .logo-sub, .user-role-s, .topbar-title { color: #666 !important; }
                    .s-input, .s-select, .s-textarea { background: #f0f0f0 !important; border-color: rgba(0,0,0,0.12) !important; color: #111 !important; }
                    .s-label { color: #555 !important; }
                    .s-desc { color: #888 !important; }
                    .section-title { color: #111 !important; border-color: rgba(0,0,0,0.07) !important; }
                    .toggle-row { border-color: rgba(0,0,0,0.06) !important; }
                    .toggle-label { color: #111 !important; }
                    .toggle-desc { color: #888 !important; }
                    .tab-btn { color: #888 !important; border-color: rgba(0,0,0,0.08) !important; }
                    .tab-btn.active { color: var(--rouge) !important; background: rgba(192,57,43,0.07) !important; }
                    .color-option { border-color: rgba(0,0,0,0.1) !important; }
                `;
                document.head.appendChild(st);
            }
            if (s.colorTheme === 'blue-black') {
                document.documentElement.style.setProperty('--rouge', '#2563eb');
                document.documentElement.style.setProperty('--rouge-light', '#3b82f6');
                document.documentElement.style.setProperty('--border', 'rgba(37,99,235,0.18)');
            } else if (s.colorTheme === 'green-black') {
                document.documentElement.style.setProperty('--rouge', '#16a34a');
                document.documentElement.style.setProperty('--rouge-light', '#22c55e');
                document.documentElement.style.setProperty('--border', 'rgba(22,163,74,0.18)');
            }
        } catch(e) {}
    })();
    </script>
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        :root {
            --rouge:#c0392b; --rouge-light:#e74c3c;
            --noir:#0a0a0a; --card:#111111;
            --border:rgba(192,57,43,0.18); --gris:#888;
        }
        body { font-family:'Segoe UI',sans-serif; background:var(--noir); color:#fff; display:flex; min-height:100vh; }

        /* SIDEBAR */
        .sidebar { width:300px; min-height:100vh; background:#0d0d0d; border-right:1px solid var(--border); display:flex; flex-direction:column; position:fixed; top:0; left:0; bottom:0; z-index:100; }
        .logo-section { padding:20px 18px; border-bottom:1px solid var(--border); display:flex; align-items:center; gap:14px; }
        .logo-name { font-size:1.1rem; font-weight:800; color:#fff; letter-spacing:2px; }
        .logo-sub { font-size:0.65rem; color:var(--gris); letter-spacing:2px; text-transform:uppercase; }
        .admin-badge-side { margin:12px 16px 4px; padding:8px 14px; background:rgba(192,57,43,0.2); border:1px solid rgba(192,57,43,0.5); border-radius:6px; font-size:0.7rem; font-weight:800; color:var(--rouge-light); letter-spacing:2px; text-transform:uppercase; text-align:center; }
        .robot-badge { margin:8px 16px 6px; padding:10px 16px; background:rgba(192,57,43,0.12); border:1px solid rgba(192,57,43,0.4); border-radius:8px; display:flex; align-items:center; gap:10px; font-size:0.75rem; font-weight:700; color:var(--rouge-light); }
        .badge-dot { width:8px; height:8px; background:var(--rouge-light); border-radius:50%; animation:blink 1.2s infinite; }
        @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.1} }
        .nav-section { padding:8px 0; flex:1; overflow-y:auto; }
        .nav-label { font-size:0.6rem; font-weight:700; color:var(--gris); letter-spacing:2px; padding:12px 18px 5px; text-transform:uppercase; }
        .nav-item { display:flex; align-items:center; gap:13px; padding:11px 18px; color:#666; text-decoration:none; font-size:0.87rem; font-weight:500; border-left:2px solid transparent; transition:all 0.18s; }
        .nav-item:hover { color:#fff; background:rgba(192,57,43,0.07); }
        .nav-item.active { color:#fff; background:rgba(192,57,43,0.13); border-left-color:var(--rouge); font-weight:600; }
        .nav-icon-wrap { width:20px; height:20px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
        .nav-text { flex:1; }
        .nav-count { background:var(--rouge); color:#fff; font-size:0.6rem; font-weight:700; padding:2px 7px; border-radius:10px; }
        .sidebar-footer { border-top:1px solid var(--border); padding:8px 0; }
        .user-row { display:flex; align-items:center; gap:10px; padding:11px 18px; }
        .user-av { width:34px; height:34px; background:linear-gradient(135deg,var(--rouge),#7b241c); border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:0.85rem; font-weight:700; flex-shrink:0; }
        .user-name-s { font-size:0.82rem; font-weight:600; }
        .user-role-s { font-size:0.65rem; color:var(--rouge-light); font-weight:600; }

        /* MAIN */
        .main-content { margin-left:300px; flex:1; display:flex; flex-direction:column; }
        .top-bar { height:52px; background:#0d0d0d; border-bottom:1px solid var(--border); display:flex; align-items:center; padding:0 24px; gap:12px; position:sticky; top:0; z-index:50; }
        .topbar-title { font-size:0.78rem; color:var(--gris); letter-spacing:1.5px; text-transform:uppercase; flex:1; }
        .topbar-right { display:flex; align-items:center; gap:10px; }
        .topbar-bell { position:relative; cursor:pointer; text-decoration:none; }
        .bell-badge { position:absolute; top:-4px; right:-4px; width:16px; height:16px; background:var(--rouge); border-radius:50%; font-size:0.6rem; color:#fff; font-weight:700; display:flex; align-items:center; justify-content:center; }
        .topbar-user { display:flex; align-items:center; gap:7px; background:rgba(192,57,43,0.12); border:1px solid rgba(192,57,43,0.35); padding:5px 14px; border-radius:20px; font-size:0.75rem; font-weight:700; color:var(--rouge-light); text-decoration:none; }
        .user-dot { width:7px; height:7px; background:var(--rouge-light); border-radius:50%; }
        .admin-pill { background:rgba(192,57,43,0.25); border:1px solid rgba(192,57,43,0.5); padding:4px 10px; border-radius:4px; font-size:0.62rem; font-weight:800; color:var(--rouge-light); letter-spacing:1.5px; text-transform:uppercase; }

        /* CONTENT */
        .content { padding:20px 24px; flex:1; }
        .page-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:20px; flex-wrap:wrap; gap:10px; }
        .page-header h1 { font-size:1.6rem; font-weight:800; }
        .page-header p { font-size:0.8rem; color:var(--gris); margin-top:3px; }

        /* TABS */
        .tabs { display:flex; gap:6px; margin-bottom:20px; flex-wrap:wrap; }
        .tab-btn { display:flex; align-items:center; gap:7px; padding:8px 16px; background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); border-radius:8px; color:#666; font-size:0.8rem; font-weight:600; cursor:pointer; transition:all 0.18s; }
        .tab-btn:hover { color:#fff; background:rgba(255,255,255,0.07); }
        .tab-btn.active { background:rgba(192,57,43,0.15); border-color:rgba(192,57,43,0.4); color:var(--rouge-light); }

        /* SETTINGS LAYOUT */
        .settings-layout { display:grid; grid-template-columns:1fr 320px; gap:16px; }
        .settings-card { background:var(--card); border:1px solid rgba(255,255,255,0.06); border-radius:12px; padding:22px; }
        .section-title { font-size:0.72rem; font-weight:700; color:var(--gris); text-transform:uppercase; letter-spacing:1.5px; padding-bottom:14px; border-bottom:1px solid rgba(255,255,255,0.05); margin-bottom:18px; display:flex; align-items:center; gap:8px; }

        /* FORM ELEMENTS */
        .s-group { margin-bottom:16px; }
        .s-label { font-size:0.75rem; font-weight:600; color:#aaa; margin-bottom:6px; display:block; }
        .s-desc { font-size:0.68rem; color:#555; margin-bottom:6px; }
        .s-input { width:100%; background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.09); border-radius:8px; padding:9px 13px; color:#fff; font-size:0.85rem; outline:none; transition:border 0.18s; font-family:inherit; }
        .s-input:focus { border-color:rgba(192,57,43,0.5); }
        .s-input::placeholder { color:#444; }
        .s-select { width:100%; background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.09); border-radius:8px; padding:9px 13px; color:#fff; font-size:0.85rem; outline:none; cursor:pointer; font-family:inherit; }
        .s-select option { background:#1a1a1a; }
        .s-textarea { width:100%; background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.09); border-radius:8px; padding:9px 13px; color:#fff; font-size:0.85rem; outline:none; resize:vertical; min-height:80px; font-family:inherit; }
        .s-textarea:focus { border-color:rgba(192,57,43,0.5); }
        .s-row { display:grid; grid-template-columns:1fr 1fr; gap:14px; }

        /* TOGGLE */
        .toggle-row { display:flex; align-items:center; justify-content:space-between; padding:12px 0; border-bottom:1px solid rgba(255,255,255,0.04); }
        .toggle-row:last-child { border-bottom:none; }
        .toggle-info { flex:1; }
        .toggle-label { font-size:0.83rem; font-weight:600; color:#ddd; }
        .toggle-desc { font-size:0.7rem; color:#555; margin-top:2px; }
        .toggle { position:relative; width:42px; height:24px; flex-shrink:0; }
        .toggle input { opacity:0; width:0; height:0; }
        .toggle-slider { position:absolute; cursor:pointer; inset:0; background:#222; border-radius:24px; border:1px solid rgba(255,255,255,0.08); transition:all 0.25s; }
        .toggle-slider:before { content:''; position:absolute; width:16px; height:16px; left:3px; bottom:3px; background:#555; border-radius:50%; transition:all 0.25s; }
        .toggle input:checked + .toggle-slider { background:rgba(192,57,43,0.3); border-color:rgba(192,57,43,0.5); }
        .toggle input:checked + .toggle-slider:before { transform:translateX(18px); background:var(--rouge-light); }

        /* COLOR THEMES */
        .color-options { display:flex; gap:10px; flex-wrap:wrap; margin-top:8px; }
        .color-option { width:36px; height:36px; border-radius:50%; cursor:pointer; border:2px solid rgba(255,255,255,0.1); transition:all 0.18s; position:relative; }
        .color-option:hover { transform:scale(1.1); }
        .color-option.selected::after { content:'✓'; position:absolute; inset:0; display:flex; align-items:center; justify-content:center; font-size:0.8rem; color:#fff; font-weight:800; }
        .color-option.selected { border-color:#fff; transform:scale(1.1); }

        /* SAVE BTN */
        .save-btn { display:flex; align-items:center; gap:7px; padding:10px 22px; background:var(--rouge); color:#fff; border:none; border-radius:8px; font-size:0.85rem; font-weight:700; cursor:pointer; transition:all 0.18s; }
        .save-btn:hover { background:var(--rouge-light); transform:translateY(-1px); }
        .save-btn.saving { opacity:0.7; pointer-events:none; }

        /* RIGHT SIDEBAR */
        .info-box { background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.06); border-radius:10px; padding:14px; margin-bottom:12px; }
        .info-box-title { font-size:0.65rem; font-weight:700; color:var(--gris); text-transform:uppercase; letter-spacing:1px; margin-bottom:10px; }
        .info-row { display:flex; justify-content:space-between; align-items:center; padding:5px 0; border-bottom:1px solid rgba(255,255,255,0.04); }
        .info-row:last-child { border-bottom:none; }
        .info-key { font-size:0.72rem; color:#555; }
        .info-val { font-size:0.72rem; color:#888; font-weight:600; }
        .info-val.green { color:#27ae60; }
        .info-val.rouge { color:var(--rouge-light); }

        /* TOAST */
        .toast { position:fixed; bottom:24px; right:24px; padding:12px 20px; border-radius:10px; font-size:0.82rem; font-weight:600; z-index:999; transform:translateY(80px); opacity:0; transition:all 0.3s; display:flex; align-items:center; gap:8px; }
        .toast.show { transform:translateY(0); opacity:1; }
        .toast.success { background:rgba(39,174,96,0.15); border:1px solid rgba(39,174,96,0.4); color:#27ae60; }
        .toast.error { background:rgba(192,57,43,0.15); border:1px solid rgba(192,57,43,0.4); color:var(--rouge-light); }

        /* TAB PANELS */
        .tab-panel { display:none; }
        .tab-panel.active { display:block; }

        @keyframes fadeInUp { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }
        .settings-card { animation:fadeInUp 0.3s ease both; }
    </style>
</head>
<body>

<div class="toast" id="toast"></div>

<!-- SIDEBAR -->
