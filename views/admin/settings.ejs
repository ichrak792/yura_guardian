<script>
// TABS
function switchTab(tab) {
    document.querySelectorAll('.tab-btn').forEach((b,i) => b.classList.remove('active'));
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    const tabs = ['compte','systeme','apparence','robot','securite'];
    document.querySelectorAll('.tab-btn')[tabs.indexOf(tab)].classList.add('active');
    document.getElementById('panel-' + tab).classList.add('active');
}

// DARK MODE
function toggleDarkMode(cb) {
    try {
        const s = JSON.parse(localStorage.getItem('yuraSettings') || '{}');
        s.darkMode = cb.checked;
        localStorage.setItem('yuraSettings', JSON.stringify(s));
        if (!cb.checked) {
            let st = document.getElementById('__yuraLight');
            if (!st) {
                st = document.createElement('style');
                st.id = '__yuraLight';
                document.head.appendChild(st);
            }
            st.textContent = `body{background:#f0f2f5!important;color:#111!important}.sidebar{background:#fff!important}.top-bar{background:#fff!important}.settings-card{background:#fff!important;border-color:rgba(0,0,0,0.08)!important}.s-input,.s-select,.s-textarea{background:#f0f0f0!important;color:#111!important}`;
        } else {
            const st = document.getElementById('__yuraLight');
            if (st) st.remove();
        }
    } catch(e) {}
}

// COLOR THEME
function setColor(theme) {
    document.querySelectorAll('.color-option').forEach(el => el.classList.remove('selected'));
    document.getElementById('color-' + theme).classList.add('selected');
    const themes = {
        'red-black':    ['#c0392b','#e74c3c','rgba(192,57,43,0.18)'],
        'blue-black':   ['#2563eb','#3b82f6','rgba(37,99,235,0.18)'],
        'green-black':  ['#16a34a','#22c55e','rgba(22,163,74,0.18)'],
        'purple-black': ['#7c3aed','#8b5cf6','rgba(124,58,237,0.18)'],
        'orange-black': ['#ea580c','#f97316','rgba(234,88,12,0.18)']
    };
    if (themes[theme]) {
        document.documentElement.style.setProperty('--rouge', themes[theme][0]);
        document.documentElement.style.setProperty('--rouge-light', themes[theme][1]);
        document.documentElement.style.setProperty('--border', themes[theme][2]);
        try {
            const s = JSON.parse(localStorage.getItem('yuraSettings') || '{}');
            s.colorTheme = theme;
            localStorage.setItem('yuraSettings', JSON.stringify(s));
        } catch(e) {}
    }
}

// SAVE ALL
function saveAll() {
    const btn = document.getElementById('saveBtn');
    btn.classList.add('saving');
    btn.innerHTML = '<svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="2"><path d="M6.5 1a5.5 5.5 0 100 11 5.5 5.5 0 000-11z"/></svg> Sauvegarde...';
    try {
        const s = JSON.parse(localStorage.getItem('yuraSettings') || '{}');
        s.darkMode      = document.getElementById('darkMode').checked;
        s.animations    = document.getElementById('animations').checked;
        s.sysName       = document.getElementById('sysName').value;
        s.sysLang       = document.getElementById('sysLang').value;
        s.robotMaxSpeed = document.getElementById('robotMaxSpeed').value;
        s.robotPatrol   = document.getElementById('robotPatrolSpeed').value;
        s.robotBatAlert = document.getElementById('robotBatteryAlert').value;
        s.sessionTimeout= document.getElementById('sessionTimeout').value;
        localStorage.setItem('yuraSettings', JSON.stringify(s));
    } catch(e) {}
    setTimeout(function() {
        btn.classList.remove('saving');
        btn.innerHTML = '<svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 2h7l2 2v7a1 1 0 01-1 1H2a1 1 0 01-1-1V3a1 1 0 011-1z"/><rect x="4" y="8" width="5" height="4"/><rect x="3" y="1" width="5" height="3"/></svg> Sauvegarder tout';
        showToast('✅ Paramètres sauvegardés!', 'success');
    }, 800);
}

// CHANGE PASSWORD
function changePassword() {
    const cur  = document.getElementById('currentPwd').value;
    const nw   = document.getElementById('newPwd').value;
    const conf = document.getElementById('confirmPwd').value;
    if (!cur || !nw || !conf) return showToast('⚠️ Remplir tous les champs', 'error');
    if (nw.length < 6)        return showToast('⚠️ Mot de passe trop court (min 6)', 'error');
    if (nw !== conf)           return showToast('⚠️ Mots de passe différents', 'error');
    fetch('/dashboard/settings/change-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ currentPassword: cur, newPassword: nw, confirmPassword: conf })
    })
    .then(r => r.json())
    .then(d => {
        showToast(d.success ? '✅ ' + d.message : '❌ ' + d.message, d.success ? 'success' : 'error');
        if (d.success) {
            document.getElementById('currentPwd').value = '';
            document.getElementById('newPwd').value = '';
            document.getElementById('confirmPwd').value = '';
        }
    })
    .catch(() => showToast('❌ Erreur serveur', 'error'));
}

// CONFIRM DANGEROUS ACTIONS
function confirmAction(action) {
    const msgs = {
        'reset-logs':   'Vider tous les logs ? Cette action est irréversible.',
        'reset-notifs': 'Supprimer toutes les notifications ?',
        'reset-all':    '⚠️ RESET COMPLET — Supprimer TOUT ? Cette action est IRRÉVERSIBLE!'
    };
    if (confirm(msgs[action])) {
        showToast('Action effectuée', 'success');
    }
}

// TOAST
function showToast(msg, type) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.className = 'toast ' + type + ' show';
    setTimeout(() => t.classList.remove('show'), 3500);
}

// INIT — load saved settings
window.addEventListener('DOMContentLoaded', function() {
    try {
        const s = JSON.parse(localStorage.getItem('yuraSettings') || '{}');
        if (s.darkMode === false) document.getElementById('darkMode').checked = false;
        if (s.colorTheme) {
            document.querySelectorAll('.color-option').forEach(el => el.classList.remove('selected'));
            const el = document.getElementById('color-' + s.colorTheme);
            if (el) el.classList.add('selected');
        }
        if (s.sysName)       document.getElementById('sysName').value = s.sysName;
        if (s.sysLang)       document.getElementById('sysLang').value = s.sysLang;
        if (s.robotMaxSpeed) document.getElementById('robotMaxSpeed').value = s.robotMaxSpeed;
        if (s.sessionTimeout)document.getElementById('sessionTimeout').value = s.sessionTimeout;
    } catch(e) {}
});
</script>
