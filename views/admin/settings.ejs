<!-- MAIN -->
<div class="main-content">
    <div class="top-bar">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="#888"><rect y="3" width="18" height="2"/><rect y="8" width="18" height="2"/><rect y="13" width="18" height="2"/></svg>
        <span class="topbar-title">Paramètres Système</span>
        <div class="topbar-right">
            <span class="admin-pill">ADMIN</span>
            <a href="/admin/notifications" class="topbar-bell">
                <svg width="18" height="18" viewBox="0 0 16 16" fill="#888"><path d="M8 1a5 5 0 00-5 5v3l-1.5 2.5h13L13 9V6a5 5 0 00-5-5zm0 14a2 2 0 01-2-2h4a2 2 0 01-2 2z"/></svg>
                <div class="bell-badge">3</div>
            </a>
            <a href="/admin/settings" class="topbar-user"><div class="user-dot"></div><%= user.name %></a>
        </div>
    </div>

    <div class="content">
        <div class="page-header">
            <div>
                <h1>Paramètres</h1>
                <p>Configuration système YURA Guardian</p>
            </div>
            <button class="save-btn" id="saveBtn" onclick="saveAll()">
                <svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 2h7l2 2v7a1 1 0 01-1 1H2a1 1 0 01-1-1V3a1 1 0 011-1z"/><rect x="4" y="8" width="5" height="4"/><rect x="3" y="1" width="5" height="3"/></svg>
                Sauvegarder tout
            </button>
        </div>

        <!-- TABS -->
        <div class="tabs">
            <button class="tab-btn active" onclick="switchTab('compte')">
                <svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="6.5" cy="4" r="2.5"/><path d="M1 12c0-3 2.5-5 5.5-5s5.5 2 5.5 5"/></svg>
                Mon Compte
            </button>
            <button class="tab-btn" onclick="switchTab('systeme')">
                <svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="1" width="11" height="11" rx="2"/><path d="M4 6.5h5M6.5 4v5"/></svg>
                Système
            </button>
            <button class="tab-btn" onclick="switchTab('apparence')">
                <svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="6.5" cy="6.5" r="5"/><path d="M6.5 1v2M6.5 10v2M1 6.5h2M10 6.5h2"/></svg>
                Apparence
            </button>
            <button class="tab-btn" onclick="switchTab('robot')">
                <svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="1" width="7" height="5" rx="1"/><rect x="2" y="6" width="9" height="5" rx="1"/><circle cx="5" cy="3.5" r="0.8" fill="currentColor"/><circle cx="8" cy="3.5" r="0.8" fill="currentColor"/></svg>
                Robot
            </button>
            <button class="tab-btn" onclick="switchTab('securite')">
                <svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6.5 1L1 4v4c0 3.5 2.5 5.5 5.5 6.5C9 13.5 12 11.5 12 8V4L6.5 1z"/></svg>
                Sécurité
            </button>
        </div>

        <div class="settings-layout">
            <div>

                <!-- TAB: COMPTE -->
                <div class="tab-panel active" id="panel-compte">
