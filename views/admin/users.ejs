<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script>
    (function(){
        try {
            const s = JSON.parse(localStorage.getItem('yuraSettings') || '{}');
            if (s.darkMode === false) {
                const st = document.createElement('style');
                st.id = '__yuraLight';
                st.textContent = `
                    body { background: #f0f2f5 !important; color: #111 !important; }
                    .sidebar { background: #fff !important; border-color: rgba(0,0,0,0.1) !important; }
                    .top-bar { background: #fff !important; border-color: rgba(0,0,0,0.1) !important; }
                    .main-content { background: #f0f2f5 !important; }
                    .content { background: #f0f2f5 !important; }
                    .table-wrap { background: #fff !important; border-color: rgba(0,0,0,0.08) !important; }
                    .modal-box { background: #fff !important; border-color: rgba(0,0,0,0.1) !important; }
                    .form-group input, .form-group select { background: #f5f5f5 !important; border-color: rgba(0,0,0,0.15) !important; color: #111 !important; }
                    .nav-item { color: #555 !important; }
                    .nav-item:hover { background: rgba(0,0,0,0.04) !important; color: #111 !important; }
                    .nav-item.active { color: var(--rouge) !important; background: rgba(192,57,43,0.07) !important; }
                    .logo-name, .user-name-s, h1, .modal-title { color: #111 !important; }
                    .logo-sub, .user-role-s, .topbar-title, .form-label, .table-head span { color: #666 !important; }
                    .topbar-user { background: rgba(192,57,43,0.07) !important; border-color: rgba(192,57,43,0.2) !important; }
                    .robot-badge { background: rgba(192,57,43,0.07) !important; border-color: rgba(192,57,43,0.25) !important; }
                    .user-row-item { border-color: rgba(0,0,0,0.05) !important; }
                    .user-row-item:hover { background: #f8f8f8 !important; }
                    .table-head { background: rgba(0,0,0,0.02) !important; border-color: rgba(0,0,0,0.06) !important; }
                    .user-name-cell { color: #111 !important; }
                    .user-id-cell { color: #888 !important; }
                    .user-email-cell { color: #555 !important; }
                    .action-btn { background: rgba(0,0,0,0.04) !important; border-color: rgba(0,0,0,0.1) !important; color: #555 !important; }
                    .pag-btn { background: rgba(0,0,0,0.04) !important; border-color: rgba(0,0,0,0.1) !important; color: #555 !important; }
                    .pag-info { color: #666 !important; }
                    .search-input { background: #f0f0f0 !important; border-color: rgba(0,0,0,0.1) !important; color: #111 !important; }
                    .filter-select { background: #f0f0f0 !important; border-color: rgba(0,0,0,0.1) !important; color: #555 !important; }
                    .count-badge { background: rgba(192,57,43,0.1) !important; color: var(--rouge) !important; }
                    .user-info-box { background: rgba(0,0,0,0.03) !important; border-color: rgba(0,0,0,0.08) !important; }
                    .access-input { background: #f0f0f0 !important; border-color: rgba(0,0,0,0.12) !important; color: #111 !important; }
                    .access-select { background: #f0f0f0 !important; border-color: rgba(0,0,0,0.12) !important; color: #111 !important; }
                `;
                document.head.appendChild(st);
            }
            if (s.colorTheme === 'blue-black') {
                document.documentElement.style.setProperty('--rouge', '#2563eb');
                document.documentElement.style.setProperty('--rouge-light', '#3b82f6');
                document.documentElement.style.setProperty('--border', 'rgba(37,99,235,0.18)');
            } else if (s.colorTheme === 'green-black') {
                document.documentElement.style.setProperty('--rouge', '#16a34a');
                document.documentElement.style.setProperty('--rouge-light', '#22c55e');
                document.documentElement.style.setProperty('--border', 'rgba(22,163,74,0.18)');
            }
        } catch(e) {}
    })();
    </script>
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        :root {
            --rouge:#c0392b; --rouge-light:#e74c3c;
            --noir:#0a0a0a; --card:#111111; --card2:#161616;
            --border:rgba(192,57,43,0.18); --gris:#888; --gris2:#bbb;
        }
        body { font-family:'Segoe UI',sans-serif; background:var(--noir); color:#fff; display:flex; min-height:100vh; }
        .sidebar { width:300px; min-height:100vh; background:#0d0d0d; border-right:1px solid var(--border); display:flex; flex-direction:column; position:fixed; top:0; left:0; bottom:0; z-index:100; }
        .logo-section { padding:20px 18px; border-bottom:1px solid var(--border); display:flex; align-items:center; gap:14px; }
        .logo-name { font-size:1.1rem; font-weight:800; color:#fff; letter-spacing:2px; }
        .logo-sub { font-size:0.65rem; color:var(--gris); letter-spacing:2px; text-transform:uppercase; }
        .admin-badge-side { margin:12px 16px 4px; padding:8px 14px; background:rgba(192,57,43,0.2); border:1px solid rgba(192,57,43,0.5); border-radius:6px; font-size:0.7rem; font-weight:800; color:var(--rouge-light); letter-spacing:2px; text-transform:uppercase; text-align:center; }
        .robot-badge { margin:8px 16px 6px; padding:10px 16px; background:rgba(192,57,43,0.12); border:1px solid rgba(192,57,43,0.4); border-radius:8px; display:flex; align-items:center; gap:10px; font-size:0.75rem; font-weight:700; color:var(--rouge-light); }
        .badge-dot { width:8px; height:8px; background:var(--rouge-light); border-radius:50%; animation:blink 1.2s infinite; }
        @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.1} }
        .nav-section { padding:8px 0; flex:1; overflow-y:auto; }
        .nav-label { font-size:0.6rem; font-weight:700; color:var(--gris); letter-spacing:2px; padding:12px 18px 5px; text-transform:uppercase; }
        .nav-item { display:flex; align-items:center; gap:13px; padding:11px 18px; color:#666; text-decoration:none; font-size:0.87rem; font-weight:500; border-left:2px solid transparent; transition:all 0.18s; }
        .nav-item:hover { color:#fff; background:rgba(192,57,43,0.07); }
        .nav-item.active { color:#fff; background:rgba(192,57,43,0.13); border-left-color:var(--rouge); font-weight:600; }
        .nav-icon-wrap { width:20px; height:20px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
        .nav-text { flex:1; }
        .nav-count { background:var(--rouge); color:#fff; font-size:0.6rem; font-weight:700; padding:2px 7px; border-radius:10px; }
        .sidebar-footer { border-top:1px solid var(--border); padding:8px 0; }
        .user-row { display:flex; align-items:center; gap:10px; padding:11px 18px; }
        .user-av { width:34px; height:34px; background:linear-gradient(135deg,var(--rouge),#7b241c); border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:0.85rem; font-weight:700; flex-shrink:0; }
        .user-name-s { font-size:0.82rem; font-weight:600; }
        .user-role-s { font-size:0.65rem; color:var(--rouge-light); font-weight:600; }
        .main-content { margin-left:300px; flex:1; display:flex; flex-direction:column; min-height:100vh; }
        .top-bar { height:52px; background:#0d0d0d; border-bottom:1px solid var(--border); display:flex; align-items:center; padding:0 24px; gap:12px; position:sticky; top:0; z-index:50; }
        .topbar-title { font-size:0.78rem; color:var(--gris); letter-spacing:1.5px; text-transform:uppercase; flex:1; }
        .topbar-right { display:flex; align-items:center; gap:10px; }
        .topbar-bell { position:relative; cursor:pointer; text-decoration:none; }
        .bell-badge { position:absolute; top:-4px; right:-4px; width:16px; height:16px; background:var(--rouge); border-radius:50%; font-size:0.6rem; color:#fff; font-weight:700; display:flex; align-items:center; justify-content:center; }
        .topbar-user { display:flex; align-items:center; gap:7px; background:rgba(192,57,43,0.12); border:1px solid rgba(192,57,43,0.35); padding:5px 14px; border-radius:20px; font-size:0.75rem; font-weight:700; color:var(--rouge-light); text-decoration:none; }
        .user-dot { width:7px; height:7px; background:var(--rouge-light); border-radius:50%; }
        .admin-pill { background:rgba(192,57,43,0.25); border:1px solid rgba(192,57,43,0.5); padding:4px 10px; border-radius:4px; font-size:0.62rem; font-weight:800; color:var(--rouge-light); letter-spacing:1.5px; text-transform:uppercase; }
        .content { padding:20px 24px; flex:1; }
        .page-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:20px; flex-wrap:wrap; gap:10px; }
        .page-header-left { display:flex; align-items:center; gap:14px; }
        .page-header h1 { font-size:1.6rem; font-weight:800; }
        .count-badge { background:rgba(192,57,43,0.15); border:1px solid rgba(192,57,43,0.3); color:var(--rouge-light); font-size:0.75rem; font-weight:700; padding:4px 12px; border-radius:20px; }
        .btn-add { display:flex; align-items:center; gap:7px; padding:9px 18px; background:var(--rouge); color:#fff; border:none; border-radius:8px; font-size:0.82rem; font-weight:700; cursor:pointer; transition:all 0.18s; }
        .btn-add:hover { background:var(--rouge-light); transform:translateY(-1px); }
        .filters-bar { display:flex; align-items:center; gap:10px; margin-bottom:14px; flex-wrap:wrap; }
        .search-wrap { position:relative; flex:1; min-width:200px; }
        .search-icon { position:absolute; left:12px; top:50%; transform:translateY(-50%); color:var(--gris); }
        .search-input { width:100%; background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); border-radius:8px; padding:8px 12px 8px 36px; color:#fff; font-size:0.82rem; outline:none; transition:border 0.18s; }
        .search-input:focus { border-color:rgba(192,57,43,0.4); }
        .search-input::placeholder { color:#555; }
        .filter-select { background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); border-radius:8px; padding:8px 12px; color:#888; font-size:0.8rem; outline:none; cursor:pointer; }
        .filter-select option { background:#1a1a1a; color:#fff; }
        .table-wrap { background:var(--card); border:1px solid rgba(255,255,255,0.06); border-radius:12px; overflow:hidden; animation:fadeInUp 0.3s ease both; }
        .table-head { display:grid; grid-template-columns:40px 1fr 140px 120px 200px 130px; padding:10px 18px; background:rgba(255,255,255,0.02); border-bottom:1px solid rgba(255,255,255,0.05); }
        .table-head span { font-size:0.62rem; font-weight:700; color:var(--gris); text-transform:uppercase; letter-spacing:1.2px; }
        .user-row-item { display:grid; grid-template-columns:40px 1fr 140px 120px 200px 130px; padding:12px 18px; border-bottom:1px solid rgba(255,255,255,0.04); align-items:center; transition:background 0.15s; }
        .user-row-item:last-child { border-bottom:none; }
        .user-row-item:hover { background:rgba(255,255,255,0.02); }
        .user-cell { display:flex; align-items:center; gap:11px; }
        .user-av-table { width:36px; height:36px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:0.9rem; font-weight:800; flex-shrink:0; color:#fff; }
        .user-name-cell { font-size:0.85rem; font-weight:600; color:#fff; }
        .user-id-cell { font-size:0.72rem; color:#555; margin-top:2px; }
        .status-pill { display:inline-flex; align-items:center; gap:5px; font-size:0.68rem; font-weight:700; padding:4px 10px; border-radius:20px; }
        .status-pill.active { background:rgba(39,174,96,0.12); color:#27ae60; border:1px solid rgba(39,174,96,0.25); }
        .status-pill.inactive { background:rgba(136,136,136,0.1); color:#666; border:1px solid rgba(136,136,136,0.2); }
        .status-dot { width:6px; height:6px; border-radius:50%; }
        .status-dot.active { background:#27ae60; }
        .status-dot.inactive { background:#555; }
        .role-pill { display:inline-flex; font-size:0.65rem; font-weight:700; padding:3px 9px; border-radius:4px; text-transform:uppercase; letter-spacing:0.5px; }
        .role-pill.admin { background:rgba(192,57,43,0.18); color:var(--rouge-light); border:1px solid rgba(192,57,43,0.3); }
        .role-pill.agent { background:rgba(59,130,246,0.12); color:#3b82f6; border:1px solid rgba(59,130,246,0.25); }
        .user-email-cell { font-size:0.78rem; color:#555; }
        .actions-cell { display:flex; align-items:center; gap:6px; }
        .action-btn { width:30px; height:30px; border-radius:6px; border:1px solid rgba(255,255,255,0.08); background:rgba(255,255,255,0.04); color:#666; cursor:pointer; display:flex; align-items:center; justify-content:center; transition:all 0.15s; }
        .action-btn:hover { background:rgba(192,57,43,0.15); border-color:rgba(192,57,43,0.35); color:#fff; }
        .action-btn.toggle-on { background:rgba(39,174,96,0.12); border-color:rgba(39,174,96,0.3); color:#27ae60; }
        .action-btn.toggle-on:hover { background:rgba(39,174,96,0.2); }
        .action-btn.del:hover { background:rgba(192,57,43,0.2); border-color:rgba(192,57,43,0.4); color:var(--rouge-light); }
        .action-btn.access:hover { background:rgba(59,130,246,0.15); border-color:rgba(59,130,246,0.35); color:#3b82f6; }
        .pagination { display:flex; align-items:center; justify-content:space-between; padding:14px 18px; border-top:1px solid rgba(255,255,255,0.05); }
        .pag-info { font-size:0.75rem; color:var(--gris); }
        .pag-btns { display:flex; gap:6px; }
        .pag-btn { padding:6px 14px; background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); border-radius:6px; color:#888; font-size:0.78rem; font-weight:600; cursor:pointer; transition:all 0.15s; text-decoration:none; display:inline-block; }
        .pag-btn:hover { background:rgba(192,57,43,0.12); border-color:rgba(192,57,43,0.3); color:#fff; }
        .pag-btn.active { background:var(--rouge); border-color:var(--rouge); color:#fff; }
        .pag-btn.disabled { opacity:0.3; pointer-events:none; }
        .empty-state { padding:50px 20px; text-align:center; color:var(--gris); }
        .success-msg { background:rgba(39,174,96,0.12); border:1px solid rgba(39,174,96,0.3); color:#27ae60; padding:10px 14px; border-radius:8px; font-size:0.8rem; margin-bottom:14px; }
        .modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.75); z-index:200; align-items:center; justify-content:center; }
        .modal-overlay.open { display:flex; }
        .modal-box { background:#111; border:1px solid var(--border); border-radius:14px; padding:28px; width:500px; max-width:95vw; max-height:90vh; overflow-y:auto; }
        .modal-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:22px; }
        .modal-title { font-size:1.1rem; font-weight:800; color:#fff; }
        .modal-close { width:30px; height:30px; background:rgba(255,255,255,0.06); border:none; border-radius:6px; color:#888; cursor:pointer; font-size:1.1rem; display:flex; align-items:center; justify-content:center; }
        .modal-close:hover { background:rgba(192,57,43,0.2); color:#fff; }
        .form-grid { display:grid; grid-template-columns:1fr 1fr; gap:14px; }
        .form-group { display:flex; flex-direction:column; gap:6px; }
        .form-group.full { grid-column:1/-1; }
        .form-label { font-size:0.72rem; font-weight:600; color:var(--gris); text-transform:uppercase; letter-spacing:0.8px; }
        .form-group input, .form-group select { background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.1); border-radius:8px; padding:9px 13px; color:#fff; font-size:0.85rem; outline:none; transition:border 0.18s; font-family:inherit; }
        .form-group input:focus, .form-group select:focus { border-color:rgba(192,57,43,0.5); }
        .form-group select option { background:#1a1a1a; }
        .form-group input::placeholder { color:#444; }
        .modal-actions { display:flex; gap:10px; justify-content:flex-end; margin-top:22px; }
        .btn-cancel { padding:9px 18px; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); border-radius:8px; color:#888; font-size:0.82rem; font-weight:600; cursor:pointer; }
        .btn-cancel:hover { background:rgba(255,255,255,0.09); color:#fff; }
        .btn-submit { padding:9px 20px; background:var(--rouge); border:none; border-radius:8px; color:#fff; font-size:0.82rem; font-weight:700; cursor:pointer; transition:all 0.18s; }
        .btn-submit:hover { background:var(--rouge-light); }
        .error-msg { background:rgba(192,57,43,0.12); border:1px solid rgba(192,57,43,0.3); color:var(--rouge-light); padding:10px 14px; border-radius:8px; font-size:0.8rem; margin-bottom:14px; }
        .user-info-box { background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.07); border-radius:10px; padding:14px; margin-bottom:18px; }
        .section-sep { font-size:0.68rem; font-weight:700; color:var(--gris); text-transform:uppercase; letter-spacing:1px; margin-bottom:8px; margin-top:16px; padding-top:16px; border-top:1px solid rgba(255,255,255,0.05); }
        .access-input { background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.1); border-radius:8px; padding:9px 13px; color:#fff; font-size:0.85rem; outline:none; font-family:inherit; transition:border 0.18s; width:100%; }
        .access-input:focus { border-color:rgba(192,57,43,0.5); }
        .access-input::placeholder { color:#444; }
        .access-select { background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.1); border-radius:8px; padding:9px 13px; color:#fff; font-size:0.85rem; outline:none; font-family:inherit; cursor:pointer; flex:1; }
        .access-select option { background:#1a1a1a; color:#fff; }
        @keyframes fadeInUp { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }
    </style>
</head>
<body>

<!-- MODAL AJOUT -->
<div class="modal-overlay" id="addModal">
    <div class="modal-box">
        <div class="modal-header">
            <div class="modal-title">Ajouter un utilisateur</div>
            <button class="modal-close" onclick="closeModal()">✕</button>
        </div>
        <% if(typeof error !== 'undefined' && error) { %>
        <div class="error-msg">⚠️ Cet identifiant ou email existe déjà.</div>
        <% } %>
        <form action="/admin/users/add" method="POST">
            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label">Nom complet</label>
                    <input type="text" name="name" placeholder="ex: Ahmed Ben Ali" required>
                </div>
                <div class="form-group">
                    <label class="form-label">Identifiant</label>
                    <input type="text" name="identifiant" placeholder="ex: ahmed.benali" required>
                </div>
                <div class="form-group full">
                    <label class="form-label">Email</label>
                    <input type="email" name="email" placeholder="ex: ahmed@yura.com" required>
                </div>
                <div class="form-group">
                    <label class="form-label">Mot de passe</label>
                    <input type="password" name="password" placeholder="Min. 6 caractères" required>
                </div>
                <div class="form-group">
                    <label class="form-label">Rôle</label>
                    <select name="role">
                        <option value="agent">Agent Sécurité</option>
                        <option value="admin">Administrateur</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Poste</label>
                    <input type="text" name="position" placeholder="ex: Agent de Surveillance">
                </div>
                <div class="form-group">
                    <label class="form-label">Statut</label>
                    <select name="status">
                        <option value="active">Actif</option>
                        <option value="inactive">Inactif</option>
                    </select>
                </div>
            </div>
            <div class="modal-actions">
                <button type="button" class="btn-cancel" onclick="closeModal()">Annuler</button>
                <button type="submit" class="btn-submit">Créer l'utilisateur</button>
            </div>
        </form>
    </div>
</div>

<!-- MODAL GESTION ACCES -->
<div class="modal-overlay" id="accessModal">
    <div class="modal-box" style="width:460px;">
        <div class="modal-header">
            <div class="modal-title">Gestion Accès — <span id="modalUserName" style="color:var(--rouge-light)"></span></div>
            <button class="modal-close" onclick="closeAccessModal()">✕</button>
        </div>
        <div class="user-info-box">
            <div style="display:flex;align-items:center;gap:12px;">
                <div id="modalUserAv" style="width:42px;height:42px;background:linear-gradient(135deg,var(--rouge),#7b241c);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.1rem;font-weight:800;flex-shrink:0;color:#fff;"></div>
                <div>
                    <div style="font-size:0.88rem;font-weight:700;color:#fff;" id="modalUserNameFull"></div>
                    <div style="font-size:0.72rem;color:#555;margin-top:2px;" id="modalUserEmail"></div>
                </div>
                <div style="margin-left:auto;display:flex;flex-direction:column;align-items:flex-end;gap:5px;">
                    <span id="modalUserRoleBadge"></span>
                    <span id="modalUserStatusBadge"></span>
                </div>
            </div>
            <div style="margin-top:10px;padding-top:10px;border-top:1px solid rgba(255,255,255,0.05);display:grid;grid-template-columns:1fr 1fr;gap:8px;">
                <div>
                    <div style="font-size:0.6rem;color:#444;text-transform:uppercase;letter-spacing:0.8px;">Identifiant</div>
                    <div style="font-size:0.78rem;color:#777;margin-top:2px;" id="modalUserIdent"></div>
                </div>
                <div>
                    <div style="font-size:0.6rem;color:#444;text-transform:uppercase;letter-spacing:0.8px;">Dernière connexion</div>
                    <div style="font-size:0.78rem;color:#777;margin-top:2px;">Aujourd'hui</div>
                </div>
            </div>
        </div>
        <div class="section-sep" style="margin-top:0;padding-top:0;border-top:none;">Statut du compte</div>
        <form id="toggleForm" action="#" method="POST">
            <button type="submit" id="toggleBtn" style="width:100%;display:flex;align-items:center;justify-content:center;gap:8px;padding:10px 16px;border-radius:8px;font-size:0.82rem;font-weight:700;cursor:pointer;border:1px solid transparent;transition:all 0.18s;"></button>
        </form>
       
        <div class="section-sep">Changer le mot de passe</div>
        <form id="pwdForm" action="#" method="POST" style="display:flex;gap:8px;" onsubmit="return validatePwd()">
            <input type="password" name="newPassword" id="newPwdInput" class="access-input" placeholder="Nouveau mot de passe (min. 6 caractères)">
            <button type="submit" style="padding:9px 14px;background:rgba(59,130,246,0.85);border:none;border-radius:8px;color:#fff;font-size:0.8rem;font-weight:700;cursor:pointer;white-space:nowrap;display:flex;align-items:center;gap:4px;flex-shrink:0;">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="6" width="8" height="5" rx="1"/><path d="M4 6V4a2 2 0 014 0v2"/></svg>
                Changer
            </button>
        </form>
        <div id="pwdError" style="font-size:0.72rem;color:var(--rouge-light);margin-top:6px;display:none;">⚠️ Mot de passe trop court (min. 6 caractères)</div>
        <% if(typeof successMsg !== 'undefined' && successMsg) { %>
        <div style="background:rgba(39,174,96,0.12);border:1px solid rgba(39,174,96,0.3);color:#27ae60;padding:10px 14px;border-radius:8px;font-size:0.8rem;margin-top:14px;">✅ <%= successMsg %></div>
        <% } %>
    </div>
</div>

<!-- SIDEBAR -->
<!-- SIDEBAR -->
