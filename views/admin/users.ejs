<!-- MAIN -->
<div class="main-content">
    <div class="top-bar">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="#888"><rect y="3" width="18" height="2"/><rect y="8" width="18" height="2"/><rect y="13" width="18" height="2"/></svg>
        <span class="topbar-title">Gestion Utilisateurs</span>
        <div class="topbar-right">
            <span class="admin-pill">ADMIN</span>
            <a href="/admin/notifications" class="topbar-bell">
                <svg width="18" height="18" viewBox="0 0 16 16" fill="#888"><path d="M8 1a5 5 0 00-5 5v3l-1.5 2.5h13L13 9V6a5 5 0 00-5-5zm0 14a2 2 0 01-2-2h4a2 2 0 01-2 2z"/></svg>
                <div class="bell-badge">3</div>
            </a>
            <a href="/dashboard/settings" class="topbar-user"><div class="user-dot"></div><%= user.name %></a>
        </div>
    </div>
    <div class="content">
        <div class="page-header">
            <div class="page-header-left">
                <h1>Utilisateurs</h1>
                <span class="count-badge"><%= total %> utilisateurs</span>
            </div>
            <button class="btn-add" onclick="openModal()">
                <svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="2"><line x1="6.5" y1="1" x2="6.5" y2="12"/><line x1="1" y1="6.5" x2="12" y2="6.5"/></svg>
                Ajouter un utilisateur
            </button>
        </div>
        <% if(typeof successMsg !== 'undefined' && successMsg) { %>
        <div class="success-msg">✅ <%= successMsg %></div>
        <% } %>
        <div class="filters-bar">
            <div class="search-wrap">
                <span class="search-icon"><svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="6" cy="6" r="4"/><path d="M10 10l2.5 2.5"/></svg></span>
                <input type="text" class="search-input" id="searchInput" placeholder="Rechercher un utilisateur..." oninput="filterUsers()">
            </div>
            <select class="filter-select" id="roleFilter" onchange="filterUsers()">
                <option value="">Tous les rôles</option>
                <option value="admin">Admin</option>
                <option value="agent">Agent</option>
            </select>
            <select class="filter-select" id="statusFilter" onchange="filterUsers()">
                <option value="">Tous les statuts</option>
                <option value="active">Actif</option>
                <option value="inactive">Inactif</option>
            </select>
        </div>
        <div class="table-wrap">
            <div class="table-head">
                <span>#</span><span>Utilisateur</span><span>Statut</span><span>Rôle</span><span>Email</span><span>Actions</span>
            </div>
            <div id="usersList">
            <% if(users && users.length > 0) { %>
                <% users.forEach(function(u, i) { %>
                <div class="user-row-item"
                     data-name="<%= u.name ? u.name.toLowerCase() : '' %>"
                     data-role="<%= u.role %>"
                     data-status="<%= u.status %>">
                    <span style="font-size:0.72rem;color:#444;font-weight:600;"><%= i + 1 %></span>
                    <div class="user-cell">
                        <div class="user-av-table" style="background:linear-gradient(135deg,<%= u.role === 'admin' ? 'var(--rouge),#7b241c' : '#1a4fa8,#0d3080' %>);">
                            <%= u.name ? u.name.charAt(0).toUpperCase() : '?' %>
                        </div>
                        <div>
                            <div class="user-name-cell"><%= u.name %></div>
                            <div class="user-id-cell">@<%= u.identifiant %></div>
                        </div>
                    </div>
                    <div>
                        <span class="status-pill <%= u.status === 'active' ? 'active' : 'inactive' %>">
                            <span class="status-dot <%= u.status === 'active' ? 'active' : 'inactive' %>"></span>
                            <%= u.status === 'active' ? 'Actif' : 'Inactif' %>
                        </span>
                    </div>
                    <div>
                        <span class="role-pill <%= u.role === 'admin' ? 'admin' : 'agent' %>">
                            <%= u.role === 'admin' ? 'Admin' : 'Agent' %>
                        </span>
                    </div>
                    <div class="user-email-cell"><%= u.email %></div>
                    <div class="actions-cell">
                        <button type="button" class="action-btn access" title="Gestion accès"
                            data-id="<%= u._id %>"
                            data-name="<%= u.name %>"
                            data-email="<%= u.email %>"
                            data-ident="<%= u.identifiant %>"
                            data-role="<%= u.role %>"
                            data-status="<%= u.status %>"
                            onclick="openAccessModal(this)">
                            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="6" width="8" height="5" rx="1"/><path d="M4 6V4a2 2 0 014 0v2"/></svg>
                        </button>
                        <form action="/admin/users/toggle/<%= u._id %>" method="POST" style="display:inline">
                            <button type="submit" class="action-btn <%= u.status === 'active' ? '' : 'toggle-on' %>" title="<%= u.status === 'active' ? 'Désactiver' : 'Activer' %>">
                                <% if(u.status === 'active') { %>
                                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2"><line x1="2" y1="2" x2="10" y2="10"/><line x1="10" y1="2" x2="2" y2="10"/></svg>
                                <% } else { %>
                                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2"><polyline points="2,6 5,9 10,3"/></svg>
                                <% } %>
                            </button>
                        </form>
                        <form action="/admin/users/delete/<%= u._id %>" method="POST" style="display:inline" onsubmit="return confirm('Supprimer <%= u.name %> ?')">
                            <button type="submit" class="action-btn del" title="Supprimer">
                                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3h8M5 3V2h2v1M4 3v7h4V3H4z"/></svg>
                            </button>
                        </form>
                    </div>
                </div>
                <% }); %>
            <% } else { %>
                <div class="empty-state"><p>Aucun utilisateur trouvé</p></div>
            <% } %>
            </div>
            <% if(totalPages > 1) { %>
            <div class="pagination">
                <span class="pag-info">Page <%= currentPage %> / <%= totalPages %> — <%= total %> utilisateurs</span>
                <div class="pag-btns">
                    <a href="?page=<%= currentPage - 1 %>" class="pag-btn <%= currentPage <= 1 ? 'disabled' : '' %>">← Préc.</a>
                    <% for(let p = 1; p <= totalPages; p++) { %>
                    <a href="?page=<%= p %>" class="pag-btn <%= p === currentPage ? 'active' : '' %>"><%= p %></a>
                    <% } %>
                    <a href="?page=<%= currentPage + 1 %>" class="pag-btn <%= currentPage >= totalPages ? 'disabled' : '' %>">Suiv. →</a>
                </div>
            </div>
            <% } %>
        </div>
    </div>
</div>

<script>
function openModal() { document.getElementById('addModal').classList.add('open'); }
function closeModal() { document.getElementById('addModal').classList.remove('open'); }
document.getElementById('addModal').addEventListener('click', function(e) { if(e.target===this) closeModal(); });
<% if(typeof error !== 'undefined' && error) { %>
window.addEventListener('DOMContentLoaded', function(){ openModal(); });
<% } %>

function filterUsers() {
    const search = document.getElementById('searchInput').value.toLowerCase();
    const role   = document.getElementById('roleFilter').value;
    const status = document.getElementById('statusFilter').value;
    document.querySelectorAll('.user-row-item').forEach(function(row) {
        const ok = (row.dataset.name||'').includes(search)
                && (!role   || row.dataset.role   === role)
                && (!status || row.dataset.status === status);
        row.style.display = ok ? '' : 'none';
    });
}

function openAccessModal(btn) {
    const id     = btn.dataset.id;
    const name   = btn.dataset.name;
    const email  = btn.dataset.email;
    const ident  = btn.dataset.ident;
    const role   = btn.dataset.role;
    const status = btn.dataset.status;

    document.getElementById('modalUserName').textContent     = name;
    document.getElementById('modalUserNameFull').textContent = name;
    document.getElementById('modalUserEmail').textContent    = email;
    document.getElementById('modalUserIdent').textContent    = '@' + ident;
    document.getElementById('modalUserAv').textContent       = name.charAt(0).toUpperCase();

    const roleBadge = document.getElementById('modalUserRoleBadge');
    roleBadge.textContent = role === 'admin' ? 'Admin' : 'Agent';
    roleBadge.style.cssText = role === 'admin'
        ? 'background:rgba(192,57,43,0.2);color:#e74c3c;border:1px solid rgba(192,57,43,0.3);border-radius:4px;font-size:0.65rem;font-weight:700;padding:3px 9px;'
        : 'background:rgba(59,130,246,0.12);color:#3b82f6;border:1px solid rgba(59,130,246,0.25);border-radius:4px;font-size:0.65rem;font-weight:700;padding:3px 9px;';

    const statusBadge = document.getElementById('modalUserStatusBadge');
    statusBadge.textContent = status === 'active' ? 'Actif' : 'Inactif';
    statusBadge.style.cssText = status === 'active'
        ? 'background:rgba(39,174,96,0.12);color:#27ae60;border:1px solid rgba(39,174,96,0.25);border-radius:10px;font-size:0.65rem;font-weight:700;padding:3px 9px;'
        : 'background:rgba(136,136,136,0.1);color:#666;border:1px solid rgba(136,136,136,0.2);border-radius:10px;font-size:0.65rem;font-weight:700;padding:3px 9px;';

    const toggleBtn = document.getElementById('toggleBtn');
    document.getElementById('toggleForm').action = '/admin/users/toggle/' + id;
    if (status === 'active') {
        toggleBtn.style.cssText = 'width:100%;display:flex;align-items:center;justify-content:center;gap:8px;padding:10px 16px;border-radius:8px;font-size:0.82rem;font-weight:700;cursor:pointer;background:rgba(192,57,43,0.12);border:1px solid rgba(192,57,43,0.35);color:#e74c3c;transition:all 0.18s;';
        toggleBtn.innerHTML = '<svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="2"><line x1="2" y1="2" x2="11" y2="11"/><line x1="11" y1="2" x2="2" y2="11"/></svg> Désactiver le compte';
    } else {
        toggleBtn.style.cssText = 'width:100%;display:flex;align-items:center;justify-content:center;gap:8px;padding:10px 16px;border-radius:8px;font-size:0.82rem;font-weight:700;cursor:pointer;background:rgba(39,174,96,0.12);border:1px solid rgba(39,174,96,0.3);color:#27ae60;transition:all 0.18s;';
        toggleBtn.innerHTML = '<svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="2"><polyline points="2,6 5,9 11,3"/></svg> Activer le compte';
    }

   
    document.getElementById('pwdForm').action          = '/admin/users/change-password/' + id;
    document.getElementById('newPwdInput').value       = '';
    document.getElementById('pwdError').style.display  = 'none';

    document.getElementById('accessModal').classList.add('open');
}

function closeAccessModal() {
    document.getElementById('accessModal').classList.remove('open');
}

function validatePwd() {
    const val = document.getElementById('newPwdInput').value;
    if (val.length < 6) {
        document.getElementById('pwdError').style.display = 'block';
        return false;
    }
    return true;
}

document.getElementById('accessModal').addEventListener('click', function(e) {
    if (e.target === this) closeAccessModal();
});
</script>
</body>
</html>