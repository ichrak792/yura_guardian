<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
    <div class="admin-container">
        <%- include('../partials/admin-sidebar') %>
        <main class="main-content">
            <header class="top-bar">
                <div class="top-bar-left">
                    <h1>Utilisateurs</h1>
                    <span class="total-badge"><%= total %> utilisateurs</span>
                </div>
                <div class="top-bar-right">
                    <button class="btn-primary" onclick="document.getElementById('addModal').style.display='flex'">
                        + Ajouter un utilisateur
                    </button>
                </div>
            </header>

            <div class="content-wrapper">
                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="alert-error">⚠️ Cet identifiant ou email existe déjà.</div>
                <% } %>

                <div class="users-table-container">
                    <table class="users-table">
                        <thead>
                            <tr>
                                <th><input type="checkbox"></th>
                                <th>Name</th>
                                <th>Status</th>
                                <th>Role</th>
                                <th>Email address</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% users.forEach(function(u) { %>
                            <tr>
                                <td><input type="checkbox"></td>
                                <td>
                                    <div class="user-cell">
                                        <div class="user-avatar" style="background: <%= ['#667eea','#f093fb','#4facfe','#43e97b','#fa709a','#fee140'][Math.floor(Math.random()*6)] %>">
                                            <%= u.name.charAt(0).toUpperCase() %>
                                        </div>
                                        <div>
                                            <div class="user-name"><%= u.name %></div>
                                            <div class="user-id">@<%= u.identifiant %></div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="status-badge <%= u.status === 'active' ? 'status-active' : 'status-inactive' %>">
                                        ● <%= u.status === 'active' ? 'Active' : 'Inactive' %>
                                    </span>
                                </td>
                                <td>
                                    <span class="role-tag role-<%= u.role %>">
                                        <%= u.position || u.role %>
                                    </span>
                                </td>
                                <td class="email-cell"><%= u.email %></td>
                                <td>
                                    <div class="action-buttons">
                                        <form action="/admin/users/toggle/<%= u._id %>" method="POST" style="display:inline">
                                            <button type="submit" class="action-btn" title="<%= u.status === 'active' ? 'Désactiver' : 'Activer' %>">
                                                <%= u.status === 'active' ? '🔕' : '✅' %>
                                            </button>
                                        </form>
                                        <form action="/admin/users/delete/<%= u._id %>" method="POST" style="display:inline" onsubmit="return confirm('Supprimer cet utilisateur?')">
                                            <button type="submit" class="action-btn delete-btn" title="Supprimer">🗑️</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>

                    <div class="pagination">
                        <% if (currentPage > 1) { %>
                            <a href="/admin/users?page=<%= currentPage - 1 %>" class="pagination-btn">← Précédent</a>
                        <% } %>
                        <span class="page-info">Page <%= currentPage %> / <%= totalPages %></span>
                        <% if (currentPage < totalPages) { %>
                            <a href="/admin/users?page=<%= currentPage + 1 %>" class="pagination-btn">Suivant →</a>
                        <% } %>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Modal Ajouter Utilisateur -->
    <div class="modal-overlay" id="addModal" onclick="if(event.target===this)this.style.display='none'">
        <div class="modal">
            <div class="modal-header">
                <h2>Ajouter un utilisateur</h2>
                <button class="modal-close" onclick="document.getElementById('addModal').style.display='none'">✕</button>
            </div>
            <form action="/admin/users/add" method="POST" class="modal-form">
                <div class="form-row">
                    <div class="form-group">
                        <label>Nom complet</label>
                        <input type="text" name="name" required placeholder="Prénom Nom">
                    </div>
                    <div class="form-group">
                        <label>Identifiant</label>
                        <input type="text" name="identifiant" required placeholder="username">
                    </div>
                </div>
                <div class="form-group">
                    <label>Email</label>
                    <input type="email" name="email" required placeholder="email@yura.com">
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Mot de passe</label>
                        <input type="password" name="password" required placeholder="••••••••">
                    </div>
                    <div class="form-group">
                        <label>Rôle</label>
                        <select name="role">
                            <option value="security">Sécurité</option>
                            <option value="admin">Admin</option>
                        </select>
                    </div>
                </div>
                <div class="form-group">
                    <label>Position / Fonction</label>
                    <input type="text" name="position" placeholder="Ex: Agent de Surveillance">
                </div>
                <div class="form-group">
                    <label>Statut</label>
                    <select name="status">
                        <option value="active">Actif</option>
                        <option value="inactive">Inactif</option>
                    </select>
                </div>
                <div class="modal-actions">
                    <button type="button" class="btn-secondary" onclick="document.getElementById('addModal').style.display='none'">Annuler</button>
                    <button type="submit" class="btn-primary">Créer l'utilisateur</button>
                </div>
            </form>
        </div>
    </div>
</body>
</html>
