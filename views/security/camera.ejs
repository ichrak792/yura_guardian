<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="/js/theme.js"></script>
    
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        :root {
            --rouge: #c0392b;
            --rouge-light: #e74c3c;
            --noir: #0a0a0a;
            --card: #111111;
            --card2: #161616;
            --border: rgba(192,57,43,0.18);
            --gris: #888;
            --gris2: #bbb;
        }
        body { font-family: 'Segoe UI', sans-serif; background: var(--noir); color: #fff; display: flex; min-height: 100vh; }

        /* SIDEBAR */
        .sidebar {
            width: 300px; min-height: 100vh;
            background: #0d0d0d;
            border-right: 1px solid var(--border);
            display: flex; flex-direction: column;
            position: fixed; top:0; left:0; bottom:0; z-index:100;
        }
        .logo-section {
            padding: 20px 18px;
            border-bottom: 1px solid var(--border);
            display: flex; align-items: center; gap: 14px;
        }
        .logo-icon {
            width: 48px; height: 48px;
            background: var(--rouge);
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.4rem;
            box-shadow: 0 0 15px rgba(192,57,43,0.4);
            flex-shrink: 0;
        }
        .logo-texts { display: flex; flex-direction: column; }
        .logo-name { font-size: 1.1rem; font-weight: 800; color: #fff; letter-spacing: 2px; }
        .logo-sub  { font-size: 0.65rem; color: var(--gris); letter-spacing: 2px; text-transform: uppercase; }

        .robot-badge {
            margin: 16px 16px 6px;
            padding: 11px 18px;
            background: rgba(192,57,43,0.15);
            border: 1px solid rgba(192,57,43,0.5);
            border-radius: 8px;
            display: flex; align-items: center; gap: 10px;
            font-size: 0.78rem; font-weight: 700;
            color: var(--rouge-light); letter-spacing: 1px;
        }
        .badge-dot {
            width: 9px; height: 9px;
            background: var(--rouge-light); border-radius: 50%;
            animation: blink 1.2s infinite;
            box-shadow: 0 0 6px rgba(231,76,60,0.8);
        }
        @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.15} }

        .nav-section { padding: 10px 0; flex:1; }
        .nav-label { font-size: 0.62rem; font-weight: 700; color: var(--gris); letter-spacing: 2px; padding: 14px 18px 6px; text-transform: uppercase; }
        .nav-item {
            display: flex; align-items: center; gap: 14px;
            padding: 12px 18px; color: #777; text-decoration: none;
            font-size: 0.9rem; font-weight: 500;
            border-left: 2px solid transparent;
            transition: all 0.18s; cursor: pointer;
        }
        .nav-item:hover { color: #fff; background: rgba(192,57,43,0.07); }
        .nav-item.active { color: #fff; background: rgba(192,57,43,0.13); border-left-color: var(--rouge); font-weight: 600; }
        .nav-icon-wrap { width: 22px; height: 22px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
        .nav-text { flex: 1; }
        .nav-count { background: var(--rouge); color: #fff; font-size: 0.65rem; font-weight: 700; padding: 3px 8px; border-radius: 12px; }

        .sidebar-footer { border-top: 1px solid var(--border); padding: 10px 0; }
        .user-row { display: flex; align-items: center; gap: 11px; padding: 12px 18px; }
        .user-av { width: 36px; height: 36px; background: linear-gradient(135deg, var(--rouge), #7b241c); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.9rem; font-weight: 700; flex-shrink: 0; }
        .user-name-s { font-size: 0.85rem; font-weight: 600; }
        .user-role-s { font-size: 0.68rem; color: var(--gris); }

        /* MAIN */
        .main-content { margin-left: 300px; flex: 1; display: flex; flex-direction: column; min-height: 100vh; }

        .top-bar {
            height: 52px; background: #0d0d0d;
            border-bottom: 1px solid var(--border);
            display: flex; align-items: center;
            padding: 0 24px; gap: 14px;
            position: sticky; top:0; z-index:50;
        }
        .topbar-title { font-size: 0.8rem; color: var(--gris); letter-spacing: 1.5px; text-transform: uppercase; flex:1; }
        .topbar-right { display: flex; align-items: center; gap: 14px; }
        .topbar-bell { font-size: 1.1rem; color: var(--gris); position: relative; cursor: pointer; }
        .bell-badge { position: absolute; top:-4px; right:-4px; width:16px; height:16px; background: var(--rouge); border-radius: 50%; font-size: 0.6rem; color:#fff; font-weight:700; display: flex; align-items:center; justify-content:center; }
        .topbar-user { display: flex; align-items: center; gap: 7px; background: rgba(192,57,43,0.12); border: 1px solid rgba(192,57,43,0.35); padding: 5px 14px; border-radius: 20px; font-size: 0.78rem; font-weight: 600; color: var(--rouge-light); }
        .user-dot { width:7px; height:7px; background:var(--rouge-light); border-radius:50%; }

        /* CONTENT */
        .content { padding: 20px 24px; flex:1; display: flex; gap: 16px; }

        /* MAIN CAM AREA */
        .cam-main { flex: 1; display: flex; flex-direction: column; gap: 14px; }

        /* CAM CARD */
        .cam-card { background: var(--card); border: 1px solid rgba(255,255,255,0.06); border-radius: 12px; overflow: hidden; flex:1; display:flex; flex-direction:column; }

        .cam-header {
            display: flex; align-items: center; gap: 14px;
            padding: 13px 18px; border-bottom: 1px solid rgba(255,255,255,0.05);
        }
        .cam-title-row { display: flex; align-items: center; gap: 9px; flex:1; }
        .cam-icon { color: var(--rouge); }
        .cam-name { font-size: 1rem; font-weight: 700; color: #fff; }
        .rec-badge { display: flex; align-items: center; gap: 6px; font-size: 0.78rem; font-weight: 700; color: var(--rouge-light); letter-spacing: 1px; }
        .rec-dot { width:8px; height:8px; background:var(--rouge-light); border-radius:50%; animation:blink 0.9s infinite; }

        .cam-controls-top { display: flex; align-items: center; gap: 10px; margin-left: auto; }
        .cam-ctrl-btn {
            width: 34px; height: 34px;
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 7px; cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            color: #888; transition: all 0.18s;
        }
        .cam-ctrl-btn:hover { background: rgba(192,57,43,0.15); border-color: rgba(192,57,43,0.4); color: #fff; }

        /* CAM VIEW */
        .cam-view {
            position: relative; background: #000;
            flex:1; min-height: 420px; overflow: hidden;
        }
        .cam-view video { width:100%; height:100%; object-fit:cover; display:none; position:absolute; inset:0; }

        .cam-corners { position:absolute; inset:0; pointer-events:none; z-index:2; }
        .corner { position:absolute; width:28px; height:28px; border-color:rgba(231,76,60,0.7); border-style:solid; }
        .corner-tl { top:16px; left:16px; border-width:2px 0 0 2px; }
        .corner-tr { top:16px; right:16px; border-width:2px 2px 0 0; }
        .corner-bl { bottom:48px; left:16px; border-width:0 0 2px 2px; }
        .corner-br { bottom:48px; right:16px; border-width:0 2px 2px 0; }

        .cam-crosshair { position:absolute; inset:0; display:flex; align-items:center; justify-content:center; pointer-events:none; z-index:2; }

        .cam-overlay-bottom {
            position:absolute; bottom:0; left:0; right:0;
            padding: 10px 16px;
            background: linear-gradient(transparent, rgba(0,0,0,0.8));
            z-index:3; display:flex; flex-direction:column; gap:2px;
        }
        .cam-overlay-line { font-size:0.72rem; color:var(--rouge-light); font-family:monospace; opacity:0.85; }

        .cam-no-signal { position:absolute; inset:0; display:flex; align-items:center; justify-content:center; flex-direction:column; gap:12px; z-index:1; }
        .cam-no-signal-icon { font-size:3rem; opacity:0.08; }
        .cam-no-signal p { font-size:0.85rem; color:rgba(255,255,255,0.18); }

        /* CAM FOOTER BUTTONS */
        .cam-footer { padding: 12px 16px; border-top: 1px solid rgba(255,255,255,0.05); display: flex; gap: 10px; }
        .cam-btn {
            flex:1; padding:10px 8px;
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 8px; color: #888;
            font-size:0.8rem; font-weight:600;
            cursor:pointer; transition:all 0.18s;
            display:flex; align-items:center; justify-content:center; gap:6px;
        }
        .cam-btn:hover { background:rgba(192,57,43,0.12); border-color:rgba(192,57,43,0.35); color:#ccc; }
        .cam-btn.active { background:rgba(192,57,43,0.2); border-color:rgba(192,57,43,0.6); color:var(--rouge-light); }
        .cam-btn:disabled { opacity:0.3; cursor:not-allowed; }

        /* ADVANCED PANEL */
        .adv-panel { display: grid; grid-template-columns: repeat(4,1fr); gap: 10px; }
        .adv-card { background: var(--card); border: 1px solid rgba(255,255,255,0.06); border-radius: 10px; padding: 14px 16px; }
        .adv-label { font-size:0.62rem; color:var(--gris); text-transform:uppercase; letter-spacing:1px; margin-bottom:8px; }
        .adv-val   { font-size:0.9rem; font-weight:700; color:#fff; }
        .adv-bar   { height:3px; background:rgba(255,255,255,0.07); border-radius:3px; overflow:hidden; margin-top:8px; }
        .adv-fill  { height:100%; background:var(--rouge); border-radius:3px; transition:width 0.5s; }

        .toggle-row { display:flex; align-items:center; justify-content:space-between; margin-bottom:8px; }
        .toggle-label { font-size:0.8rem; color:var(--gris2); }
        .mini-toggle { width:34px; height:18px; background:#2a2a2a; border-radius:9px; position:relative; cursor:pointer; transition:background 0.3s; border:1px solid rgba(255,255,255,0.08); }
        .mini-toggle.on { background:rgba(192,57,43,0.5); border-color:rgba(192,57,43,0.7); }
        .mini-knob { position:absolute; width:12px; height:12px; background:#888; border-radius:50%; top:2px; left:2px; transition:all 0.3s; }
        .mini-toggle.on .mini-knob { left:18px; background:var(--rouge-light); }

        /* RIGHT PANEL - CAMERAS LIST */
        .cams-panel { width: 220px; flex-shrink:0; display:flex; flex-direction:column; gap:12px; }
        .cams-title { font-size:0.65rem; font-weight:700; color:var(--gris); letter-spacing:2px; text-transform:uppercase; padding: 4px 0 8px; }

        .cam-thumb {
            background: var(--card);
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: 10px; overflow:hidden;
            cursor:pointer; transition:all 0.2s;
        }
        .cam-thumb:hover { border-color:rgba(192,57,43,0.4); }
        .cam-thumb.selected { border-color:var(--rouge); box-shadow:0 0 10px rgba(192,57,43,0.2); }

        .thumb-preview {
            height: 100px; background:#000;
            position:relative;
            display:flex; align-items:center; justify-content:center;
        }
        .thumb-dot {
            position:absolute; top:8px; right:8px;
            width:8px; height:8px; border-radius:50%;
        }
        .thumb-dot.online  { background:#27ae60; box-shadow:0 0 5px rgba(39,174,96,0.7); }
        .thumb-dot.offline { background:#444; }

        .thumb-crosshair { opacity:0.2; }

        .thumb-info { padding:10px 12px; }
        .thumb-name { font-size:0.82rem; font-weight:700; color:#fff; margin-bottom:3px; }
        .thumb-meta { font-size:0.7rem; color:var(--gris); }
        .thumb-meta .online-text  { color:#27ae60; }
        .thumb-meta .offline-text { color:#555; }

        /* STATS MINI */
        .stats-mini { display:grid; grid-template-columns:repeat(3,1fr); gap:8px; }
        .stat-mini { background:var(--card); border:1px solid rgba(255,255,255,0.06); border-radius:8px; padding:10px 8px; text-align:center; }
        .stat-mini-val { font-size:1rem; font-weight:800; color:var(--rouge-light); }
        .stat-mini-lbl { font-size:0.6rem; color:var(--gris); text-transform:uppercase; margin-top:3px; letter-spacing:0.5px; }
    </style>
    <script>
(function(){
    try {
        const s = JSON.parse(localStorage.getItem('yuraSettings') || '{}');
        if (s.darkMode === false) {
            const st = document.createElement('style');
            st.id = '__yuraLight';
            st.textContent = `
                body { background: #f0f2f5 !important; color: #111 !important; }
                .sidebar { background: #fff !important; border-color: rgba(0,0,0,0.1) !important; }
                .top-bar { background: #0d0d0d !important; }
                .main-content, .content { background: #f0f2f5 !important; }
                .settings-card, .stat-card, .filter-bar, .table-wrap,
                .alert-card, .cam-card, .adv-panel, .map-card,
                .map-right, .cams-panel, .cam-thumbnail,
                .ctrl-card, .env-card, .hist-card, .status-row,
                .notifications-container, .alerts-group { background: #fff !important; border-color: rgba(0,0,0,0.08) !important; }
                .card-head, .alerts-group-title { border-color: rgba(0,0,0,0.06) !important; }
                .card-head-title, .setting-label, .alert-title,
                .date-day, .user-name-s, .logo-name,
                .info-val, h1, h2, h3 { color: #111 !important; }
                .logo-sub, .user-role-s, .topbar-title, .info-lbl,
                .alert-msg, .details-cell, .date-time,
                .stat-label, .gris { color: #666 !important; }
                .nav-item { color: #555 !important; }
                .nav-item:hover { background: rgba(0,0,0,0.04) !important; color: #111 !important; }
                .nav-item.active { color: var(--rouge) !important; background: rgba(192,57,43,0.07) !important; }
                .setting-select, .search-input, .filter-btn {
                    background: #f0f0f0 !important;
                    border-color: rgba(0,0,0,0.12) !important;
                    color: #111 !important;
                }
                .filter-btn { color: #555 !important; }
                .filter-btn.active { background: rgba(192,57,43,0.12) !important; color: var(--rouge) !important; }
                .toggle-slider { background: #ddd !important; border-color: #ccc !important; }
                .info-row, .setting-row, .history-row { border-color: rgba(0,0,0,0.05) !important; }
                .history-row:hover { background: #f5f5f5 !important; }
                .table-header { background: rgba(0,0,0,0.03) !important; }
                .table-header span { color: #666 !important; }
                .act-btn, .del-btn, .card-action-btn, .pag-btn,
                .bottom-btn.secondary, .cam-ctrl-btn, .dpad-btn {
                    background: rgba(0,0,0,0.05) !important;
                    border-color: rgba(0,0,0,0.1) !important;
                    color: #555 !important;
                }
                .topbar-user { background: rgba(192,57,43,0.07) !important; border-color: rgba(192,57,43,0.2) !important; }
                .robot-badge { background: rgba(192,57,43,0.07) !important; border-color: rgba(192,57,43,0.25) !important; }
                .pag-info { color: #666 !important; }
            `;
            document.head.appendChild(st);
        }
        if (s.colorTheme === 'blue-black') {
            document.documentElement.style.setProperty('--rouge', '#2563eb');
            document.documentElement.style.setProperty('--rouge-light', '#3b82f6');
            document.documentElement.style.setProperty('--border', 'rgba(37,99,235,0.18)');
        } else if (s.colorTheme === 'green-black') {
            document.documentElement.style.setProperty('--rouge', '#16a34a');
            document.documentElement.style.setProperty('--rouge-light', '#22c55e');
            document.documentElement.style.setProperty('--border', 'rgba(22,163,74,0.18)');
        }
        if (!s.animations) {
            const na = document.createElement('style');
            na.id = '__noAnim';
            na.textContent = '* { animation: none !important; transition: none !important; }';
            document.head.appendChild(na);
        }
    } catch(e) {}
})();
</script>
</head>
<body>

<!-- SIDEBAR -->
<aside class="sidebar">
   <div class="logo-section">
    <img src="/images/logo robot.png" alt="YURA" style="width:42px;height:42px;object-fit:contain;border-radius:8px;flex-shrink:0;">
    <div>
        <div class="logo-name">YURA</div>
        <div class="logo-sub">Guardian System</div>
    </div>
    </div>
    <div class="robot-badge">
        <div class="badge-dot"></div>
        <span>ROBOT EN LIGNE</span>
    </div>
    <div class="nav-section">
        <div class="nav-label">Contrôle</div>
        <a href="/dashboard/security" class="nav-item">
            <span class="nav-icon-wrap">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><rect x="1" y="1" width="6" height="6" rx="1"/><rect x="9" y="1" width="6" height="6" rx="1"/><rect x="1" y="9" width="6" height="6" rx="1"/><rect x="9" y="9" width="6" height="6" rx="1"/></svg>
            </span>
            <span class="nav-text">Dashboard</span>
        </a>
        <a href="/dashboard/camera" class="nav-item active">
            <span class="nav-icon-wrap">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M1 4a1 1 0 011-1h8a1 1 0 011 1v1.5l3-2v7l-3-2V12a1 1 0 01-1 1H2a1 1 0 01-1-1V4z"/></svg>
            </span>
            <span class="nav-text">Live Feed</span>
        </a>
        <a href="/dashboard/map" class="nav-item">
            <span class="nav-icon-wrap">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M6 1l4 2 4-2v11l-4 2-4-2-4 2V3l4-2zm0 1.5L2 4.5v9l4-2 4 2 4-2v-9l-4 2-4-2z"/></svg>
            </span>
            <span class="nav-text">Navigation</span>
        </a>
        <a href="/notifications" class="nav-item">
            <span class="nav-icon-wrap">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1a5 5 0 00-5 5v3l-1.5 2.5h13L13 9V6a5 5 0 00-5-5zm0 14a2 2 0 01-2-2h4a2 2 0 01-2 2z"/></svg>
            </span>
            <span class="nav-text">Alertes</span>
            <span class="nav-count">3</span>
        </a>
        <a href="/dashboard/history" class="nav-item">
                <span class="nav-icon-wrap"><svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1a7 7 0 100 14A7 7 0 008 1zm0 2v5l3 3-1 1-3.5-3.5V3H8z"/></svg></span>
                <span class="nav-text">Historique</span>
            </a>
        <a href="/dashboard/settings" class="nav-item">
            <span class="nav-icon-wrap">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M7.5 1l-.8 2.4a5 5 0 00-1.4.8L3 3.5l-1.5 2.6 1.9 1.5a5 5 0 000 1.8L1.5 11l1.5 2.6 2.3-.8a5 5 0 001.4.8L7.5 16h1l.8-2.4a5 5 0 001.4-.8l2.3.8L14.5 11l-1.9-1.5a5 5 0 000-1.8l1.9-1.5L13 3.5l-2.3.7a5 5 0 00-1.4-.8L8.5 1h-1zM8 6a2 2 0 110 4A2 2 0 018 6z"/></svg>
            </span>
            <span class="nav-text">Paramètres</span>
        </a>
    </div>
    <div class="sidebar-footer">
        <div class="user-row">
            <div class="user-av"><%= user.name.charAt(0).toUpperCase() %></div>
            <div>
                <div class="user-name-s"><%= user.name %></div>
                <div class="user-role-s">Agent Sécurité</div>
            </div>
        </div>
        <a href="/logout" class="nav-item" style="color:#555;">
            <span class="nav-icon-wrap">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M6 2H3a1 1 0 00-1 1v10a1 1 0 001 1h3v-1.5H3.5v-9H6V2zm4.5 3.5L13 8l-2.5 2.5-1-1L11 8H6V6.5h5l-1.5-1.5 1-1z"/></svg>
            </span>
            <span class="nav-text">Déconnexion</span>
        </a>
    </div>
</aside>

<!-- MAIN -->
<div class="main-content">
    <div class="top-bar">
        <span style="color:#888;margin-right:4px;">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="#888"><rect y="3" width="18" height="2"/><rect y="8" width="18" height="2"/><rect y="13" width="18" height="2"/></svg>
        </span>
        <span class="topbar-title">Système de Surveillance</span>
        <div class="topbar-right">
           <a href="/notifications" class="topbar-bell" style="text-decoration:none;">
                <svg width="18" height="18" viewBox="0 0 16 16" fill="#888"><path d="M8 1a5 5 0 00-5 5v3l-1.5 2.5h13L13 9V6a5 5 0 00-5-5zm0 14a2 2 0 01-2-2h4a2 2 0 01-2 2z"/></svg>
                <div class="bell-badge">3</div>
            </a>
            <a href="/dashboard/settings" class="topbar-user" style="text-decoration:none;">
                <div class="user-dot"></div>Opérateur
            </a>
        </div>
    </div>

    <div class="content">

        <!-- MAIN CAM AREA -->
        <div class="cam-main">

            <!-- CAMERA CARD -->
            <div class="cam-card">
                <div class="cam-header">
                    <div class="cam-title-row">
                        <span class="cam-icon">
                            <svg width="17" height="17" viewBox="0 0 17 17" fill="#c0392b"><path d="M1 5a1 1 0 011-1h9a1 1 0 011 1v1.5l3.5-2.5v9L12 11.5V13a1 1 0 01-1 1H2a1 1 0 01-1-1V5z"/></svg>
                        </span>
                        <span class="cam-name" id="camNameDisplay">CAM-01 Principale</span>
                        <div class="rec-badge" id="recBadge">
                            <div class="rec-dot"></div>
                            REC
                        </div>
                    </div>
                    <div class="cam-controls-top">
                        <!-- Zoom - -->
                        <button class="cam-ctrl-btn" onclick="zoomOut()" title="Zoom -">
                            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="6" cy="6" r="4"/><line x1="9.5" y1="9.5" x2="13" y2="13"/><line x1="4" y1="6" x2="8" y2="6"/></svg>
                        </button>
                        <!-- Zoom + -->
                        <button class="cam-ctrl-btn" onclick="zoomIn()" title="Zoom +">
                            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="6" cy="6" r="4"/><line x1="9.5" y1="9.5" x2="13" y2="13"/><line x1="4" y1="6" x2="8" y2="6"/><line x1="6" y1="4" x2="6" y2="8"/></svg>
                        </button>
                        <!-- Audio -->
                        <button class="cam-ctrl-btn" id="audioBtn" onclick="toggleAudio()" title="Audio">
                            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 5h2l3-3v10L4 9H2V5z"/><path d="M9 4.5a3 3 0 010 5"/></svg>
                        </button>
                        <!-- Fullscreen -->
                        <button class="cam-ctrl-btn" onclick="goFull()" title="Plein écran">
                            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 5V1h4M9 1h4v4M13 9v4h-4M5 13H1V9"/></svg>
                        </button>
                    </div>
                </div>

                <div class="cam-view" id="camView">
                    <div class="cam-corners">
                        <div class="corner corner-tl"></div>
                        <div class="corner corner-tr"></div>
                        <div class="corner corner-bl"></div>
                        <div class="corner corner-br"></div>
                    </div>
                    <div class="cam-crosshair">
                        <svg class="thumb-crosshair" width="100" height="100" viewBox="0 0 100 100" style="opacity:0.4;">
                            <circle cx="50" cy="50" r="35" fill="none" stroke="#c0392b" stroke-width="1.5" stroke-dasharray="6,5"/>
                            <circle cx="50" cy="50" r="18" fill="none" stroke="#c0392b" stroke-width="1.2"/>
                            <line x1="50" y1="0" x2="50" y2="32" stroke="#c0392b" stroke-width="1.3"/>
                            <line x1="50" y1="68" x2="50" y2="100" stroke="#c0392b" stroke-width="1.3"/>
                            <line x1="0" y1="50" x2="32" y2="50" stroke="#c0392b" stroke-width="1.3"/>
                            <line x1="68" y1="50" x2="100" y2="50" stroke="#c0392b" stroke-width="1.3"/>
                            <circle cx="50" cy="50" r="3" fill="#c0392b"/>
                        </svg>
                    </div>
                    <div class="cam-no-signal" id="camNoSignal">
                        <div class="cam-no-signal-icon">📹</div>
                        <p>En attente du signal...</p>
                    </div>
                    <video id="camVideo" autoplay playsinline muted></video>
                    <canvas id="snapCanvas" style="display:none;"></canvas>
                    <div class="cam-overlay-bottom">
                        <div class="cam-overlay-line" id="camDate">--/--/---- | --:--:--</div>
                        <div class="cam-overlay-line" id="camRes">RES: -- | FPS: --</div>
                    </div>
                </div>

                <div class="cam-footer">
                    <button class="cam-btn active" id="btnStart" onclick="startCam()">
                        <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor"><polygon points="2,1 11,6 2,11"/></svg>
                        Commencer
                    </button>
                    <button class="cam-btn" id="btnStop" onclick="stopCam()" disabled>
                        <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor"><rect x="2" y="2" width="8" height="8" rx="1"/></svg>
                        Arrêter
                    </button>
                    <button class="cam-btn" id="btnSnap" onclick="takeSnap()" disabled>
                        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="10" height="8" rx="1"/><circle cx="6" cy="7" r="2"/><path d="M4 3l1-2h2l1 2"/></svg>
                        Capture
                    </button>
                    <button class="cam-btn" id="btnNight" onclick="toggleNight()">
                        <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor"><path d="M10 7a5 5 0 01-5-5 5 5 0 00-1 9.9A5 5 0 0010 7z"/></svg>
                        Nuit
                    </button>
                    <button class="cam-btn" id="btnRecord" onclick="toggleRecord()" disabled>
                        <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor"><circle cx="6" cy="6" r="4"/></svg>
                        Enregistrer
                    </button>
                </div>
            </div>

            <!-- ADVANCED STATS -->
            <div class="adv-panel">
                <div class="adv-card">
                    <div class="adv-label">Luminosité</div>
                    <input type="range" min="0" max="200" value="100" id="brightness"
                        style="width:100%;accent-color:var(--rouge);height:3px;margin-bottom:6px;"
                        oninput="updateFilters()">
                    <div class="adv-val" id="brightnessVal">100%</div>
                </div>
                <div class="adv-card">
                    <div class="adv-label">Contraste</div>
                    <input type="range" min="0" max="200" value="100" id="contrast"
                        style="width:100%;accent-color:var(--rouge);height:3px;margin-bottom:6px;"
                        oninput="updateFilters()">
                    <div class="adv-val" id="contrastVal">100%</div>
                </div>
                <div class="adv-card">
                    <div class="adv-label">Modes</div>
                    <div class="toggle-row">
                        <span class="toggle-label">Vision nuit</span>
                        <div class="mini-toggle" id="nightToggle" onclick="toggleNightMode(this)"><div class="mini-knob"></div></div>
                    </div>
                    <div class="toggle-row">
                        <span class="toggle-label">Grille</span>
                        <div class="mini-toggle" id="gridToggle" onclick="toggleGrid(this)"><div class="mini-knob"></div></div>
                    </div>
                </div>
                <div class="adv-card">
                    <div class="adv-label">Stats</div>
                    <div class="stats-mini">
                        <div class="stat-mini"><div class="stat-mini-val" id="statDur">00:00</div><div class="stat-mini-lbl">Durée</div></div>
                        <div class="stat-mini"><div class="stat-mini-val" id="statSnap">0</div><div class="stat-mini-lbl">Captures</div></div>
                        <div class="stat-mini"><div class="stat-mini-val" id="statFps">0</div><div class="stat-mini-lbl">FPS</div></div>
                    </div>
                </div>
            </div>

        </div>

        <!-- RIGHT: CAMERAS LIST -->
        <div class="cams-panel">
            <div class="cams-title">Caméras Disponibles</div>

            <% const cameras = [
                {id:'CAM-01', name:'CAM-01 Principale', res:'1080p', online:true},
                {id:'CAM-02', name:'CAM-02 Thermique',  res:'720p',  online:true},
                {id:'CAM-03', name:'CAM-03 Arrière',    res:'1080p', online:true},
                {id:'CAM-04', name:'CAM-04 Night Vision',res:'720p', online:false},
            ]; %>

            <% cameras.forEach(function(cam, i){ %>
                <div class="cam-thumb <%= i===0 ? 'selected' : '' %>" onclick="selectCam('<%= cam.id %>', '<%= cam.name %>', this)">
                    <div class="thumb-preview">
                        <div class="thumb-dot <%= cam.online ? 'online' : 'offline' %>"></div>
                        <svg width="50" height="50" viewBox="0 0 100 100" style="opacity:0.15;">
                            <circle cx="50" cy="50" r="32" fill="none" stroke="#c0392b" stroke-width="2" stroke-dasharray="6,5"/>
                            <circle cx="50" cy="50" r="16" fill="none" stroke="#c0392b" stroke-width="1.5"/>
                            <line x1="50" y1="18" x2="50" y2="34" stroke="#c0392b" stroke-width="1.5"/>
                            <line x1="50" y1="66" x2="50" y2="82" stroke="#c0392b" stroke-width="1.5"/>
                            <line x1="18" y1="50" x2="34" y2="50" stroke="#c0392b" stroke-width="1.5"/>
                            <line x1="66" y1="50" x2="82" y2="50" stroke="#c0392b" stroke-width="1.5"/>
                            <circle cx="50" cy="50" r="3" fill="#c0392b"/>
                        </svg>
                    </div>
                    <div class="thumb-info">
                        <div class="thumb-name"><%= cam.name %></div>
                        <div class="thumb-meta">
                            <%= cam.res %> |
                            <span class="<%= cam.online ? 'online-text' : 'offline-text' %>">
                                <%= cam.online ? 'En ligne' : 'Hors ligne' %>
                            </span>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>

    </div>
</div>

<script>
    let camStream = null, durSecs = 0, durInterval = null;
    let snapCount = 0, isRecording = false, recInterval = null, recSecs = 0;
    let nightMode = false, gridMode = false;
    const filters = {brightness:100, contrast:100};

    // DATE/TIME
    function updateOverlay() {
        const now = new Date();
        const date = now.toLocaleDateString('fr-FR').replace(/\//g, '/');
        const time = now.toLocaleTimeString('fr-FR');
        document.getElementById('camDate').textContent = date + ' | ' + time;
        if(camStream) document.getElementById('camRes').textContent = 'RES: 1080p | FPS: 30';
    }
    updateOverlay(); setInterval(updateOverlay, 1000);

    // CAMERA
    async function startCam() {
        try {
            camStream = await navigator.mediaDevices.getUserMedia({video:true,audio:false});
            const v = document.getElementById('camVideo');
            v.srcObject = camStream; v.style.display = 'block';
            document.getElementById('camNoSignal').style.display = 'none';
            document.getElementById('btnStart').disabled = true;
            document.getElementById('btnStart').classList.remove('active');
            document.getElementById('btnStop').disabled  = false;
            document.getElementById('btnSnap').disabled  = false;
            document.getElementById('btnRecord').disabled = false;
            document.getElementById('statFps').textContent = '30';
            durSecs = 0;
            durInterval = setInterval(()=>{
                durSecs++;
                const m=Math.floor(durSecs/60), s=durSecs%60;
                document.getElementById('statDur').textContent = String(m).padStart(2,'0')+':'+String(s).padStart(2,'0');
            }, 1000);
        } catch(e) { alert('Caméra indisponible: '+e.message); }
    }

    function stopCam() {
        if(camStream){ camStream.getTracks().forEach(t=>t.stop()); camStream=null; }
        clearInterval(durInterval); clearInterval(recInterval);
        document.getElementById('camVideo').style.display = 'none';
        document.getElementById('camNoSignal').style.display = 'flex';
        document.getElementById('btnStart').disabled = false;
        document.getElementById('btnStart').classList.add('active');
        document.getElementById('btnStop').disabled   = true;
        document.getElementById('btnSnap').disabled   = true;
        document.getElementById('btnRecord').disabled = true;
        document.getElementById('statFps').textContent = '0';
        document.getElementById('statDur').textContent = '00:00';
        if(isRecording) { isRecording=false; document.getElementById('btnRecord').classList.remove('active'); }
    }

    function takeSnap() {
        const v = document.getElementById('camVideo');
        if(!camStream) return;
        const c = document.getElementById('snapCanvas');
        c.width=v.videoWidth; c.height=v.videoHeight;
        c.getContext('2d').drawImage(v,0,0);
        const a = document.createElement('a');
        a.download='yura-snap-'+Date.now()+'.png';
        a.href=c.toDataURL(); a.click();
        snapCount++;
        document.getElementById('statSnap').textContent = snapCount;
    }

    function toggleRecord() {
        const btn = document.getElementById('btnRecord');
        if(!isRecording) {
            isRecording = true;
            btn.classList.add('active');
            btn.innerHTML = '<svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor"><rect x="2" y="2" width="8" height="8" rx="1"/></svg> Stop REC';
        } else {
            isRecording = false;
            btn.classList.remove('active');
            btn.innerHTML = '<svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor"><circle cx="6" cy="6" r="4"/></svg> Enregistrer';
        }
    }

    function goFull() {
        const v = document.getElementById('camVideo');
        if(v.requestFullscreen) v.requestFullscreen();
        else if(v.webkitRequestFullscreen) v.webkitRequestFullscreen();
    }

    function zoomIn()  { const v=document.getElementById('camVideo'); const cur=parseFloat(v.style.transform?.match(/scale\((.+)\)/)?.[1]||1); v.style.transform=`scale(${Math.min(cur+0.2,3)})`; }
    function zoomOut() { const v=document.getElementById('camVideo'); const cur=parseFloat(v.style.transform?.match(/scale\((.+)\)/)?.[1]||1); v.style.transform=`scale(${Math.max(cur-0.2,0.5)})`; }

    function toggleAudio() {
        const btn = document.getElementById('audioBtn');
        btn.classList.toggle('active');
    }

    function updateFilters() {
        filters.brightness = document.getElementById('brightness').value;
        filters.contrast   = document.getElementById('contrast').value;
        document.getElementById('brightnessVal').textContent = filters.brightness+'%';
        document.getElementById('contrastVal').textContent   = filters.contrast+'%';
        applyFilters();
    }

    function applyFilters() {
        const v = document.getElementById('camVideo');
        let f = `brightness(${filters.brightness}%) contrast(${filters.contrast}%)`;
        if(nightMode) f += ' grayscale(80%) hue-rotate(90deg) brightness(150%)';
        v.style.filter = f;
    }

    function toggleNight() {
        const toggle = document.getElementById('nightToggle');
        toggle.classList.toggle('on');
        nightMode = toggle.classList.contains('on');
        applyFilters();
    }

    function toggleNightMode(el) {
        el.classList.toggle('on');
        nightMode = el.classList.contains('on');
        document.getElementById('btnNight').classList.toggle('active', nightMode);
        applyFilters();
    }

    function toggleGrid(el) {
        el.classList.toggle('on');
        gridMode = el.classList.contains('on');
        document.getElementById('camView').style.backgroundImage = gridMode
            ? 'linear-gradient(rgba(192,57,43,0.08) 1px, transparent 1px), linear-gradient(90deg, rgba(192,57,43,0.08) 1px, transparent 1px)'
            : 'none';
        document.getElementById('camView').style.backgroundSize = gridMode ? '33.3% 33.3%' : '';
    }

    // SELECT CAMERA
    function selectCam(id, name, el) {
        document.querySelectorAll('.cam-thumb').forEach(t=>t.classList.remove('selected'));
        el.classList.add('selected');
        document.getElementById('camNameDisplay').textContent = name;
        if(camStream) stopCam();
    }
</script>
</body>
</html>