<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
    
    <script src="/js/theme.js"></script>
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        :root {
            --rouge: #c0392b;
            --rouge-light: #e74c3c;
            --noir: #0a0a0a;
            --card: #111111;
            --card2: #161616;
            --border: rgba(192,57,43,0.18);
            --gris: #888;
            --gris2: #bbb;
        }
        body { font-family: 'Segoe UI', sans-serif; background: var(--noir); color: #fff; display: flex; min-height: 100vh; }

        /* SIDEBAR */
        .sidebar {
            width: 300px; min-height: 100vh;
            background: #0d0d0d;
            border-right: 1px solid var(--border);
            display: flex; flex-direction: column;
            position: fixed; top:0; left:0; bottom:0; z-index:100;
        }
        .logo-section {
            padding: 20px 18px;
            border-bottom: 1px solid var(--border);
            display: flex; align-items: center; gap: 14px;
        }
        .logo-icon {
            width: 48px; height: 48px;
            background: var(--rouge);
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.4rem;
            box-shadow: 0 0 15px rgba(192,57,43,0.4);
            flex-shrink: 0;
        }
        .logo-name { font-size: 1.1rem; font-weight: 800; color: #fff; letter-spacing: 2px; }
        .logo-sub  { font-size: 0.65rem; color: var(--gris); letter-spacing: 2px; text-transform: uppercase; }

        .robot-badge {
            margin: 16px 16px 6px;
            padding: 11px 18px;
            background: rgba(192,57,43,0.15);
            border: 1px solid rgba(192,57,43,0.5);
            border-radius: 8px;
            display: flex; align-items: center; gap: 10px;
            font-size: 0.78rem; font-weight: 700;
            color: var(--rouge-light); letter-spacing: 1px;
        }
        .badge-dot {
            width: 9px; height: 9px;
            background: var(--rouge-light); border-radius: 50%;
            animation: blink 1.2s infinite;
            box-shadow: 0 0 6px rgba(231,76,60,0.8);
        }
        @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.15} }

        .nav-section { padding: 10px 0; flex:1; }
        .nav-label { font-size: 0.62rem; font-weight: 700; color: var(--gris); letter-spacing: 2px; padding: 14px 18px 6px; text-transform: uppercase; }
        .nav-item {
            display: flex; align-items: center; gap: 14px;
            padding: 12px 18px; color: #777; text-decoration: none;
            font-size: 0.9rem; font-weight: 500;
            border-left: 2px solid transparent;
            transition: all 0.18s;
        }
        .nav-item:hover { color: #fff; background: rgba(192,57,43,0.07); }
        .nav-item.active { color: #fff; background: rgba(192,57,43,0.13); border-left-color: var(--rouge); font-weight: 600; }
        .nav-icon-wrap { width: 22px; height: 22px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
        .nav-text { flex: 1; }
        .nav-count { background: var(--rouge); color: #fff; font-size: 0.65rem; font-weight: 700; padding: 3px 8px; border-radius: 12px; }

        .sidebar-footer { border-top: 1px solid var(--border); padding: 10px 0; }
        .user-row { display: flex; align-items: center; gap: 11px; padding: 12px 18px; }
        .user-av { width: 36px; height: 36px; background: linear-gradient(135deg, var(--rouge), #7b241c); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.9rem; font-weight: 700; flex-shrink: 0; }
        .user-name-s { font-size: 0.85rem; font-weight: 600; }
        .user-role-s { font-size: 0.68rem; color: var(--gris); }

        /* MAIN */
        .main-content { margin-left: 300px; flex: 1; display: flex; flex-direction: column; min-height: 100vh; }

        .top-bar {
            height: 52px; background: #0d0d0d;
            border-bottom: 1px solid var(--border);
            display: flex; align-items: center;
            padding: 0 24px; gap: 14px;
            position: sticky; top:0; z-index:50;
        }
        .topbar-title { font-size: 0.8rem; color: var(--gris); letter-spacing: 1.5px; text-transform: uppercase; flex:1; }
        .topbar-right { display: flex; align-items: center; gap: 10px; }
        .topbar-bell { position: relative; cursor: pointer; color: var(--gris); }
        .bell-badge { position: absolute; top:-4px; right:-4px; width:16px; height:16px; background: var(--rouge); border-radius: 50%; font-size: 0.6rem; color:#fff; font-weight:700; display: flex; align-items:center; justify-content:center; }
        .topbar-user { display: flex; align-items: center; gap: 7px; background: rgba(192,57,43,0.12); border: 1px solid rgba(192,57,43,0.35); padding: 5px 14px; border-radius: 20px; font-size: 0.78rem; font-weight: 600; color: var(--rouge-light); }
        .user-dot { width:7px; height:7px; background:var(--rouge-light); border-radius:50%; }

        /* TOP ACTION BUTTONS */
        .top-action-btn {
            display: flex; align-items: center; gap: 6px;
            padding: 6px 14px;
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 7px;
            color: #999; font-size: 0.78rem; font-weight: 600;
            cursor: pointer; transition: all 0.18s;
        }
        .top-action-btn:hover { background: rgba(192,57,43,0.15); border-color: rgba(192,57,43,0.4); color: #fff; }
        .top-action-btn.active { background: rgba(192,57,43,0.2); border-color: rgba(192,57,43,0.6); color: var(--rouge-light); }

        /* CONTENT */
        .content { padding: 20px 24px; flex:1; display: flex; flex-direction: column; gap: 16px; height: calc(100vh - 52px); }

        /* STAT ROW */
        .map-stat-row { display: grid; grid-template-columns: repeat(4,1fr); gap: 12px; flex-shrink: 0; }
        .map-stat {
            background: var(--card); border: 1px solid rgba(255,255,255,0.06);
            border-radius: 10px; padding: 14px 16px;
            display: flex; align-items: center; gap: 12px;
        }
        .map-stat-icon {
            width: 38px; height: 38px;
            background: rgba(192,57,43,0.15);
            border: 1px solid rgba(192,57,43,0.3);
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
        }
        .map-stat-label { font-size: 0.62rem; color: var(--gris); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 3px; }
        .map-stat-val   { font-size: 0.95rem; font-weight: 700; color: #fff; }

        /* MAIN GRID */
        .map-grid { display: grid; grid-template-columns: 1fr 280px; gap: 14px; flex:1; min-height: 0; }

        /* MAP CARD */
        .map-card {
            background: var(--card); border: 1px solid rgba(255,255,255,0.06);
            border-radius: 12px; overflow: hidden;
            display: flex; flex-direction: column;
        }
        .map-card-header {
            display: flex; align-items: center; justify-content: space-between;
            padding: 12px 16px; border-bottom: 1px solid rgba(255,255,255,0.05);
            flex-shrink: 0;
        }
        .map-card-title { display: flex; align-items: center; gap: 8px; font-size: 0.85rem; font-weight: 700; color: var(--gris2); text-transform: uppercase; letter-spacing: 0.5px; }
        .map-card-title-icon { color: var(--rouge); }
        .map-zoom-btns { display: flex; gap: 6px; }
        .map-zoom-btn {
            width: 30px; height: 30px;
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 6px; cursor: pointer;
            color: #888; font-size: 0.9rem; font-weight: 700;
            display: flex; align-items: center; justify-content: center;
            transition: all 0.18s;
        }
        .map-zoom-btn:hover { background: rgba(192,57,43,0.15); border-color: rgba(192,57,43,0.4); color: #fff; }

        #map { flex:1; min-height: 0; }

        /* Leaflet dark override */
        .leaflet-tile { filter: brightness(0.6) contrast(1.1) saturate(0.8) hue-rotate(180deg); }
        .leaflet-container { background: #0a0a0a; }
        .leaflet-popup-content-wrapper { background: #1a1a1a; border: 1px solid rgba(192,57,43,0.3); color: #fff; border-radius: 8px; }
        .leaflet-popup-tip { background: #1a1a1a; }
        .leaflet-popup-content { font-size: 0.82rem; line-height: 1.5; }
        .leaflet-control-zoom a { background: #111 !important; color: #888 !important; border-color: rgba(255,255,255,0.08) !important; }
        .leaflet-control-zoom a:hover { background: rgba(192,57,43,0.2) !important; color: #fff !important; }
        .leaflet-control-attribution { background: rgba(0,0,0,0.5) !important; color: #555 !important; font-size: 0.6rem !important; }

        /* LEGEND */
        .map-legend-overlay {
            position: absolute; bottom: 16px; left: 16px;
            background: rgba(17,17,17,0.92);
            border: 1px solid rgba(192,57,43,0.2);
            border-radius: 8px; padding: 12px 14px;
            z-index: 400; backdrop-filter: blur(10px);
        }
        .legend-title { font-size: 0.62rem; color: var(--gris); text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 8px; }
        .legend-row { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; font-size: 0.78rem; color: var(--gris2); }
        .legend-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
        .legend-dot.rouge   { background: var(--rouge-light); box-shadow: 0 0 5px rgba(231,76,60,0.6); }
        .legend-dot.vert    { background: #27ae60; box-shadow: 0 0 5px rgba(39,174,96,0.5); }
        .legend-dot.bleu    { background: #3b82f6; box-shadow: 0 0 5px rgba(59,130,246,0.5); }
        .legend-dot.orange  { background: #f39c12; box-shadow: 0 0 5px rgba(243,156,18,0.5); }

        /* RIGHT PANEL */
        .map-right { display: flex; flex-direction: column; gap: 12px; overflow-y: auto; }

        /* INFO CARD */
        .info-card {
            background: var(--card); border: 1px solid rgba(255,255,255,0.06);
            border-radius: 10px; overflow: hidden;
        }
        .info-card-header {
            padding: 11px 14px; border-bottom: 1px solid rgba(255,255,255,0.05);
            font-size: 0.78rem; font-weight: 700; color: var(--gris2);
            text-transform: uppercase; letter-spacing: 0.5px;
            display: flex; align-items: center; gap: 7px;
        }
        .info-card-icon { color: var(--rouge); }
        .info-card-body { padding: 12px 14px; }

        .pos-row { display: flex; justify-content: space-between; align-items: center; padding: 7px 0; border-bottom: 1px solid rgba(255,255,255,0.04); }
        .pos-row:last-child { border-bottom: none; }
        .pos-label { font-size: 0.68rem; color: var(--gris); text-transform: uppercase; letter-spacing: 0.5px; }
        .pos-val   { font-size: 0.82rem; font-weight: 700; color: #fff; font-family: monospace; }
        .pos-val.green  { color: #27ae60; }
        .pos-val.rouge  { color: var(--rouge-light); }
        .pos-val.orange { color: #f39c12; }

        /* ACTION LOG */
        .log-list { max-height: 180px; overflow-y: auto; }
        .log-item { display: flex; align-items: flex-start; gap: 8px; padding: 7px 0; border-bottom: 1px solid rgba(255,255,255,0.03); }
        .log-item:last-child { border-bottom: none; }
        .log-time { font-size: 0.65rem; color: var(--gris); font-family: monospace; white-space: nowrap; flex-shrink: 0; margin-top: 1px; }
        .log-dot  { width: 6px; height: 6px; border-radius: 50%; background: var(--rouge); flex-shrink: 0; margin-top: 4px; }
        .log-text { font-size: 0.75rem; color: var(--gris2); line-height: 1.3; }

        /* ZONE CARD */
        .zone-item {
            display: flex; align-items: center; gap: 10px;
            padding: 8px 0; border-bottom: 1px solid rgba(255,255,255,0.04);
        }
        .zone-item:last-child { border-bottom: none; }
        .zone-dot { width: 10px; height: 10px; border-radius: 2px; flex-shrink: 0; }
        .zone-name  { font-size: 0.8rem; color: var(--gris2); flex:1; }
        .zone-badge { font-size: 0.62rem; padding: 2px 7px; border-radius: 10px; font-weight: 700; }
        .zone-badge.active   { background: rgba(192,57,43,0.2); color: var(--rouge-light); }
        .zone-badge.inactive { background: rgba(255,255,255,0.05); color: var(--gris); }
        .zone-badge.patrol   { background: rgba(39,174,96,0.2); color: #27ae60; }

        /* CONTROL BTNS */
        .ctrl-btns { display: flex; flex-direction: column; gap: 7px; }
        .ctrl-action-btn {
            display: flex; align-items: center; gap: 8px;
            padding: 9px 14px;
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 8px; cursor: pointer;
            color: #999; font-size: 0.8rem; font-weight: 600;
            transition: all 0.18s; text-align: left;
        }
        .ctrl-action-btn:hover { background: rgba(192,57,43,0.12); border-color: rgba(192,57,43,0.35); color: #fff; }
        .ctrl-action-btn.primary { background: rgba(192,57,43,0.15); border-color: rgba(192,57,43,0.4); color: var(--rouge-light); }
        .ctrl-action-btn.primary:hover { background: rgba(192,57,43,0.3); }
        .ctrl-action-btn svg { flex-shrink: 0; }
    </style>
    <script>
(function(){
    try {
        const s = JSON.parse(localStorage.getItem('yuraSettings') || '{}');
        if (s.darkMode === false) {
            const st = document.createElement('style');
            st.id = '__yuraLight';
            st.textContent = `
                body { background: #f0f2f5 !important; color: #111 !important; }
                .sidebar { background: #fff !important; border-color: rgba(0,0,0,0.1) !important; }
                .top-bar { background: #0d0d0d !important; }
                .main-content, .content { background: #f0f2f5 !important; }
                .settings-card, .stat-card, .filter-bar, .table-wrap,
                .alert-card, .cam-card, .adv-panel, .map-card,
                .map-right, .cams-panel, .cam-thumbnail,
                .ctrl-card, .env-card, .hist-card, .status-row,
                .notifications-container, .alerts-group { background: #fff !important; border-color: rgba(0,0,0,0.08) !important; }
                .card-head, .alerts-group-title { border-color: rgba(0,0,0,0.06) !important; }
                .card-head-title, .setting-label, .alert-title,
                .date-day, .user-name-s, .logo-name,
                .info-val, h1, h2, h3 { color: #111 !important; }
                .logo-sub, .user-role-s, .topbar-title, .info-lbl,
                .alert-msg, .details-cell, .date-time,
                .stat-label, .gris { color: #666 !important; }
                .nav-item { color: #555 !important; }
                .nav-item:hover { background: rgba(0,0,0,0.04) !important; color: #111 !important; }
                .nav-item.active { color: var(--rouge) !important; background: rgba(192,57,43,0.07) !important; }
                .setting-select, .search-input, .filter-btn {
                    background: #f0f0f0 !important;
                    border-color: rgba(0,0,0,0.12) !important;
                    color: #111 !important;
                }
                .filter-btn { color: #555 !important; }
                .filter-btn.active { background: rgba(192,57,43,0.12) !important; color: var(--rouge) !important; }
                .toggle-slider { background: #ddd !important; border-color: #ccc !important; }
                .info-row, .setting-row, .history-row { border-color: rgba(0,0,0,0.05) !important; }
                .history-row:hover { background: #f5f5f5 !important; }
                .table-header { background: rgba(0,0,0,0.03) !important; }
                .table-header span { color: #666 !important; }
                .act-btn, .del-btn, .card-action-btn, .pag-btn,
                .bottom-btn.secondary, .cam-ctrl-btn, .dpad-btn {
                    background: rgba(0,0,0,0.05) !important;
                    border-color: rgba(0,0,0,0.1) !important;
                    color: #555 !important;
                }
                .topbar-user { background: rgba(192,57,43,0.07) !important; border-color: rgba(192,57,43,0.2) !important; }
                .robot-badge { background: rgba(192,57,43,0.07) !important; border-color: rgba(192,57,43,0.25) !important; }
                .pag-info { color: #666 !important; }
            `;
            document.head.appendChild(st);
        }
        if (s.colorTheme === 'blue-black') {
            document.documentElement.style.setProperty('--rouge', '#2563eb');
            document.documentElement.style.setProperty('--rouge-light', '#3b82f6');
            document.documentElement.style.setProperty('--border', 'rgba(37,99,235,0.18)');
        } else if (s.colorTheme === 'green-black') {
            document.documentElement.style.setProperty('--rouge', '#16a34a');
            document.documentElement.style.setProperty('--rouge-light', '#22c55e');
            document.documentElement.style.setProperty('--border', 'rgba(22,163,74,0.18)');
        }
        if (!s.animations) {
            const na = document.createElement('style');
            na.id = '__noAnim';
            na.textContent = '* { animation: none !important; transition: none !important; }';
            document.head.appendChild(na);
        }
    } catch(e) {}
})();
</script>
</head>
<body>

<!-- SIDEBAR -->
<aside class="sidebar">
    <div class="logo-section">
    <img src="/images/logo robot.png" alt="YURA" style="width:42px;height:42px;object-fit:contain;border-radius:8px;flex-shrink:0;">
    <div>
        <div class="logo-name">YURA</div>
        <div class="logo-sub">Guardian System</div>
    </div>
   </div>
    <div class="robot-badge">
        <div class="badge-dot"></div>
        <span>ROBOT EN LIGNE</span>
    </div>
    <div class="nav-section">
        <div class="nav-label">Contrôle</div>
        <a href="/dashboard/security" class="nav-item">
            <span class="nav-icon-wrap">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><rect x="1" y="1" width="6" height="6" rx="1"/><rect x="9" y="1" width="6" height="6" rx="1"/><rect x="1" y="9" width="6" height="6" rx="1"/><rect x="9" y="9" width="6" height="6" rx="1"/></svg>
            </span>
            <span class="nav-text">Dashboard</span>
        </a>
        <a href="/dashboard/camera" class="nav-item">
            <span class="nav-icon-wrap">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M1 4a1 1 0 011-1h8a1 1 0 011 1v1.5l3-2v7l-3-2V12a1 1 0 01-1 1H2a1 1 0 01-1-1V4z"/></svg>
            </span>
            <span class="nav-text">Live Feed</span>
        </a>
        <a href="/dashboard/map" class="nav-item active">
            <span class="nav-icon-wrap">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M6 1l4 2 4-2v11l-4 2-4-2-4 2V3l4-2zm0 1.5L2 4.5v9l4-2 4 2 4-2v-9l-4 2-4-2z"/></svg>
            </span>
            <span class="nav-text">Navigation</span>
        </a>
        <a href="/notifications" class="nav-item">
            <span class="nav-icon-wrap">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1a5 5 0 00-5 5v3l-1.5 2.5h13L13 9V6a5 5 0 00-5-5zm0 14a2 2 0 01-2-2h4a2 2 0 01-2 2z"/></svg>
            </span>
            <span class="nav-text">Alertes</span>
            <span class="nav-count">3</span>
        </a>
        <a href="/dashboard/history" class="nav-item">
        <span class="nav-icon-wrap"><svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1a7 7 0 100 14A7 7 0 008 1zm0 2v5l3 3-1 1-3.5-3.5V3H8z"/></svg></span>
        <span class="nav-text">Historique</span>
    </a>
        <a href="/dashboard/settings" class="nav-item">
            <span class="nav-icon-wrap">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M7.5 1l-.8 2.4a5 5 0 00-1.4.8L3 3.5l-1.5 2.6 1.9 1.5a5 5 0 000 1.8L1.5 11l1.5 2.6 2.3-.8a5 5 0 001.4.8L7.5 16h1l.8-2.4a5 5 0 001.4-.8l2.3.8L14.5 11l-1.9-1.5a5 5 0 000-1.8l1.9-1.5L13 3.5l-2.3.7a5 5 0 00-1.4-.8L8.5 1h-1zM8 6a2 2 0 110 4A2 2 0 018 6z"/></svg>
            </span>
            <span class="nav-text">Paramètres</span>
        </a>
    </div>
    <div class="sidebar-footer">
        <div class="user-row">
            <div class="user-av"><%= user.name.charAt(0).toUpperCase() %></div>
            <div>
                <div class="user-name-s"><%= user.name %></div>
                <div class="user-role-s">Agent Sécurité</div>
            </div>
        </div>
        <a href="/logout" class="nav-item" style="color:#555;">
            <span class="nav-icon-wrap">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M6 2H3a1 1 0 00-1 1v10a1 1 0 001 1h3v-1.5H3.5v-9H6V2zm4.5 3.5L13 8l-2.5 2.5-1-1L11 8H6V6.5h5l-1.5-1.5 1-1z"/></svg>
            </span>
            <span class="nav-text">Déconnexion</span>
        </a>
    </div>
</aside>

<!-- MAIN -->
<div class="main-content">
    <div class="top-bar">
        <span style="color:#888;margin-right:4px;">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="#888"><rect y="3" width="18" height="2"/><rect y="8" width="18" height="2"/><rect y="13" width="18" height="2"/></svg>
        </span>
        <span class="topbar-title">Navigation — Position Robot</span>
        <div class="topbar-right">
            <button class="top-action-btn" onclick="centerOnRobot()">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor"><circle cx="6" cy="6" r="2"/><path d="M6 0v2M6 10v2M0 6h2M10 6h2" stroke="currentColor" stroke-width="1.2"/></svg>
                Centrer
            </button>
            <button class="top-action-btn" id="trajBtn" onclick="toggleTrajectory()">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="1,9 4,5 7,7 11,2"/></svg>
                Trajectoire
            </button>
            <button class="top-action-btn" onclick="locateMe()">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor"><path d="M6 0a4 4 0 00-4 4c0 3 4 8 4 8s4-5 4-8a4 4 0 00-4-4zm0 5.5a1.5 1.5 0 110-3 1.5 1.5 0 010 3z"/></svg>
                Ma position
            </button>
            <button class="top-action-btn" onclick="resetMap()">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10 6A4 4 0 112 6M2 3v3H5"/></svg>
                Reset
            </button>
            <a href="/notifications" class="topbar-bell" style="text-decoration:none;">
                <svg width="18" height="18" viewBox="0 0 16 16" fill="#888"><path d="M8 1a5 5 0 00-5 5v3l-1.5 2.5h13L13 9V6a5 5 0 00-5-5zm0 14a2 2 0 01-2-2h4a2 2 0 01-2 2z"/></svg>
                <div class="bell-badge">3</div>
            </a>
           <a href="/dashboard/settings" class="topbar-user" style="text-decoration:none;">
                <div class="user-dot"></div>Opérateur
            </a>
        </div>
    </div>

    <div class="content">

        <!-- STAT ROW -->
        <div class="map-stat-row">
            <div class="map-stat">
                <div class="map-stat-icon">
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="#c0392b"><path d="M9 1a5 5 0 00-5 5c0 4.5 5 11 5 11s5-6.5 5-11a5 5 0 00-5-5zm0 7a2 2 0 110-4 2 2 0 010 4z"/></svg>
                </div>
                <div>
                    <div class="map-stat-label">Latitude</div>
                    <div class="map-stat-val" id="statLat">36.8065°</div>
                </div>
            </div>
            <div class="map-stat">
                <div class="map-stat-icon">
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="#c0392b"><path d="M9 1a5 5 0 00-5 5c0 4.5 5 11 5 11s5-6.5 5-11a5 5 0 00-5-5zm0 7a2 2 0 110-4 2 2 0 010 4z"/></svg>
                </div>
                <div>
                    <div class="map-stat-label">Longitude</div>
                    <div class="map-stat-val" id="statLng">10.1815°</div>
                </div>
            </div>
            <div class="map-stat">
                <div class="map-stat-icon">
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="#c0392b" stroke-width="1.5"><polyline points="2,13 6,8 10,10 16,4"/></svg>
                </div>
                <div>
                    <div class="map-stat-label">Vitesse</div>
                    <div class="map-stat-val" id="statSpeed">0.0 m/s</div>
                </div>
            </div>
            <div class="map-stat">
                <div class="map-stat-icon">
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="#c0392b" stroke-width="1.5"><circle cx="9" cy="9" r="7"/><polyline points="9,5 9,9 12,11"/></svg>
                </div>
                <div>
                    <div class="map-stat-label">Durée mission</div>
                    <div class="map-stat-val" id="statMission">00:00:00</div>
                </div>
            </div>
        </div>

        <!-- MAP GRID -->
        <div class="map-grid">

            <!-- MAP -->
            <div class="map-card" style="position:relative;">
                <div class="map-card-header">
                    <div class="map-card-title">
                        <span class="map-card-title-icon">
                            <svg width="14" height="14" viewBox="0 0 14 14" fill="#c0392b"><path d="M5 0l4 2 4-2v10l-4 2-4-2-4 2V2l4-2zm0 1.4L1 3.4v9l4-2 4 2 4-2v-9l-4 2-4-2z"/></svg>
                        </span>
                        Carte en temps réel
                    </div>
                    <div class="map-zoom-btns">
                        <button class="map-zoom-btn" onclick="map.zoomIn()">+</button>
                        <button class="map-zoom-btn" onclick="map.zoomOut()">−</button>
                    </div>
                </div>
                <div id="map"></div>
                <!-- LEGEND OVERLAY -->
                <div class="map-legend-overlay">
                    <div class="legend-title">Légende</div>
                    <div class="legend-row"><div class="legend-dot rouge"></div> Robot YURA</div>
                    <div class="legend-row"><div class="legend-dot vert"></div> Votre position</div>
                    <div class="legend-row"><div class="legend-dot orange"></div> Zone alerte</div>
                    <div class="legend-row"><div class="legend-dot bleu"></div> Trajectoire</div>
                </div>
            </div>

            <!-- RIGHT PANEL -->
            <div class="map-right">

                <!-- POSITION -->
                <div class="info-card">
                    <div class="info-card-header">
                        <span class="info-card-icon">📍</span>
                        Position Robot
                    </div>
                    <div class="info-card-body">
                        <div class="pos-row">
                            <span class="pos-label">Latitude</span>
                            <span class="pos-val" id="posLat">36.8065</span>
                        </div>
                        <div class="pos-row">
                            <span class="pos-label">Longitude</span>
                            <span class="pos-val" id="posLng">10.1815</span>
                        </div>
                        <div class="pos-row">
                            <span class="pos-label">Statut</span>
                            <span class="pos-val green">En patrouille</span>
                        </div>
                        <div class="pos-row">
                            <span class="pos-label">Direction</span>
                            <span class="pos-val orange" id="posDir">Nord-Est</span>
                        </div>
                        <div class="pos-row">
                            <span class="pos-label">Dernière MAJ</span>
                            <span class="pos-val" id="posTime">--:--:--</span>
                        </div>
                    </div>
                </div>

                <!-- ZONES -->
                <div class="info-card">
                    <div class="info-card-header">
                        <span class="info-card-icon">🔴</span>
                        Zones de Sécurité
                    </div>
                    <div class="info-card-body">
                        <div class="zone-item">
                            <div class="zone-dot" style="background:#e74c3c;"></div>
                            <span class="zone-name">Zone Entrée</span>
                            <span class="zone-badge active">Alerte</span>
                        </div>
                        <div class="zone-item">
                            <div class="zone-dot" style="background:#27ae60;"></div>
                            <span class="zone-name">Zone Patrouille A</span>
                            <span class="zone-badge patrol">Actif</span>
                        </div>
                        <div class="zone-item">
                            <div class="zone-dot" style="background:#3b82f6;"></div>
                            <span class="zone-name">Périmètre Nord</span>
                            <span class="zone-badge inactive">Inactif</span>
                        </div>
                        <div class="zone-item">
                            <div class="zone-dot" style="background:#f39c12;"></div>
                            <span class="zone-name">Zone Surveillance</span>
                            <span class="zone-badge patrol">Actif</span>
                        </div>
                    </div>
                </div>

                <!-- ACTIONS -->
                <div class="info-card">
                    <div class="info-card-header">
                        <span class="info-card-icon">⚡</span>
                        Actions Rapides
                    </div>
                    <div class="info-card-body">
                        <div class="ctrl-btns">
                            <button class="ctrl-action-btn primary" onclick="centerOnRobot()">
                                <svg width="13" height="13" viewBox="0 0 13 13" fill="currentColor"><circle cx="6.5" cy="6.5" r="2"/><path d="M6.5 0v2M6.5 11v2M0 6.5h2M11 6.5h2" stroke="currentColor" stroke-width="1.2"/></svg>
                                Centrer sur le robot
                            </button>
                            <button class="ctrl-action-btn" onclick="toggleTrajectory()">
                                <svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="1,10 4,6 7,8 12,2"/></svg>
                                Afficher trajectoire
                            </button>
                            <button class="ctrl-action-btn" onclick="locateMe()">
                                <svg width="13" height="13" viewBox="0 0 13 13" fill="currentColor"><path d="M6.5 0a4 4 0 00-4 4c0 3.5 4 9 4 9s4-5.5 4-9a4 4 0 00-4-4zm0 5.5a1.5 1.5 0 110-3 1.5 1.5 0 010 3z"/></svg>
                                Ma position GPS
                            </button>
                            <button class="ctrl-action-btn" onclick="resetMap()">
                                <svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M11 6.5A4.5 4.5 0 112 6.5M2 3v3.5H5.5"/></svg>
                                Réinitialiser carte
                            </button>
                        </div>
                    </div>
                </div>

                <!-- LOG -->
                <div class="info-card">
                    <div class="info-card-header">
                        <span class="info-card-icon">📋</span>
                        Journal
                    </div>
                    <div class="info-card-body" style="padding:8px 14px;">
                        <div class="log-list" id="logList"></div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
    const defaultLat = 36.8065, defaultLng = 10.1815;
    let map, robotMarker, userMarker, trajectoryLine;
    let showTraj = false, trajPoints = [[defaultLat, defaultLng]];
    let missionSecs = 0;
    const directions = ['Nord','Nord-Est','Est','Sud-Est','Sud','Sud-Ouest','Ouest','Nord-Ouest'];

    // MISSION TIMER
    setInterval(()=>{
        missionSecs++;
        const h=Math.floor(missionSecs/3600), m=Math.floor((missionSecs%3600)/60), s=missionSecs%60;
        document.getElementById('statMission').textContent =
            String(h).padStart(2,'0')+':'+String(m).padStart(2,'0')+':'+String(s).padStart(2,'0');
    }, 1000);

    // POS TIME
    function updatePosTime() {
        document.getElementById('posTime').textContent = new Date().toLocaleTimeString('fr-FR');
    }
    updatePosTime(); setInterval(updatePosTime, 1000);

    // LOG
    function addLog(text) {
        const list = document.getElementById('logList');
        const time = new Date().toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'});
        const div = document.createElement('div');
        div.className = 'log-item';
        div.innerHTML = `<span class="log-time">${time}</span><div class="log-dot"></div><span class="log-text">${text}</span>`;
        list.insertBefore(div, list.firstChild);
        if(list.children.length > 20) list.removeChild(list.lastChild);
    }

    // MAP INIT
    window.addEventListener('load', ()=>{
        map = L.map('map', {zoomControl: false}).setView([defaultLat, defaultLng], 14);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap', maxZoom: 19
        }).addTo(map);

        // Robot marker
        const robotIcon = L.divIcon({
            html: `<div style="
                width:32px;height:32px;
                background:rgba(192,57,43,0.9);
                border:2px solid #e74c3c;
                border-radius:50%;
                display:flex;align-items:center;justify-content:center;
                box-shadow:0 0 12px rgba(192,57,43,0.7);
                animation:pulse-robot 1.5s infinite;
            ">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="white">
                    <rect x="4" y="2" width="8" height="7" rx="1"/>
                    <rect x="3" y="9" width="10" height="5" rx="1"/>
                    <circle cx="6" cy="4" r="1"/><circle cx="10" cy="4" r="1"/>
                    <rect x="1" y="10" width="2" height="3" rx="1"/>
                    <rect x="13" y="10" width="2" height="3" rx="1"/>
                </svg>
            </div>`,
            iconSize: [32,32], iconAnchor: [16,16], className: ''
        });

        robotMarker = L.marker([defaultLat, defaultLng], {icon: robotIcon})
            .addTo(map)
            .bindPopup('<b style="color:#e74c3c;">Robot YURA</b><br><span style="color:#888;font-size:0.8rem;">En patrouille active</span>');

        // Alert zone
        L.circle([36.808, 10.180], {
            color: '#e74c3c', fillColor: '#c0392b',
            fillOpacity: 0.1, weight: 1.5, radius: 200
        }).addTo(map).bindPopup('<b style="color:#e74c3c;">Zone Alerte — Entrée</b>');

        // Patrol zone
        L.circle([36.805, 10.183], {
            color: '#27ae60', fillColor: '#27ae60',
            fillOpacity: 0.06, weight: 1, radius: 300, dashArray: '5,5'
        }).addTo(map).bindPopup('<b style="color:#27ae60;">Zone Patrouille A</b>');

        addLog('Carte initialisée');
        addLog('Robot YURA localisé');

        // Robot movement
        setInterval(()=>{
            const oLat = (Math.random()-0.5)*0.006;
            const oLng = (Math.random()-0.5)*0.006;
            const newPos = [
                parseFloat(robotMarker.getLatLng().lat) + oLat,
                parseFloat(robotMarker.getLatLng().lng) + oLng
            ];
            robotMarker.setLatLng(newPos);
            trajPoints.push(newPos);
            if(trajectoryLine) trajectoryLine.setLatLngs(trajPoints);

            // Update stats
            document.getElementById('statLat').textContent = newPos[0].toFixed(4)+'°';
            document.getElementById('statLng').textContent = newPos[1].toFixed(4)+'°';
            document.getElementById('posLat').textContent  = newPos[0].toFixed(5);
            document.getElementById('posLng').textContent  = newPos[1].toFixed(5);
            document.getElementById('statSpeed').textContent = (0.5+Math.random()*1.5).toFixed(1)+' m/s';
            document.getElementById('posDir').textContent = directions[Math.floor(Math.random()*directions.length)];
            addLog('Position MAJ → '+newPos[0].toFixed(4)+', '+newPos[1].toFixed(4));
        }, 5000);
    });

    function centerOnRobot() {
        map.setView(robotMarker.getLatLng(), 15);
        addLog('Centré sur robot');
    }

    function toggleTrajectory() {
        showTraj = !showTraj;
        const btn = document.getElementById('trajBtn');
        if(showTraj) {
            trajectoryLine = L.polyline(trajPoints, {color:'#3b82f6', weight:2.5, opacity:0.8}).addTo(map);
            btn.classList.add('active');
            addLog('Trajectoire affichée');
        } else {
            if(trajectoryLine) { trajectoryLine.remove(); trajectoryLine=null; }
            btn.classList.remove('active');
            addLog('Trajectoire masquée');
        }
    }

    function locateMe() {
        if(!navigator.geolocation) return;
        navigator.geolocation.getCurrentPosition(pos=>{
            const lat=pos.coords.latitude, lng=pos.coords.longitude;
            const icon = L.divIcon({
                html:`<div style="width:14px;height:14px;background:#27ae60;border:2px solid #fff;border-radius:50%;box-shadow:0 0 8px rgba(39,174,96,0.7);"></div>`,
                iconSize:[14,14], iconAnchor:[7,7], className:''
            });
            if(userMarker) userMarker.setLatLng([lat,lng]);
            else userMarker = L.marker([lat,lng],{icon}).addTo(map).bindPopup('<b style="color:#27ae60;">Votre position</b>');
            map.setView([lat,lng],15);
            addLog('Position GPS: '+lat.toFixed(4)+', '+lng.toFixed(4));
        }, ()=>addLog('GPS indisponible'));
    }

    function resetMap() {
        map.setView([defaultLat,defaultLng],14);
        if(userMarker){userMarker.remove();userMarker=null;}
        if(trajectoryLine){trajectoryLine.remove();trajectoryLine=null;}
        trajPoints = [[defaultLat,defaultLng]];
        showTraj = false;
        document.getElementById('trajBtn').classList.remove('active');
        addLog('Carte réinitialisée');
    }
</script>

<style>
@keyframes pulse-robot {
    0%,100% { box-shadow: 0 0 12px rgba(192,57,43,0.7); }
    50%      { box-shadow: 0 0 22px rgba(192,57,43,1); transform: scale(1.08); }
}
</style>

</body>
</html>