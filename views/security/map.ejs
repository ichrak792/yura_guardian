<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/security.css">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
</head>
<body>
    <div class="dashboard-container">
        <aside class="sidebar">
            <div class="logo-section">
                
            </div>
            <nav class="sidebar-nav">
                
                <div class="nav-divider">Menu</div>
                <a href="/dashboard/security" class="nav-item"><span class="icon">🏠</span><span>Dashboard</span></a>
                <a href="/dashboard/history" class="nav-item"><span class="icon">⏱️</span><span>Historiques d'activités</span></a>
                <a href="/dashboard/camera" class="nav-item"><span class="icon">📹</span><span>Caméra</span></a>
                <a href="/dashboard/map" class="nav-item active"><span class="icon">🗺️</span><span>Map</span></a>
            </nav>
            <div class="sidebar-footer">
                <div class="user-profile">
                    <div class="user-avatar-small"><%= user.name.charAt(0).toUpperCase() %></div>
                    <div class="user-details"><div class="user-name-small"><%= user.name %></div></div>
                </div>
                <a href="/logout" class="logout-link-sec">🚪 Se déconnecter</a>
            </div>
        </aside>
        <main class="main-content">
            <header class="top-bar">
                <h1>ROBOT MAP</h1>
                <button class="logout-btn" onclick="window.location.href='/logout'">Se déconnecter</button>
            </header>
            <div class="content-wrapper">
                <div class="sec-map-section">
                    <div class="sec-map-controls">
                        <button class="ctrl-btn start-btn" onclick="locateMe()">📍 Ma position</button>
                        <button class="ctrl-btn stop-btn-sec" onclick="resetMap()">🔄 Reset</button>
                    </div>
                    <div id="secMap" style="width:100%; height:500px; border-radius:12px; border:2px solid rgba(255,255,255,0.1);"></div>
                </div>
            </div>
        </main>
    </div>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        const map = L.map('secMap').setView([36.8065, 10.1815], 13);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '© OpenStreetMap' }).addTo(map);
        const rIcon = L.divIcon({ html: '<div style="font-size:2rem; filter:drop-shadow(0 2px 4px rgba(0,0,0,0.5));">🤖</div>', iconSize: [40, 40], iconAnchor: [20, 40], className: '' });
        let marker = L.marker([36.8065, 10.1815], {icon: rIcon}).addTo(map).bindPopup('<b>Robot YURA GUARDIAN</b>').openPopup();

        function locateMe() {
            if (navigator.geolocation) {
                navigator.geolocation.getCurrentPosition(pos => {
                    marker.setLatLng([pos.coords.latitude, pos.coords.longitude]);
                    map.setView([pos.coords.latitude, pos.coords.longitude], 15);
                });
            }
        }
        function resetMap() {
            marker.setLatLng([36.8065, 10.1815]);
            map.setView([36.8065, 10.1815], 13);
        }
    </script>
</body>
</html>
