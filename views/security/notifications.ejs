<script>
    function updateStats() {
        const c = { danger:0, warning:0, info:0, success:0 };
        document.querySelectorAll('.alert-card').forEach(card => {
            const t = card.dataset.type;
            if(c[t] !== undefined) c[t]++;
        });
        document.getElementById('criticalCount').textContent = c.danger;
        document.getElementById('warningCount').textContent  = c.warning;
        document.getElementById('infoCount').textContent     = c.info;
        document.getElementById('successCount').textContent  = c.success;
        const total = c.danger + c.warning;
        document.getElementById('bellCount').textContent = total;
        document.getElementById('navCount').textContent  = total;
    }

    function filterAlerts(type, btn) {
        document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        document.querySelectorAll('.alerts-group').forEach(group => {
            if(type === 'all') {
                group.style.display = '';
            } else {
                group.style.display = group.dataset.group === type ? '' : 'none';
            }
        });
    }

    function searchAlerts(val) {
        const v = val.toLowerCase();
        document.querySelectorAll('.alert-card').forEach(card => {
            card.style.display = card.textContent.toLowerCase().includes(v) ? '' : 'none';
        });
    }

    function resolveAlert(btn) {
        const card = btn.closest('.alert-card');
        card.style.animation = 'slideOut 0.3s ease forwards';
        setTimeout(() => { card.remove(); updateStats(); }, 280);
    }

    function deleteAlert(btn) {
        const card = btn.closest('.alert-card');
        card.style.animation = 'slideOut 0.3s ease forwards';
        setTimeout(() => { card.remove(); updateStats(); }, 280);
    }

    function markAllRead() {
        document.querySelectorAll('.alert-new-badge').forEach(b => b.remove());
    }

    function deleteAllNotif() {
        document.querySelectorAll('.alert-card').forEach(card => {
            card.style.animation = 'slideOut 0.3s ease forwards';
        });
        setTimeout(() => {
            document.querySelectorAll('.alert-card').forEach(c => c.remove());
            updateStats();
        }, 300);
    }
</script>
