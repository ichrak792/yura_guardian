<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        :root {
            --rouge: #c0392b;
            --rouge-light: #e74c3c;
            --noir: #0a0a0a;
            --card: #111111;
            --card2: #161616;
            --border: rgba(192,57,43,0.18);
            --gris: #888;
            --gris2: #bbb;
        }
        body { font-family: 'Segoe UI', sans-serif; background: var(--noir); color: #fff; display: flex; min-height: 100vh; }
        .sidebar { width:300px; min-height:100vh; background:#0d0d0d; border-right:1px solid var(--border); display:flex; flex-direction:column; position:fixed; top:0; left:0; bottom:0; z-index:100; }
        .logo-section { padding:20px 18px; border-bottom:1px solid var(--border); display:flex; align-items:center; gap:14px; }
        .logo-name { font-size:1.1rem; font-weight:800; color:#fff; letter-spacing:2px; }
        .logo-sub  { font-size:0.65rem; color:var(--gris); letter-spacing:2px; text-transform:uppercase; }
        .robot-badge { margin:16px 16px 6px; padding:11px 18px; background:rgba(192,57,43,0.15); border:1px solid rgba(192,57,43,0.5); border-radius:8px; display:flex; align-items:center; gap:10px; font-size:0.78rem; font-weight:700; color:var(--rouge-light); letter-spacing:1px; }
        .badge-dot { width:9px; height:9px; background:var(--rouge-light); border-radius:50%; animation:blink 1.2s infinite; box-shadow:0 0 6px rgba(231,76,60,0.8); }
        @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.15} }
        .nav-section { padding:10px 0; flex:1; }
        .nav-label { font-size:0.62rem; font-weight:700; color:var(--gris); letter-spacing:2px; padding:14px 18px 6px; text-transform:uppercase; }
        .nav-item { display:flex; align-items:center; gap:14px; padding:12px 18px; color:#777; text-decoration:none; font-size:0.9rem; font-weight:500; border-left:2px solid transparent; transition:all 0.18s; }
        .nav-item:hover { color:#fff; background:rgba(192,57,43,0.07); }
        .nav-item.active { color:#fff; background:rgba(192,57,43,0.13); border-left-color:var(--rouge); font-weight:600; }
        .nav-icon-wrap { width:22px; height:22px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
        .nav-text { flex:1; }
        .nav-count { background:var(--rouge); color:#fff; font-size:0.65rem; font-weight:700; padding:3px 8px; border-radius:12px; }
        .sidebar-footer { border-top:1px solid var(--border); padding:10px 0; }
        .user-row { display:flex; align-items:center; gap:11px; padding:12px 18px; }
        .user-av { width:36px; height:36px; background:linear-gradient(135deg,var(--rouge),#7b241c); border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:0.9rem; font-weight:700; flex-shrink:0; }
        .user-name-s { font-size:0.85rem; font-weight:600; }
        .user-role-s { font-size:0.68rem; color:var(--gris); }
        .main-content { margin-left:300px; flex:1; display:flex; flex-direction:column; min-height:100vh; }
        .top-bar { height:52px; background:#0d0d0d; border-bottom:1px solid var(--border); display:flex; align-items:center; padding:0 24px; gap:14px; position:sticky; top:0; z-index:50; }
        .topbar-title { font-size:0.8rem; color:var(--gris); letter-spacing:1.5px; text-transform:uppercase; flex:1; }
        .topbar-right { display:flex; align-items:center; gap:10px; }
        .topbar-bell { position:relative; cursor:pointer; text-decoration:none; }
        .bell-badge { position:absolute; top:-4px; right:-4px; width:16px; height:16px; background:var(--rouge); border-radius:50%; font-size:0.6rem; color:#fff; font-weight:700; display:flex; align-items:center; justify-content:center; }
        .topbar-user { display:flex; align-items:center; gap:7px; background:rgba(192,57,43,0.12); border:1px solid rgba(192,57,43,0.35); padding:5px 14px; border-radius:20px; font-size:0.78rem; font-weight:600; color:var(--rouge-light); text-decoration:none; }
        .user-dot { width:7px; height:7px; background:var(--rouge-light); border-radius:50%; }
        .save-btn { display:flex; align-items:center; gap:7px; padding:7px 18px; background:var(--rouge); border:none; border-radius:8px; color:#fff; font-size:0.82rem; font-weight:700; cursor:pointer; transition:all 0.18s; }
        .save-btn:hover { background:var(--rouge-light); transform:translateY(-1px); }
        .content { padding:22px 24px; flex:1; }
        .page-header { display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:22px; }
        .page-header h1 { font-size:1.7rem; font-weight:800; }
        .page-header p  { font-size:0.82rem; color:var(--gris); margin-top:4px; }
        .settings-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:14px; margin-bottom:18px; }
        .settings-card { background:var(--card); border:1px solid rgba(255,255,255,0.06); border-radius:12px; padding:18px; transition:border-color 0.2s; }
        .settings-card:hover { border-color:rgba(192,57,43,0.3); }
        .card-head { display:flex; align-items:center; gap:10px; margin-bottom:16px; padding-bottom:12px; border-bottom:1px solid rgba(255,255,255,0.05); }
        .card-head-icon { width:36px; height:36px; background:rgba(192,57,43,0.15); border:1px solid rgba(192,57,43,0.25); border-radius:8px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
        .card-head-title { font-size:0.88rem; font-weight:700; color:#fff; text-transform:uppercase; letter-spacing:0.5px; }
        .setting-row { display:flex; align-items:center; justify-content:space-between; padding:9px 0; border-bottom:1px solid rgba(255,255,255,0.04); }
        .setting-row:last-child { border-bottom:none; padding-bottom:0; }
        .setting-label { font-size:0.82rem; color:var(--gris2); }
        .toggle-wrap { position:relative; width:38px; height:20px; flex-shrink:0; }
        .toggle-wrap input { opacity:0; width:0; height:0; position:absolute; }
        .toggle-slider { position:absolute; inset:0; background:#2a2a2a; border:1px solid rgba(255,255,255,0.08); border-radius:10px; cursor:pointer; transition:all 0.25s; }
        .toggle-slider::after { content:''; position:absolute; width:14px; height:14px; background:#555; border-radius:50%; top:2px; left:2px; transition:all 0.25s; }
        .toggle-wrap input:checked + .toggle-slider { background:rgba(192,57,43,0.5); border-color:rgba(192,57,43,0.7); }
        .toggle-wrap input:checked + .toggle-slider::after { left:20px; background:var(--rouge-light); }
        .setting-select { background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.09); border-radius:7px; color:#fff; font-size:0.78rem; padding:5px 10px; outline:none; cursor:pointer; transition:all 0.18s; }
        .setting-select:hover { border-color:rgba(192,57,43,0.4); }
        .setting-select option { background:#1a1a1a; }
        .range-wrap { display:flex; align-items:center; gap:8px; }
        .range-input { -webkit-appearance:none; appearance:none; width:100px; height:3px; background:rgba(255,255,255,0.1); border-radius:3px; outline:none; cursor:pointer; }
        .range-input::-webkit-slider-thumb { -webkit-appearance:none; width:14px; height:14px; background:var(--rouge); border-radius:50%; cursor:pointer; }
        .range-val { font-size:0.78rem; font-weight:700; color:var(--rouge-light); min-width:18px; text-align:center; }
        .card-action-btn { width:100%; padding:8px; background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); border-radius:8px; color:#888; font-size:0.78rem; font-weight:600; cursor:pointer; transition:all 0.18s; display:flex; align-items:center; justify-content:center; gap:6px; margin-top:7px; }
        .card-action-btn:hover { background:rgba(192,57,43,0.12); border-color:rgba(192,57,43,0.35); color:#fff; }
        .card-action-btn.primary { background:rgba(192,57,43,0.15); border-color:rgba(192,57,43,0.4); color:var(--rouge-light); }
        .info-row { display:flex; justify-content:space-between; align-items:center; padding:8px 0; border-bottom:1px solid rgba(255,255,255,0.04); }
        .info-row:last-child { border-bottom:none; }
        .info-lbl { font-size:0.75rem; color:var(--gris); }
        .info-val { font-size:0.78rem; font-weight:700; color:#fff; }
        .info-val.green { color:#27ae60; }
        .bottom-actions { display:flex; gap:10px; flex-wrap:wrap; }
        .bottom-btn { flex:1; min-width:180px; padding:11px 18px; border-radius:9px; font-size:0.85rem; font-weight:700; cursor:pointer; transition:all 0.18s; display:flex; align-items:center; justify-content:center; gap:7px; }
        .bottom-btn.primary { background:var(--rouge); border:none; color:#fff; }
        .bottom-btn.primary:hover { background:var(--rouge-light); transform:translateY(-2px); }
        .bottom-btn.secondary { background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); color:#888; }
        .bottom-btn.secondary:hover { background:rgba(255,255,255,0.08); color:#fff; }
        .bottom-btn.danger { background:rgba(192,57,43,0.1); border:1px solid rgba(192,57,43,0.3); color:var(--rouge-light); }
        .bottom-btn.danger:hover { background:rgba(192,57,43,0.2); border-color:var(--rouge); }
        .status-msg { padding:12px 18px; border-radius:9px; font-size:0.85rem; font-weight:600; text-align:center; display:none; margin-top:10px; }
        .status-msg.success { background:rgba(39,174,96,0.15); border:1px solid rgba(39,174,96,0.3); color:#27ae60; }
        .status-msg.error   { background:rgba(192,57,43,0.15); border:1px solid rgba(192,57,43,0.3); color:var(--rouge-light); }
    </style>
</head>
<body>

<!-- PASSWORD MODAL -->
<div id="passwordModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:999;align-items:center;justify-content:center;">
    <div style="background:#111;border:1px solid rgba(192,57,43,0.35);border-radius:14px;padding:28px;width:380px;max-width:90vw;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:22px;">
            <div style="font-size:1rem;font-weight:800;color:#fff;">Changer mot de passe</div>
            <button onclick="closePasswordModal()" style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:6px;width:28px;height:28px;color:#888;cursor:pointer;font-size:1rem;">✕</button>
        </div>
        <div style="display:flex;flex-direction:column;gap:12px;">
            <div>
                <div style="font-size:0.72rem;color:#888;margin-bottom:6px;text-transform:uppercase;letter-spacing:1px;">Mot de passe actuel</div>
                <input type="password" id="currentPassword" placeholder="••••••••" style="width:100%;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:8px;color:#fff;font-size:0.85rem;padding:9px 14px;outline:none;">
            </div>
            <div>
                <div style="font-size:0.72rem;color:#888;margin-bottom:6px;text-transform:uppercase;letter-spacing:1px;">Nouveau mot de passe</div>
                <input type="password" id="newPassword" placeholder="••••••••" style="width:100%;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:8px;color:#fff;font-size:0.85rem;padding:9px 14px;outline:none;">
            </div>
            <div>
                <div style="font-size:0.72rem;color:#888;margin-bottom:6px;text-transform:uppercase;letter-spacing:1px;">Confirmer mot de passe</div>
                <input type="password" id="confirmPassword" placeholder="••••••••" style="width:100%;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:8px;color:#fff;font-size:0.85rem;padding:9px 14px;outline:none;">
            </div>
        </div>
        <div style="display:flex;gap:10px;margin-top:22px;">
            <button onclick="closePasswordModal()" style="flex:1;padding:10px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:8px;color:#888;font-size:0.85rem;font-weight:600;cursor:pointer;">Annuler</button>
            <button onclick="submitChangePassword()" style="flex:1;padding:10px;background:#c0392b;border:none;border-radius:8px;color:#fff;font-size:0.85rem;font-weight:700;cursor:pointer;">Confirmer</button>
        </div>
    </div>
</div>

<!-- SIDEBAR -->
<aside class="sidebar">
    <div class="logo-section">
        <img src="/images/logo robot.png" alt="YURA" style="width:42px;height:42px;object-fit:contain;border-radius:8px;flex-shrink:0;">
        <div>
            <div class="logo-name">YURA</div>
            <div class="logo-sub">Guardian System</div>
        </div>
    </div>
    <div class="robot-badge">
        <div class="badge-dot"></div>
        <span>ROBOT EN LIGNE</span>
    </div>
    <div class="nav-section">
        <div class="nav-label">Contrôle</div>
        <a href="/dashboard/security" class="nav-item">
            <span class="nav-icon-wrap"><svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><rect x="1" y="1" width="6" height="6" rx="1"/><rect x="9" y="1" width="6" height="6" rx="1"/><rect x="1" y="9" width="6" height="6" rx="1"/><rect x="9" y="9" width="6" height="6" rx="1"/></svg></span>
            <span class="nav-text">Dashboard</span>
        </a>
        <a href="/dashboard/camera" class="nav-item">
            <span class="nav-icon-wrap"><svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M1 4a1 1 0 011-1h8a1 1 0 011 1v1.5l3-2v7l-3-2V12a1 1 0 01-1 1H2a1 1 0 01-1-1V4z"/></svg></span>
            <span class="nav-text">Live Feed</span>
        </a>
        <a href="/dashboard/map" class="nav-item">
            <span class="nav-icon-wrap"><svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M6 1l4 2 4-2v11l-4 2-4-2-4 2V3l4-2zm0 1.5L2 4.5v9l4-2 4 2 4-2v-9l-4 2-4-2z"/></svg></span>
            <span class="nav-text">Navigation</span>
        </a>
        <a href="/notifications" class="nav-item">
            <span class="nav-icon-wrap"><svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1a5 5 0 00-5 5v3l-1.5 2.5h13L13 9V6a5 5 0 00-5-5zm0 14a2 2 0 01-2-2h4a2 2 0 01-2 2z"/></svg></span>
            <span class="nav-text">Alertes</span>
            <span class="nav-count">3</span>
        </a>
        <a href="/dashboard/history" class="nav-item">
            <span class="nav-icon-wrap"><svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1a7 7 0 100 14A7 7 0 008 1zm0 2v5l3 3-1 1-3.5-3.5V3H8z"/></svg></span>
            <span class="nav-text">Historique</span>
        </a>
        <a href="/dashboard/settings" class="nav-item active">
            <span class="nav-icon-wrap"><svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M7.5 1l-.8 2.4a5 5 0 00-1.4.8L3 3.5l-1.5 2.6 1.9 1.5a5 5 0 000 1.8L1.5 11l1.5 2.6 2.3-.8a5 5 0 001.4.8L7.5 16h1l.8-2.4a5 5 0 001.4-.8l2.3.8L14.5 11l-1.9-1.5a5 5 0 000-1.8l1.9-1.5L13 3.5l-2.3.7a5 5 0 00-1.4-.8L8.5 1h-1zM8 6a2 2 0 110 4A2 2 0 018 6z"/></svg></span>
            <span class="nav-text">Paramètres</span>
        </a>
    </div>
    <div class="sidebar-footer">
        <div class="user-row">
            <div class="user-av"><%= user.name.charAt(0).toUpperCase() %></div>
            <div>
                <div class="user-name-s"><%= user.name %></div>
                <div class="user-role-s">Agent Sécurité</div>
            </div>
        </div>
        <a href="/logout" class="nav-item" style="color:#555;">
            <span class="nav-icon-wrap"><svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M6 2H3a1 1 0 00-1 1v10a1 1 0 001 1h3v-1.5H3.5v-9H6V2zm4.5 3.5L13 8l-2.5 2.5-1-1L11 8H6V6.5h5l-1.5-1.5 1-1z"/></svg></span>
            <span class="nav-text">Déconnexion</span>
        </a>
    </div>
</aside>

<!-- MAIN -->
<div class="main-content">
    <div class="top-bar">
        <span style="color:#888;margin-right:4px;"><svg width="18" height="18" viewBox="0 0 18 18" fill="#888"><rect y="3" width="18" height="2"/><rect y="8" width="18" height="2"/><rect y="13" width="18" height="2"/></svg></span>
        <span class="topbar-title">Paramètres du Système</span>
        <div class="topbar-right">
            <button class="save-btn" onclick="saveAllSettings()">
                <svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 1h7l2 2v9H2V1z"/><rect x="4" y="7" width="5" height="5"/><rect x="3" y="1" width="5" height="3"/></svg>
                Enregistrer
            </button>
            <a href="/notifications" class="topbar-bell">
                <svg width="18" height="18" viewBox="0 0 16 16" fill="#888"><path d="M8 1a5 5 0 00-5 5v3l-1.5 2.5h13L13 9V6a5 5 0 00-5-5zm0 14a2 2 0 01-2-2h4a2 2 0 01-2 2z"/></svg>
                <div class="bell-badge">3</div>
            </a>
            <a href="/dashboard/settings" class="topbar-user">
                <div class="user-dot"></div>Opérateur
            </a>
        </div>
    </div>

    <div class="content">
        <div class="page-header">
            <div>
                <h1>Paramètres</h1>
                <p>Configuration du système YURA Guardian</p>
            </div>
        </div>

        <div class="settings-grid">
            <!-- NOTIFICATIONS -->
            <div class="settings-card">
                <div class="card-head">
                    <div class="card-head-icon"><svg width="16" height="16" viewBox="0 0 16 16" fill="#c0392b"><path d="M8 1a5 5 0 00-5 5v3l-1.5 2.5h13L13 9V6a5 5 0 00-5-5zm0 14a2 2 0 01-2-2h4a2 2 0 01-2 2z"/></svg></div>
                    <span class="card-head-title">Notifications</span>
                </div>
                <div class="setting-row"><div><div class="setting-label">Alertes sonores</div></div><label class="toggle-wrap"><input type="checkbox" id="soundAlerts" checked><span class="toggle-slider"></span></label></div>
                <div class="setting-row"><div><div class="setting-label">Notifications push</div></div><label class="toggle-wrap"><input type="checkbox" id="pushNotif" checked><span class="toggle-slider"></span></label></div>
                <div class="setting-row"><div><div class="setting-label">Critiques uniquement</div></div><label class="toggle-wrap"><input type="checkbox" id="criticalOnly"><span class="toggle-slider"></span></label></div>
                <div class="setting-row"><div><div class="setting-label">Vibration mobile</div></div><label class="toggle-wrap"><input type="checkbox" id="vibration" checked><span class="toggle-slider"></span></label></div>
            </div>

            <!-- ROBOT -->
            <div class="settings-card">
                <div class="card-head">
                    <div class="card-head-icon"><svg width="16" height="16" viewBox="0 0 16 16" fill="#c0392b"><rect x="4" y="2" width="8" height="6" rx="1"/><rect x="3" y="8" width="10" height="5" rx="1"/><circle cx="6" cy="4" r="1"/><circle cx="10" cy="4" r="1"/><rect x="1" y="9" width="2" height="3" rx="1"/><rect x="13" y="9" width="2" height="3" rx="1"/></svg></div>
                    <span class="card-head-title">Robot</span>
                </div>
                <div class="setting-row">
                    <div><div class="setting-label">Vitesse</div></div>
                    <div class="range-wrap">
                        <input type="range" class="range-input" id="robotSpeed" min="1" max="10" value="5">
                        <span class="range-val" id="speedVal">5</span>
                    </div>
                </div>
                <div class="setting-row"><div><div class="setting-label">Sensibilité détection</div></div><select class="setting-select" id="motionSensitivity"><option value="low">Faible</option><option value="medium" selected>Moyenne</option><option value="high">Élevée</option></select></div>
                <div class="setting-row"><div><div class="setting-label">Patrouille auto</div></div><label class="toggle-wrap"><input type="checkbox" id="autoMode" checked><span class="toggle-slider"></span></label></div>
                <div class="setting-row"><div><div class="setting-label">Retour base auto</div></div><label class="toggle-wrap"><input type="checkbox" id="autoReturn"><span class="toggle-slider"></span></label></div>
            </div>

            <!-- CAMÉRA -->
            <div class="settings-card">
                <div class="card-head">
                    <div class="card-head-icon"><svg width="16" height="16" viewBox="0 0 16 16" fill="#c0392b"><path d="M1 4a1 1 0 011-1h8a1 1 0 011 1v1.5l3-2v7l-3-2V12a1 1 0 01-1 1H2a1 1 0 01-1-1V4z"/></svg></div>
                    <span class="card-head-title">Caméra</span>
                </div>
                <div class="setting-row"><div><div class="setting-label">Qualité vidéo</div></div><select class="setting-select" id="videoQuality"><option value="720p">720p</option><option value="1080p" selected>1080p</option><option value="4k">4K</option></select></div>
                <div class="setting-row"><div><div class="setting-label">Vision nocturne</div></div><label class="toggle-wrap"><input type="checkbox" id="nightVision" checked><span class="toggle-slider"></span></label></div>
                <div class="setting-row"><div><div class="setting-label">Enregistrement auto</div></div><label class="toggle-wrap"><input type="checkbox" id="autoRec" checked><span class="toggle-slider"></span></label></div>
                <div class="setting-row"><div><div class="setting-label">Détection mouvement</div></div><label class="toggle-wrap"><input type="checkbox" id="motionDetect" checked><span class="toggle-slider"></span></label></div>
            </div>

            <!-- SÉCURITÉ -->
            <div class="settings-card">
                <div class="card-head">
                    <div class="card-head-icon"><svg width="16" height="16" viewBox="0 0 16 16" fill="#c0392b"><path d="M8 1L2 4v5c0 4.5 3 7.5 6 8.5C11 16.5 14 13.5 14 9V4L8 1z"/></svg></div>
                    <span class="card-head-title">Sécurité</span>
                </div>
                <div class="setting-row"><div><div class="setting-label">Déconnexion auto</div></div><select class="setting-select" id="autoLogout"><option value="15">15 min</option><option value="30" selected>30 min</option><option value="60">1 heure</option><option value="0">Jamais</option></select></div>
                <div class="setting-row"><div><div class="setting-label">Double authentification</div></div><label class="toggle-wrap"><input type="checkbox" id="twoFA"><span class="toggle-slider"></span></label></div>
                <div class="setting-row"><div><div class="setting-label">Logs de sécurité</div></div><label class="toggle-wrap"><input type="checkbox" id="secLogs" checked><span class="toggle-slider"></span></label></div>
                <button class="card-action-btn" onclick="changePassword()">
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="5" width="8" height="6" rx="1"/><path d="M4 5V4a2 2 0 014 0v1"/></svg>
                    Changer mot de passe
                </button>
            </div>

            <!-- APPARENCE -->
            <div class="settings-card">
                <div class="card-head">
                    <div class="card-head-icon"><svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="#c0392b" stroke-width="1.5"><circle cx="8" cy="8" r="3"/><path d="M8 1v2M8 13v2M1 8h2M13 8h2M3.5 3.5l1.5 1.5M11 11l1.5 1.5M3.5 12.5l1.5-1.5M11 5l1.5-1.5"/></svg></div>
                    <span class="card-head-title">Apparence</span>
                </div>
                <div class="setting-row"><div><div class="setting-label">Mode sombre</div></div><label class="toggle-wrap"><input type="checkbox" id="darkMode" checked><span class="toggle-slider"></span></label></div>
                <div class="setting-row"><div><div class="setting-label">Vue compacte</div></div><label class="toggle-wrap"><input type="checkbox" id="compactView"><span class="toggle-slider"></span></label></div>
                <div class="setting-row"><div><div class="setting-label">Animations</div></div><label class="toggle-wrap"><input type="checkbox" id="animations" checked><span class="toggle-slider"></span></label></div>
                <div class="setting-row"><div><div class="setting-label">Thème</div></div>
                    <select class="setting-select" id="colorTheme">
                        <option value="red-black" selected>Rouge-Noir</option>
                        <option value="blue-black">Bleu-Noir</option>
                        <option value="green-black">Vert-Noir</option>
                    </select>
                </div>
            </div>

            <!-- SYSTÈME -->
            <div class="settings-card">
                <div class="card-head">
                    <div class="card-head-icon"><svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="#c0392b" stroke-width="1.5"><rect x="1" y="3" width="14" height="10" rx="1"/><line x1="5" y1="13" x2="5" y2="15"/><line x1="11" y1="13" x2="11" y2="15"/><line x1="3" y1="15" x2="13" y2="15"/></svg></div>
                    <span class="card-head-title">Informations Système</span>
                </div>
                <div class="info-row"><span class="info-lbl">Version YURA</span><span class="info-val">v2.1.0</span></div>
                <div class="info-row"><span class="info-lbl">Robot actif</span><span class="info-val green">YURA-001</span></div>
                <div class="info-row"><span class="info-lbl">Dernière MAJ</span><span class="info-val">Aujourd'hui 14:30</span></div>
                <div class="info-row"><span class="info-lbl">Espace disque</span><span class="info-val">45 GB / 100 GB</span></div>
                <div class="info-row"><span class="info-lbl">Statut serveur</span><span class="info-val green">En ligne</span></div>
                <button class="card-action-btn primary" onclick="checkUpdates()">
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10 6A4 4 0 112 6M2 3v3H5"/></svg>
                    Vérifier mises à jour
                </button>
            </div>
        </div>

        <div class="bottom-actions">
            <button class="bottom-btn primary" onclick="saveAllSettings()">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 1h8l2 2v10H2V1z"/><rect x="4" y="8" width="6" height="5"/><rect x="3" y="1" width="5" height="3"/></svg>
                Enregistrer tous les paramètres
            </button>
            <button class="bottom-btn secondary" onclick="resetSettings()">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 7A5 5 0 112 7M2 4v3H5"/></svg>
                Réinitialiser par défaut
            </button>
            <button class="bottom-btn danger" onclick="clearCache()">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="1,3 13,3"/><path d="M5 3V2h4v1M3 3l1 9h6l1-9"/></svg>
                Vider le cache
            </button>
        </div>

        <div class="status-msg" id="statusMsg"></div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {

    // ===== COLLECT =====
    function collectSettings() {
        return {
            darkMode:          document.getElementById('darkMode').checked,
            compactView:       document.getElementById('compactView').checked,
            animations:        document.getElementById('animations').checked,
            colorTheme:        document.getElementById('colorTheme').value,
            soundAlerts:       document.getElementById('soundAlerts').checked,
            pushNotif:         document.getElementById('pushNotif').checked,
            criticalOnly:      document.getElementById('criticalOnly').checked,
            vibration:         document.getElementById('vibration').checked,
            robotSpeed:        document.getElementById('robotSpeed').value,
            motionSensitivity: document.getElementById('motionSensitivity').value,
            autoMode:          document.getElementById('autoMode').checked,
            autoReturn:        document.getElementById('autoReturn').checked,
            videoQuality:      document.getElementById('videoQuality').value,
            nightVision:       document.getElementById('nightVision').checked,
            autoRec:           document.getElementById('autoRec').checked,
            motionDetect:      document.getElementById('motionDetect').checked,
            autoLogout:        document.getElementById('autoLogout').value,
            twoFA:             document.getElementById('twoFA').checked,
            secLogs:           document.getElementById('secLogs').checked,
        };
    }

    // ===== APPLY =====
    function applyLocally(s) {
        const root = document.documentElement;

        // DARK / LIGHT
        let lightStyle = document.getElementById('__yuraLight');
        if (s.darkMode === false) {
            if (!lightStyle) {
                lightStyle = document.createElement('style');
                lightStyle.id = '__yuraLight';
                document.head.appendChild(lightStyle);
            }
            lightStyle.textContent = `
                body { background: #f0f2f5 !important; color: #111 !important; }
                .sidebar { background: #fff !important; border-color: rgba(0,0,0,0.1) !important; }
                .top-bar { background: #fff !important; border-color: rgba(0,0,0,0.1) !important; }
                .settings-card { background: #fff !important; border-color: rgba(0,0,0,0.08) !important; box-shadow: 0 1px 6px rgba(0,0,0,0.06) !important; }
                .main-content, .content { background: #f0f2f5 !important; }
                .card-head { border-color: rgba(0,0,0,0.06) !important; }
                .card-head-title, .setting-label, h1, h2, h3, .user-name-s, .logo-name, .info-val { color: #111 !important; }
                .logo-sub, .user-role-s, .topbar-title, .info-lbl { color: #666 !important; }
                .nav-item { color: #555 !important; }
                .nav-item:hover { background: rgba(0,0,0,0.04) !important; color: #111 !important; }
                .nav-item.active { color: #c0392b !important; background: rgba(192,57,43,0.07) !important; }
                .setting-select { background: #f0f0f0 !important; border-color: rgba(0,0,0,0.12) !important; color: #111 !important; }
                .toggle-slider { background: #ddd !important; border-color: #ccc !important; }
                .info-row, .setting-row { border-color: rgba(0,0,0,0.06) !important; }
                .bottom-btn.secondary { background: rgba(0,0,0,0.05) !important; border-color: rgba(0,0,0,0.1) !important; color: #555 !important; }
                .card-action-btn { background: rgba(0,0,0,0.05) !important; border-color: rgba(0,0,0,0.1) !important; color: #555 !important; }
                .topbar-user { background: rgba(192,57,43,0.07) !important; border-color: rgba(192,57,43,0.2) !important; }
                .robot-badge { background: rgba(192,57,43,0.07) !important; border-color: rgba(192,57,43,0.25) !important; }
            `;
        } else {
            if (lightStyle) lightStyle.remove();
        }

        // COMPACT
        let compactStyle = document.getElementById('__yuraCompact');
        if (s.compactView) {
            if (!compactStyle) {
                compactStyle = document.createElement('style');
                compactStyle.id = '__yuraCompact';
                document.head.appendChild(compactStyle);
            }
            compactStyle.textContent = `
                .settings-card { padding: 10px 12px !important; }
                .setting-row { padding: 5px 0 !important; }
                .setting-label { font-size: 0.75rem !important; }
                .card-head { margin-bottom: 8px !important; padding-bottom: 8px !important; }
            `;
        } else {
            if (compactStyle) compactStyle.remove();
        }

        // ANIMATIONS
        let noAnim = document.getElementById('__noAnim');
        if (!s.animations) {
            if (!noAnim) {
                noAnim = document.createElement('style');
                noAnim.id = '__noAnim';
                noAnim.textContent = '* { animation: none !important; transition: none !important; }';
                document.head.appendChild(noAnim);
            }
        } else {
            if (noAnim) noAnim.remove();
        }

        // COLOR THEME
        if (s.colorTheme === 'blue-black') {
            root.style.setProperty('--rouge', '#2563eb');
            root.style.setProperty('--rouge-light', '#3b82f6');
            root.style.setProperty('--border', 'rgba(37,99,235,0.18)');
        } else if (s.colorTheme === 'green-black') {
            root.style.setProperty('--rouge', '#16a34a');
            root.style.setProperty('--rouge-light', '#22c55e');
            root.style.setProperty('--border', 'rgba(22,163,74,0.18)');
        } else {
            root.style.setProperty('--rouge', '#c0392b');
            root.style.setProperty('--rouge-light', '#e74c3c');
            root.style.setProperty('--border', 'rgba(192,57,43,0.18)');
        }
    }

    // ===== LOAD =====
    function loadSavedSettings() {
        try {
            const raw = localStorage.getItem('yuraSettings');
            if (!raw) return;
            const s = JSON.parse(raw);
            const sc = (id, val) => { const el = document.getElementById(id); if (el && val !== undefined) el.checked = val; };
            const sv = (id, val) => { const el = document.getElementById(id); if (el && val !== undefined) el.value   = val; };
            sc('darkMode', s.darkMode); sc('compactView', s.compactView); sc('animations', s.animations);
            sc('soundAlerts', s.soundAlerts); sc('pushNotif', s.pushNotif); sc('criticalOnly', s.criticalOnly);
            sc('vibration', s.vibration); sc('autoMode', s.autoMode); sc('autoReturn', s.autoReturn);
            sc('nightVision', s.nightVision); sc('autoRec', s.autoRec); sc('motionDetect', s.motionDetect);
            sc('twoFA', s.twoFA); sc('secLogs', s.secLogs);
            sv('colorTheme', s.colorTheme); sv('motionSensitivity', s.motionSensitivity);
            sv('videoQuality', s.videoQuality); sv('autoLogout', s.autoLogout);
            if (s.robotSpeed) {
                document.getElementById('robotSpeed').value = s.robotSpeed;
                document.getElementById('speedVal').textContent = s.robotSpeed;
            }
            applyLocally(s);
        } catch(e) { console.error(e); }
    }

    // ===== LIVE PREVIEW =====
    document.querySelectorAll('input[type="checkbox"], select').forEach(function(el) {
        el.addEventListener('change', function() { applyLocally(collectSettings()); });
    });
    document.getElementById('robotSpeed').addEventListener('input', function() {
        document.getElementById('speedVal').textContent = this.value;
    });

    // ===== STATUS =====
    function showStatus(msg, type) {
        const el = document.getElementById('statusMsg');
        el.textContent = msg; el.className = 'status-msg ' + type; el.style.display = 'block';
        setTimeout(() => el.style.display = 'none', 4000);
    }

    // ===== GLOBAL FUNCTIONS =====
    window.saveAllSettings = function() {
        const s = collectSettings();
        localStorage.setItem('yuraSettings', JSON.stringify(s));
        fetch('/dashboard/settings/save', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(s) })
        .then(r => r.json())
        .then(d => showStatus(d.success ? '✓ '+d.message : '✗ '+d.message, d.success ? 'success' : 'error'))
        .catch(() => showStatus('✓ Paramètres enregistrés localement', 'success'));
    };

    window.resetSettings = function() {
        if (confirm('Réinitialiser tous les paramètres?')) { localStorage.removeItem('yuraSettings'); location.reload(); }
    };

    window.clearCache = function() {
        if (confirm('Vider le cache?')) { localStorage.clear(); showStatus('✓ Cache vidé', 'success'); }
    };

    window.changePassword = function() {
        document.getElementById('passwordModal').style.display = 'flex';
    };

    window.closePasswordModal = function() {
        document.getElementById('passwordModal').style.display = 'none';
        document.getElementById('currentPassword').value = '';
        document.getElementById('newPassword').value = '';
        document.getElementById('confirmPassword').value = '';
    };

    window.submitChangePassword = function() {
        const cp = document.getElementById('currentPassword').value;
        const np = document.getElementById('newPassword').value;
        const cf = document.getElementById('confirmPassword').value;
        if (!cp || !np || !cf) { showStatus('✗ Remplissez tous les champs', 'error'); window.closePasswordModal(); return; }
        fetch('/dashboard/settings/change-password', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({ currentPassword:cp, newPassword:np, confirmPassword:cf }) })
        .then(r => r.json())
        .then(d => { window.closePasswordModal(); showStatus(d.success ? '✓ '+d.message : '✗ '+d.message, d.success ? 'success' : 'error'); })
        .catch(() => { window.closePasswordModal(); showStatus('✗ Erreur serveur', 'error'); });
    };

    window.checkUpdates = function() { showStatus('✓ Version v2.1.0 — Aucune mise à jour', 'success'); };

    // START
    loadSavedSettings();
});
</script>
</body>
</html>