<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/signin.css">
</head>
<body>
    <div class="signin-container">
        <!-- Left Panel -->
        <div class="left-panel">
            <div class="left-content">
                <div class="welcome-text-wrapper">
                    <h1 class="welcome-text">BIENVENUE!</h1>
                    <div class="text-decoration"></div>
                </div>
                <p class="robot-desc">Je suis le robot Yura. Entrez dans mon univers et découvrez mes fonctionnalités avancées de sécurité.</p>
                
                <div class="features-vertical">
                    <div class="feature-item">
                        <span class="feature-icon"></span>
                        <p>Robotique Avancée</p>
                    </div>
                    <div class="feature-item">
                        <span class="feature-icon"></span>
                        <p>Surveillance 24/7</p>
                    </div>
                    <div class="feature-item">
                        <span class="feature-icon"></span>
                        <p>Sécurité Totale</p>
                    </div>
                </div>
            </div>

            <!-- Animated Background Left -->
            <div class="animated-bg-left">
                <div class="gradient-circle circle-1"></div>
                <div class="gradient-circle circle-2"></div>
            </div>
        </div>

        <!-- Right Panel -->
        <div class="right-panel">
            <!-- Animated Background Right -->
            <div class="animated-bg-right">
                <div class="gradient-circle circle-3"></div>
                <div class="gradient-circle circle-4"></div>
            </div>

            <div class="signin-box">
                <div class="header-section">
                    <div class="logo-title-row">
                        <div class="logo-wrapper">
                            <img src="/images/logo robot.png" alt="YURA GUARDIAN" class="signin-logo" loading="lazy">
                            <div class="logo-ring"></div>
                        </div>
                        <div class="header-text">
                            <h2 class="signin-title">Connexion</h2>
                            <p class="signin-subtitle">Accédez à votre compte YURA</p>
                        </div>
                    </div>
                </div>

                <% if (error) { %>
                    <div class="error-message">
                        <span class="error-icon">⚠️</span>
                        <span><%= error %></span>
                    </div>
                <% } %>

                <form action="/signin" method="POST" class="signin-form" id="signinForm">
                    <!-- Identifiant Field -->
                    <div class="form-group">
                        <label for="identifiant" class="form-label">
                            <span class="label-icon"></span>
                            <span>Identifiant</span>
                        </label>
                        <div class="input-wrapper">
                            <input 
                                type="text" 
                                id="identifiant" 
                                name="identifiant" 
                                required 
                                placeholder="Entrez votre identifiant"
                                class="form-input"
                            >
                            <span class="input-focus-border"></span>
                        </div>
                        <span class="input-hint">Votre nom d'utilisateur unique</span>
                    </div>

                    <!-- Email Field -->
                    <div class="form-group">
                        <label for="email" class="form-label">
                            <span class="label-icon"></span>
                            <span>Adresse email</span>
                        </label>
                        <div class="input-wrapper">
                            <input 
                                type="email" 
                                id="email" 
                                name="email" 
                                required 
                                placeholder="exemple@yura.com"
                                class="form-input"
                            >
                            <span class="input-focus-border"></span>
                        </div>
                        <span class="input-hint">Votre email associé au compte</span>
                    </div>

                    <!-- Password Field -->
                    <div class="form-group">
                        <label for="password" class="form-label">
                            <span class="label-icon"></span>
                            <span>Mot de passe</span>
                        </label>
                        <div class="input-wrapper password-wrapper">
                            <input 
                                type="password" 
                                id="password" 
                                name="password" 
                                required 
                                placeholder="••••••••"
                                class="form-input"
                            >
                            <button type="button" class="toggle-password" onclick="togglePassword()">
                                <span id="eyeIcon"></span>
                            </button>
                            <span class="input-focus-border"></span>
                        </div>
                        <a href="#" class="forgot-link">Mot de passe oublié?</a>
                    </div>

                    <!-- Remember Me -->
                    <div class="remember-section">
                        <label class="checkbox-label">
                            <input type="checkbox" name="remember" class="checkbox-input">
                            <span class="checkbox-custom"></span>
                            <span class="checkbox-text">Rester connecté</span>
                        </label>
                    </div>

                    <!-- Submit Button -->
                    <button type="submit" class="signin-btn" id="signinBtn">
                        <span class="btn-text">Se connecter</span>
                        <span class="btn-arrow">→</span>
                        <span class="btn-loader" style="display: none;">
                            <span class="loader-dot"></span>
                        </span>
                    </button>
                </form>

                <!-- Footer Text -->
                <div class="signin-footer">
                    <p>Besoin d'aide? <a href="#" class="footer-link">Contactez le support</a></p>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Toggle Password Visibility
        function togglePassword() {
            const passwordInput = document.getElementById('password');
            const eyeIcon = document.getElementById('eyeIcon');
            
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                eyeIcon.textContent = '👁️‍🗨️';
            } else {
                passwordInput.type = 'password';
                eyeIcon.textContent = '👁️';
            }
        }

        // Form Submission Handler
        const signinForm = document.getElementById('signinForm');
        const signinBtn = document.getElementById('signinBtn');

        signinForm.addEventListener('submit', function(e) {
            signinBtn.disabled = true;
            const btnText = signinBtn.querySelector('.btn-text');
            const btnLoader = signinBtn.querySelector('.btn-loader');
            
            btnText.style.opacity = '0';
            btnLoader.style.display = 'inline-block';
            signinBtn.style.pointerEvents = 'none';
        });

        // Real-time Input Validation
        const identifiantInput = document.getElementById('identifiant');
        const emailInput = document.getElementById('email');
        const passwordInput = document.getElementById('password');

        [identifiantInput, emailInput, passwordInput].forEach(input => {
            input.addEventListener('input', function() {
                this.parentElement.parentElement.classList.add('filled');
            });

            input.addEventListener('blur', function() {
                if (!this.value) {
                    this.parentElement.parentElement.classList.remove('filled');
                }
            });
        });

        // Enter key submit
        [identifiantInput, emailInput, passwordInput].forEach(input => {
            input.addEventListener('keypress', function(e) {
                if (e.key === 'Enter' && identifiantInput.value && emailInput.value && passwordInput.value) {
                    signinForm.submit();
                }
            });
        });

        // Auto-remove error message after 5 seconds
        const errorMsg = document.querySelector('.error-message');
        if (errorMsg) {
            setTimeout(() => {
                errorMsg.style.animation = 'slideOut 0.4s ease forwards';
                setTimeout(() => errorMsg.remove(), 400);
            }, 5000);
        }
    </script>
</body>
</html>